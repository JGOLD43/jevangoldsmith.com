    {
      "name": "dist-static",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('./scripts/_lib/static-server.js').serve('dist', 8765).then(() => console.log('serving dist on http://127.0.0.1:8765'))"],
      "port": 8765
