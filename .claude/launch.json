{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "astro-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 4321
    },
    {
      "name": "astro-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "--prefix", "site-astro", "preview"],
      "port": 4321
    },
    {
      "name": "firebase-hosting-emulator",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["firebase", "emulators:start", "--only", "hosting"],
      "port": 5000
    },
    {
      "name": "dist-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "dist", "-p", "8765", "-c-1", "--gzip"],
      "port": 8765
    }
  ]
}
