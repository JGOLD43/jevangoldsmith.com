---
// Shared layout. Ported from _src/layouts/base.html.
//
// mirrors the legacy structure (title, description, canonical, og,
// twitter, JSON-LD slot). Later phases will introduce a typed <Seo> component
// that produces byte-identical <head> output to satisfy the SEO fixture.
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import SeoRelated from '../components/SeoRelated.astro';
import { SITE_NAME, DEFAULT_OG_IMAGE, type BreadcrumbStep, type PageType } from '../lib/seo';
import { bodyClassFor, currentPageFromUrl } from '../lib/chrome';
// Critical-CSS-inline + async-load was tried and reverted: it cut FCP
// modestly but caused a major CLS regression (0.084 → 0.726) when full
// styles arrived. Below-fold layout would jump every render. The 187KB
// legacy-style.css is the FCP bottleneck; the real fix is purging unused
// selectors or migrating to per-page Tailwind utilities — both larger
// projects than the parity refactor.

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  bodyClass?: string;
  /** Pages like /meet replace the global navbar with their own header. */
  noChrome?: boolean;
  /** schema.org page type for JSON-LD. Defaults to "WebPage". */
  pageType?: PageType;
  /** Breadcrumb trail. Defaults to Home → current page. */
  breadcrumbs?: BreadcrumbStep[];
  /** Skip JSON-LD (e.g. for /data-smoke or other non-public pages). */
  noJsonLd?: boolean;
  /** Per-page schema.org @graph nodes (Article, Book, Movie, ItemList, ...). */
  extraSchema?: Array<Record<string, unknown>>;
  /** Skip the auto SeoRelated section (e.g. for pages where the body owns it). */
  noSeoRelated?: boolean;
  /** Extra <script src="/js/X.js"> tags to load before the closing body tag.
   * Mirrors the per-page script bundles the legacy build emits via
   * scripts/legacy-build/build/collection-config.js. Order is preserved. */
  scripts?: string[];
}

const _currentPage = currentPageFromUrl(Astro.url.pathname);
const {
  title,
  description = '',
  canonical = '',
  ogType = 'website',
  ogImage = DEFAULT_OG_IMAGE,
  bodyClass = bodyClassFor(_currentPage),
  noChrome = false,
  pageType = 'WebPage',
  breadcrumbs,
  noJsonLd = false,
  extraSchema,
  noSeoRelated = false,
  scripts = []
} = Astro.props;

const siteName = SITE_NAME;

// Derive the page slug from the current URL so SeoRelated.astro can look up
// the matching legacy related-cards entry without each page passing a prop.
const rawPath = Astro.url.pathname.replace(/^\/+|\/+$/g, '');
const seoSlug = rawPath === '' ? 'index' : rawPath.replace(/\.html$/, '').split('/').pop()!;

// per-page preconnect hints for cross-origin image hosts. One
// DNS+TLS round-trip up front beats paying it on every <img> request.
const preconnectOrigins: string[] = [];
if (seoSlug === 'movies') preconnectOrigins.push('https://a.ltrbxd.com');
if (seoSlug === 'videos') preconnectOrigins.push('https://i.ytimg.com');
// Note: /adventures used to preconnect to images.unsplash.com, but the
// build pipeline now self-hosts every Unsplash hero (assets:optimize +
// html-normalize rewrite to /images/generated/remote/...). The browser
// no longer crosses the third-party origin, so the hint was wasted.

// Cheap dns-prefetch on entry pages (index, search) so the user is
// already DNS-warm if they navigate into a collection page that uses
// these hosts. Doesn't open a TLS connection like preconnect — just
// resolves the name, ~10-30ms saved on the next nav.
const dnsPrefetchOrigins: string[] = [];
if (seoSlug === 'index' || seoSlug === 'search') {
  // unsplash + openlibrary are self-hosted post-build, so no DNS to prime.
  dnsPrefetchOrigins.push(
    'https://a.ltrbxd.com',
    'https://i.ytimg.com'
  );
}
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* FOUC guard: set data-theme synchronously before first paint so the
        page renders in the user's resolved theme. The full theme module
        (toggle button, system-pref listener) still runs at end of body —
        this only fixes the initial paint. ~120 bytes minified. */}
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('jg-theme')
            || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', t);
        } catch (_) { /* private mode / SSR can't read storage */ }
      })();
    </script>
    <meta name="theme-color" content="#F5F3ED" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121212" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    <link rel="stylesheet" href="/css/legacy-style.css" fetchpriority="high" />
    {preconnectOrigins.map((origin) => (
      <link rel="preconnect" href={origin} crossorigin />
    ))}
    {dnsPrefetchOrigins.map((origin) => (
      <link rel="dns-prefetch" href={origin} />
    ))}
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title={`${SITE_NAME} — RSS Feed`} />
    <link rel="alternate" type="application/json" href="/api/v1/index.json" title="Agent API index" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="Agent instructions" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    {!noChrome && <Nav />}
    <slot />
    {!noChrome && !noSeoRelated && <SeoRelated slug={seoSlug} />}
    {!noChrome && <Footer />}
    {scripts.map((src) =>
      <script is:inline src={src} defer></script>
    )}
    <slot name="scripts" />
    <script>
      import '../scripts/theme.ts';
    </script>
    {/* Phase E: register the repeat-visit service worker. The SW caches
        hashed assets cache-first and HTMLs network-first with a short
        timeout, so cold visits behave normally and warm visits hit local
        cache for nav + page CSS + JS bundles. Adds ~300 bytes of inline
        JS; no harm if the browser disables SW. */}
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js').catch(() => {});
        });
      }
    </script>
    {/* Phase H: Chrome-style Speculation Rules — prerender same-origin
        nav links on hover/touchstart. The browser eagerly fetches +
        renders the next page in a hidden tab; clicking the link swaps
        in the prerendered document instantly (sub-100ms FCP for the
        second navigation). Excludes API endpoints, large assets, and
        auth-shaped URLs to keep cost predictable. Browsers without
        speculation-rules support ignore the block. */}
    <script type="speculationrules" is:inline set:html={JSON.stringify({
      prerender: [{
        where: {
          and: [
            { href_matches: '/*.html' },
            { not: { href_matches: '/data-smoke.html' } },
            { not: { href_matches: '/dateme.html' } },
            { not: { href_matches: '/meet.html' } }
          ]
        },
        eagerness: 'moderate'
      }],
      prefetch: [{
        where: { href_matches: '/*.html' },
        eagerness: 'moderate'
      }]
    })} />
    {/* Inline script: hover-prefetch fallback for browsers without
        Speculation Rules support (older Firefox / Safari). Adds a
        <link rel="prefetch"> on first hover/touchstart on a same-origin
        anchor. Skipped when Speculation Rules are supported — Chrome's
        prerender already covers hover and runs strictly more work than
        a bare prefetch, so doubling up just wastes bandwidth. */}
    <script is:inline>
      (() => {
        if (HTMLScriptElement.supports?.('speculationrules')) return;
        const seen = new Set();
        const prefetch = (href) => {
          if (seen.has(href)) return;
          seen.add(href);
          const l = document.createElement('link');
          l.rel = 'prefetch';
          l.href = href;
          document.head.appendChild(l);
        };
        const onHover = (e) => {
          const a = e.target.closest('a[href]');
          if (!a) return;
          if (a.origin !== location.origin) return;
          if (a.href === location.href) return;
          if (!navigator.onLine) return;
          prefetch(a.href);
        };
        addEventListener('mouseover', onHover, { passive: true });
        addEventListener('touchstart', onHover, { passive: true });
      })();
    </script>
    {/* JSON-LD at end of <body>: ~4KB structured-data block was previously
        in <head> where it stalled the parser before reaching <body>.
        Crawlers (Google, Bing, ClaudeBot, etc.) read JSON-LD anywhere in
        the document. Saves ~30-50ms FCP under CPU throttle, no behavior
        change for SEO. */}
    {!noJsonLd && canonical && (
      <JsonLd
        canonical={canonical}
        title={title}
        description={description}
        pageType={pageType}
        image={ogImage}
        breadcrumbs={breadcrumbs}
        extraSchema={extraSchema}
      />
    )}
  </body>
</html>
