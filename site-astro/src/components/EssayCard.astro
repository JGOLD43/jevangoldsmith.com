---
import type { CollectionEntry } from 'astro:content';

interface Props { entry: CollectionEntry<'essays'> }
const { entry } = Astro.props;
const e = entry.data;
---
<article class="article-full" data-essay-id={entry.id} data-category={e.category ?? ''}>
  <header class="article-header">
    {e.date && <p class="article-date">{e.date}{e.category ? ` · ${e.category}` : ''}</p>}
    <h2>{e.title}</h2>
    {e.subtitle && <p class="article-subtitle">{e.subtitle}</p>}
  </header>
  <div class="article-content" set:html={e.content} />
</article>
