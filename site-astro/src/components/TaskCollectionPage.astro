---
// Phase 3: Shared task-list collection wrapper (projects, challenges).
//
// Uses the existing renderTaskListMain string template internally so HTML
// output is byte-identical to the previous per-page composition.

import Base from '../layouts/Base.astro';
import { renderTaskListMain } from '../lib/collection-sections';
import type { TaskListConfig } from '../lib/collection-sections';

interface Props {
  items: any[];
  config: TaskListConfig;
  renderCard: (item: any) => string;
  title: string;
  description: string;
  canonical: string;
  pageType?: 'CollectionPage' | 'WebPage' | 'AboutPage' | 'ContactPage';
}

const { items, config, renderCard, title, description, canonical, pageType = 'CollectionPage' } = Astro.props;
const main = renderTaskListMain(items, config, renderCard);
---
<Base
  title={title}
  description={description}
  canonical={canonical}
  pageType={pageType}
>
  <Fragment set:html={main} />
</Base>
