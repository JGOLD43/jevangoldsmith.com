---
// Single person card — wrapped in <a> so the whole card opens the detail page.
import type { CollectionEntry } from 'astro:content';

interface Props { entry: CollectionEntry<'people'> }
const { entry } = Astro.props;
const p = entry.data;
const search = (p.searchText ?? `${p.name ?? ''} ${p.title ?? ''} ${p.lesson ?? ''}`).trim();
const href = `/people/${entry.id}.html`;
---
<a
  href={href}
  class="person-card person-card-link"
  data-category={p.category ?? ''}
  data-person-id={entry.id}
  data-search={search}
  data-cta-id={`person-${entry.id}`}
  data-cta-location="people"
>
  <div class="person-image-container">
    {p.image && (
      <img
        src={`/${p.image}`}
        alt={p.name ?? ''}
        class="person-image"
        srcset={p.srcset ?? undefined}
        sizes="(max-width: 768px) 42vw, 220px"
        width="400"
        height="400"
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
  <div class="person-info">
    <h3 class="person-name">{p.name}</h3>
    {p.title && <p class="person-title">{p.title}</p>}
    {p.lesson && <p class="person-lesson">{p.lesson}</p>}
  </div>
</a>
