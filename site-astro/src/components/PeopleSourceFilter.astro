<div class="sidebar-filter-section people-source-filter" aria-label="Filter people by source type">
  <div class="filter-header">
    <div class="filter-label">Source</div>
  </div>
  <div class="people-source-filter-list" role="group" aria-label="People source type">
    <button type="button" class="people-source-filter-btn active" data-action="filterPeopleSource" data-action-args="all" data-action-this="true">
      <span class="people-source-label">All</span>
      <span class="people-source-count" id="people-source-count-all">0</span>
    </button>
    <button type="button" class="people-source-filter-btn" data-action="filterPeopleSource" data-action-args="nonfiction" data-action-this="true">
      <span class="people-source-label">Non-fiction</span>
      <span class="people-source-count" id="people-source-count-nonfiction">0</span>
    </button>
    <button type="button" class="people-source-filter-btn" data-action="filterPeopleSource" data-action-args="fiction" data-action-this="true">
      <span class="people-source-label">Fiction</span>
      <span class="people-source-count" id="people-source-count-fiction">0</span>
    </button>
  </div>
</div>
