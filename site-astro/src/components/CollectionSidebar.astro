---
// Shared left sidebar for collection pages (books, movies, people, etc.)
// Mirrors legacy structure — search input, optional category filters, collapse
// toggle. Categories prop is optional; pages without distinct categories can
// pass [] and the filter section will be omitted.

interface Category {
  key: string;
  label: string;
  count?: number;
}

interface Props {
  /** ID prefix for sidebar elements, e.g. 'people' → people-sidebar, people-search. */
  pageKey: string;
  /** Category list rendered as filter buttons. Pass [] to skip. */
  categories?: Category[];
  /** Placeholder for the search input. */
  searchPlaceholder?: string;
  /** Total item count, shown next to "All". */
  totalCount?: number;
}

const {
  pageKey,
  categories = [],
  searchPlaceholder = 'Search...',
  totalCount
} = Astro.props;

const sidebarId = `${pageKey}-sidebar`;
const searchId = `${pageKey}-search`;
const clearId = `${pageKey}-search-clear-btn`;
---
<aside class="collection-sidebar" id={sidebarId}>
  <div class="sidebar-header">
    <button class="sidebar-collapse-btn" type="button" aria-label="Collapse sidebar" data-collection-sidebar-toggle={pageKey}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
        <line x1="9" y1="3" x2="9" y2="21" />
      </svg>
    </button>
    <span class="sidebar-browse-label">Browse</span>
  </div>

  <div class="sidebar-search">
    <div class="search-bubble">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input
        type="text"
        class="collection-search-input"
        id={searchId}
        placeholder={searchPlaceholder}
        autocomplete="off"
        data-collection-search={pageKey}
      />
      <button class="search-clear-btn" id={clearId} type="button" style="display: none;" aria-label="Clear search" data-collection-search-clear={pageKey}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  {categories.length > 0 && (
    <div class="sidebar-filter-section" aria-label={`Filter ${pageKey} by category`}>
      <div class="filter-header">
        <span class="filter-label">Categories</span>
      </div>
      <div class="sidebar-filter-list">
        <button class="sidebar-filter-btn active" type="button" data-collection-filter={pageKey} data-filter-key="all">
          <span class="filter-btn-label">All</span>
          {totalCount !== undefined && <span class="filter-btn-count">{totalCount}</span>}
        </button>
        {categories.map((c) => (
          <button class="sidebar-filter-btn" type="button" data-collection-filter={pageKey} data-filter-key={c.key}>
            <span class="filter-btn-label">{c.label}</span>
            {c.count !== undefined && <span class="filter-btn-count">{c.count}</span>}
          </button>
        ))}
      </div>
    </div>
  )}
</aside>

<script>
  // Lightweight client wiring: search filters cards by data-search attribute,
  // category filter shows only cards with matching data-category, collapse
  // toggles a class on the parent layout. Works for any page that includes
  // CollectionSidebar.
  document.querySelectorAll('[data-collection-search]').forEach((input) => {
    const pageKey = (input as HTMLElement).dataset.collectionSearch!;
    const layout = document.getElementById(`${pageKey}-layout`);
    const clearBtn = document.querySelector(`[data-collection-search-clear="${pageKey}"]`) as HTMLElement | null;
    if (!layout) return;
    const cards = layout.querySelectorAll<HTMLElement>('[data-search], [data-category]');

    function applyFilter() {
      const q = ((input as HTMLInputElement).value ?? '').toLowerCase().trim();
      const activeBtn = document.querySelector<HTMLElement>(`[data-collection-filter="${pageKey}"].active`);
      const cat = activeBtn?.dataset.filterKey ?? 'all';
      let visible = 0;
      cards.forEach((card) => {
        const haystack = (card.dataset.search ?? '').toLowerCase();
        const cardCat = (card.dataset.category ?? '').toLowerCase();
        const matchQ = !q || haystack.includes(q);
        const matchC = cat === 'all' || cardCat === cat.toLowerCase();
        const show = matchQ && matchC;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (clearBtn) clearBtn.style.display = q ? '' : 'none';
    }

    input.addEventListener('input', applyFilter);
    clearBtn?.addEventListener('click', () => {
      (input as HTMLInputElement).value = '';
      applyFilter();
    });
    document.querySelectorAll<HTMLElement>(`[data-collection-filter="${pageKey}"]`).forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll<HTMLElement>(`[data-collection-filter="${pageKey}"]`).forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter();
      });
    });
  });

  document.querySelectorAll('[data-collection-sidebar-toggle]').forEach((btn) => {
    const pageKey = (btn as HTMLElement).dataset.collectionSidebarToggle!;
    const layout = document.getElementById(`${pageKey}-layout`);
    btn.addEventListener('click', () => layout?.classList.toggle('sidebar-collapsed'));
  });
</script>
