---
// Stats panel for the People page. Mirrors the others — build-time
// derivation, zero runtime fetches.

interface PersonLite {
  name?: string | null;
  category?: string | null;
  sourceType?: string | null;
}

interface Props { people: PersonLite[]; }

const { people } = Astro.props as Props;
const list = Array.isArray(people) ? people : [];

const total = list.length;

const sourceCounts: Record<string, number> = {};
list.forEach((p) => {
  const s = (p.sourceType || '').trim();
  if (!s) return;
  sourceCounts[s] = (sourceCounts[s] || 0) + 1;
});
const profiles = sourceCounts['profile'] || 0;
const peopleOnly = total - profiles;

const categoryCounts: Record<string, number> = {};
list.forEach((p) => {
  const c = (p.category || '').trim();
  if (!c) return;
  categoryCounts[c] = (categoryCounts[c] || 0) + 1;
});
const topCategories = Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]).slice(0, 6);
const categoryMax = topCategories[0]?.[1] || 1;
---

<div class="stats-headline-grid">
  <div class="stats-headline-card"><div class="stats-headline-value">{total.toLocaleString()}</div><div class="stats-headline-label">Total people</div></div>
  <div class="stats-headline-card"><div class="stats-headline-value">{profiles.toLocaleString()}</div><div class="stats-headline-label">Full profiles</div></div>
  <div class="stats-headline-card"><div class="stats-headline-value">{peopleOnly.toLocaleString()}</div><div class="stats-headline-label">Quick entries</div></div>
  <div class="stats-headline-card"><div class="stats-headline-value">{Object.keys(categoryCounts).length.toLocaleString()}</div><div class="stats-headline-label">Categories</div></div>
</div>

{topCategories.length > 0 && (
  <div class="stats-section">
    <h3 class="stats-section-title">Top categories</h3>
    <div class="stats-bars">
      {topCategories.map(([name, count]) => (
        <div class="stats-bar-row">
          <div class="stats-bar-label">{name}</div>
          <div class="stats-bar-track"><div class="stats-bar-fill" style={`width: ${(count / categoryMax) * 100}%`}></div></div>
          <div class="stats-bar-value">{count}</div>
        </div>
      ))}
    </div>
  </div>
)}
