---
// RemoteImage: source-native picture markup for remote-localized images
// (Unsplash, OpenLibrary covers, etc). Resolves the source URL through
// data/remote-assets.generated.json and emits avif/jpg <source> + <img>
// fallback so post-build localizeRemainingRemoteAssetReferences can run
// in --check mode.
//
// Usage:
//   <RemoteImage
//     src="https://images.unsplash.com/photo-..."
//     sizes="(max-width: 768px) 100vw, 480px"
//     alt="Adventure cover"
//     width={1200}
//     height={800}
//     loading="lazy"
//   />

import remoteAssets from '../../../data/remote-assets.generated.json';

interface Props {
  src: string;
  sizes?: string;
  alt: string;
  width: number;
  height: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'sync' | 'async' | 'auto';
  class?: string;
}

const {
  src,
  sizes = '100vw',
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  class: className,
} = Astro.props;

type RemoteEntry = {
  source: string;
  widths: number[];
  formats: Record<string, { avif?: string; jpg?: string }>;
};

const entry = (remoteAssets as Record<string, RemoteEntry>)[src];

// Fallback: if the URL isn't in the manifest, emit a plain <img> pointing
// at the remote source. The post-build normalizer will localize on next
// build after assets:optimize runs.
let avifSrcset = '';
let jpgSrcset = '';
let fallbackSrc = src;

if (entry) {
  const sortedWidths = [...entry.widths].sort((a, b) => a - b);
  const avifs = sortedWidths
    .map((w) => entry.formats[String(w)]?.avif)
    .filter(Boolean) as string[];
  const jpgs = sortedWidths
    .map((w) => entry.formats[String(w)]?.jpg)
    .filter(Boolean) as string[];

  avifSrcset = avifs.map((u, i) => `${u} ${sortedWidths[i]}w`).join(', ');
  jpgSrcset = jpgs.map((u, i) => `${u} ${sortedWidths[i]}w`).join(', ');
  fallbackSrc = jpgs[jpgs.length - 1] || src;
}
---

<picture>
  {avifSrcset && <source type="image/avif" srcset={avifSrcset} sizes={sizes} />}
  <img
    src={fallbackSrc}
    srcset={jpgSrcset || undefined}
    sizes={sizes}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    class={className}
  />
</picture>
