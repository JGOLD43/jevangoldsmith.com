---
// Loads Leaflet + initializes the world map for /adventures.html.
// The <div id="world-map"> lives in the page itself; this component only
// emits the stylesheet + script + initializer.
//
// Marker payload is dumped as a separate JSON script tag (not a
// data-markers attribute on the div) to keep adventures.html byte-close
// to legacy where the markers ship via a separate JS bundle.
import type { CollectionEntry } from 'astro:content';

interface Props { adventures: CollectionEntry<'adventures'>[] }
const { adventures } = Astro.props;

const markers = adventures
  .filter((a) => {
    const c = a.data.mapCenter as { lat?: number; lng?: number } | undefined;
    return c && typeof c.lat === 'number' && typeof c.lng === 'number';
  })
  .map((a) => {
    const c = a.data.mapCenter as { lat: number; lng: number };
    return {
      id: a.id,
      title: a.data.title,
      location: a.data.location ?? '',
      lat: c.lat,
      lng: c.lng,
      href: `/adventure-${a.id}.html`
    };
  });
---
<link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />
<script is:inline src="/vendor/leaflet/leaflet.js"></script>
<script type="application/json" id="adventures-map-data" set:html={JSON.stringify(markers)} />
<script is:inline src="/js/adventures-map-init.js" defer></script>
