---
import type { CollectionEntry } from 'astro:content';

interface Props { entry: CollectionEntry<'movies'> }
const { entry } = Astro.props;
const m = entry.data;
const stars = m.rating ?? '';
const fmtRuntime = (mins?: number | null) => {
  if (!mins) return null;
  const h = Math.floor(mins / 60);
  const r = mins % 60;
  return h ? `${h}h ${r}m` : `${r}m`;
};
const runtime = fmtRuntime(m.runtime);
---
<div
  class="movie-card js-zoom-item"
  data-movie-title={m.title}
  data-title={m.title}
  data-id={m.title}
  data-search={`${m.title ?? ''} ${m.genre ?? ''} ${(m.tmdbGenres ?? []).join(' ')}`.toLowerCase()}
  data-category={m.genre ?? ''}
>
  <div class="movie-poster-wrapper">
    {m.poster && <img src={m.poster} alt={m.title} class="movie-poster" loading="lazy" decoding="async" />}
  </div>
  <div class="movie-info">
    <div class="movie-title-row">
      <h3 class="movie-title">{m.title}</h3>
      {m.year && <span class="movie-year">{m.year}</span>}
    </div>
    {runtime && <div class="movie-runtime">{runtime}</div>}
    {m.genre && <div class="movie-genre-badge">🎭 {m.genre}</div>}
    {m.starCount && <div class="movie-rating"><span class="rating-number">{m.starCount}</span>{stars}</div>}
    {m.date && <p class="movie-date">Watched: {m.date}</p>}
  </div>
</div>
