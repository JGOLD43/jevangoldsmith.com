---
import type { Movie as MovieRecord } from '../content.config';
import { formatRuntime } from '../lib/dates';
import { slugify } from '../lib/slug';

interface Props {
  movie: Partial<MovieRecord>;
}

const { movie } = Astro.props;
const title = movie.title ?? '';
const date = movie.date ?? '';
const link = movie.link ?? '';
const rating = movie.rating ?? '';
const starCount = movie.starCount ?? 0;
const year = movie.year != null ? String(movie.year) : '';
const poster = movie.poster ?? '';
const genre = movie.genre ?? '';
const timesWatched = Number(movie.timesWatched) || 1;
const runtime = Number(movie.runtime) || 0;
const review = movie.review ?? '';
const shortDescription = movie.shortDescription ?? '';
const runtimeStr = runtime ? formatRuntime(runtime) : '';
const genreIcons: Record<string, string> = {
  Action: '💥', Adventure: '🗺️', Animation: '🎨', Comedy: '😂',
  Crime: '🔫', Documentary: '📹', Drama: '🎭', Fantasy: '🧙',
  Horror: '👻', Mystery: '🔍', Romance: '💕', 'Sci-Fi': '🚀',
  Thriller: '😱', Western: '🤠', Uncategorized: '🎬'
};
const genreIcon = (genre && genreIcons[genre]) || '🎬';
const slug = slugify(title);
const classes = ['movie-card', 'card-link', review ? 'has-review' : ''].filter(Boolean).join(' ');
---
<a class={classes} href={slug ? `/movies/${slug}.html` : '#'} data-movie-title={title}>
  {timesWatched > 1 && <div class="times-read-badge movie-watch-badge">{timesWatched}x Watched</div>}
  <div class="movie-poster-wrapper">
    {poster
      ? <img src={poster} alt={title} class="movie-poster" width="150" height="230" loading="lazy" decoding="async" style={slug ? `view-transition-name: movie-poster-${slug}` : undefined} />
      : <div class="movie-poster-placeholder">{title}</div>}
  </div>
  <div class="movie-info">
    <div class="movie-title-row">
      <h3 class="movie-title">{title}</h3>
      {year && <span class="movie-year">{year}</span>}
    </div>
    {runtimeStr && <div class="movie-runtime">{runtimeStr}</div>}
    {genre && <div class="movie-genre-badge">{genreIcon} {genre}</div>}
    {rating && <div class="movie-rating">{starCount ? <span class="rating-number">{starCount}</span> : null}{rating}</div>}
    {shortDescription && <p class="movie-description">{shortDescription}</p>}
    {date && <p class="movie-date">Watched: {date}</p>}
  </div>
  <div class="js-zoom-detail" aria-hidden="true">
    <p class="zoom-detail-kicker">{genre || 'Film'}{year ? ` · ${year}` : ''}</p>
    <p class="zoom-detail-title">{title}</p>
    {rating && <p class="zoom-detail-lead"><span aria-hidden="true">{rating}</span>{starCount ? <span class="sr-only">{starCount} out of 5 stars</span> : null}</p>}
    {review && <p class="zoom-detail-line"><span>Review —</span> {review}</p>}
    {date && <p class="zoom-detail-line"><span>Watched —</span> {date}</p>}
    {link && link !== '#' && <a class="zoom-detail-link" href={link} target="_blank" rel="noopener noreferrer">Letterboxd</a>}
  </div>
</a>
