---
// OptimizedImage: source-native picture markup for local generated images.
// Replaces the work post-build normalize-astro-html.js does for <img> tags
// pointing at images/generated/. Pages migrated to use this component
// produce final HTML at build time — the normalizer can then run in --check
// mode for those pages instead of mutate.
//
// Usage:
//   <OptimizedImage
//     src="images/generated/profile/profile-720.jpg"
//     basename="images/generated/profile/profile"
//     widths={[360, 520, 720, 960, 1200]}
//     sizes="(max-width: 768px) 100vw, 720px"
//     alt="Profile photo"
//     width={720}
//     height={720}
//   />
//
// Emits AVIF source + JPG/PNG fallback. No WebP except logo (handled
// inline in Nav.astro).

interface Props {
  src: string;
  basename: string;
  widths: number[];
  sizes?: string;
  alt: string;
  width: number;
  height: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'sync' | 'async' | 'auto';
  class?: string;
}

const {
  src,
  basename,
  widths,
  sizes = '100vw',
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  class: className,
} = Astro.props;

// Detect raster format from the fallback src extension. Generated remote /
// profile / content surfaces are JPEG; logo / people / products are PNG.
const fallbackExt = src.endsWith('.png') ? 'png' : 'jpg';

const srcsetFor = (ext: string) =>
  widths.map((w) => `${basename}-${w}.${ext} ${w}w`).join(', ');
---

<picture>
  <source type="image/avif" srcset={srcsetFor('avif')} sizes={sizes} />
  <img
    src={src}
    srcset={srcsetFor(fallbackExt)}
    sizes={sizes}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    class={className}
  />
</picture>
