---
// Shared collection-page wrapper for books, movies, people, podcasts, essays.

import Base from '../layouts/Base.astro';
import CollectionShell from './CollectionShell.astro';
import type { CollectionConfig } from '../lib/collection-shell';

interface CommonProps {
  title: string;
  description: string;
  canonical: string;
  pageType?: 'CollectionPage' | 'WebPage' | 'AboutPage' | 'ContactPage';
}

type Props = CommonProps & {
  config: CollectionConfig;
};

const props = Astro.props as Props;
const { title, description, canonical, pageType = 'CollectionPage' } = props;
---
<Base
  title={title}
  description={description}
  canonical={canonical}
  pageType={pageType}
>
  <slot name="head" slot="head" />
  <CollectionShell config={props.config}>
    <slot name="sidebar-extra" slot="sidebar-extra" />
    <slot name="header-extra" slot="header-extra" />
    <slot name="counter-extra" slot="counter-extra" />
    <slot />
    <slot name="after-main" slot="after-main" />
  </CollectionShell>
</Base>
