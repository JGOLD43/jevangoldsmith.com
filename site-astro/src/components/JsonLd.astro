---
// Renders a single <script type="application/ld+json"> with the site-wide
// Person + WebSite graph plus a per-page BreadcrumbList + page node + any
// per-page entity schemas (Article, Book, Movie, ItemList, etc).
import {
  PERSON_SCHEMA,
  WEBSITE_SCHEMA,
  breadcrumbList,
  pageNode,
  type BreadcrumbStep,
  type PageType
} from '../lib/seo';

interface Props {
  canonical: string;
  title: string;
  description: string;
  pageType?: PageType;
  image?: string;
  breadcrumbs?: BreadcrumbStep[];
  /** Additional schema.org @graph nodes (Article, Book, Movie, ItemList, ...). */
  extraSchema?: Array<Record<string, unknown>>;
}

const {
  canonical,
  title,
  description,
  pageType = 'WebPage',
  image,
  breadcrumbs = [{ name: 'Home', url: 'https://jevangoldsmith.com/' }, { name: title, url: canonical }],
  extraSchema = []
} = Astro.props;

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    PERSON_SCHEMA,
    WEBSITE_SCHEMA,
    breadcrumbList(canonical, breadcrumbs),
    pageNode({ type: pageType, canonical, title, description, image }),
    ...extraSchema
  ]
};
---
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
