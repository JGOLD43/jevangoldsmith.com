---
import Base from '../layouts/Base.astro';

const canonical = 'https://jevangoldsmith.com/now.html';

// Edit these as life changes. Newest section first.
const lastUpdated = 'May 12, 2026';
const lastUpdatedLocation = 'Ayr, QLD';
// Coordinates for the location above — used by /adventures map to drop a
// "now" pin and to focus the view when arriving via the link below.
const lastUpdatedLat = -19.5765;
const lastUpdatedLng = 147.4035;
const mapLink = `/adventures.html?focus=now&lat=${lastUpdatedLat}&lng=${lastUpdatedLng}&place=${encodeURIComponent(lastUpdatedLocation)}`;

// Build an Esri World Imagery satellite tile URL that contains the
// "now" location. zoom 10 is the same level the trip map ends at
// after fitBounds-to-25km-circle, so the zoom-in animation lands on
// the same imagery the user will see on the destination — visual
// continuity across the swap, no zoom mismatch.
const MAP_ZOOM = 10;
const _xFrac = (lastUpdatedLng + 180) / 360 * Math.pow(2, MAP_ZOOM);
const _yFrac = (1 - Math.log(Math.tan(lastUpdatedLat * Math.PI / 180) + 1 / Math.cos(lastUpdatedLat * Math.PI / 180)) / Math.PI) / 2 * Math.pow(2, MAP_ZOOM);
const tileX = Math.floor(_xFrac);
const tileY = Math.floor(_yFrac);
const mapThumbUrl = `https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/${MAP_ZOOM}/${tileY}/${tileX}`;
// Sub-tile pin offset (0..100%) so the marker lands on the actual lat/lng
// instead of the tile's center.
const pinLeftPct = ((_xFrac - tileX) * 100).toFixed(2);
const pinTopPct = ((_yFrac - tileY) * 100).toFixed(2);

const sections = [
  {
    title: 'Building this archive',
    body: `<p>Most of my recent free hours have gone into the site you're reading. It's an experiment in keeping a record — essays, books, movies, people, places — that's mine to shape rather than a feed someone else owns. The performance audit branch I'm on now is shaving the page weight down so it loads fast even on bad hotel Wi-Fi.</p>`
  },
  {
    title: 'Reading deliberately',
    body: `<p>Trying to finish one book before starting the next. Currently working through long-form non-fiction on attention, money, and craft. Notes land on the <a href="books.html">books page</a> when they're worth keeping.</p>`
  },
  {
    title: 'Health reset',
    body: `<p>Cut alcohol and most processed food for the year. Lifting four days a week, walking everywhere I reasonably can. Goal is less about a number and more about staying useful at 40, 50, 60.</p>`
  },
  {
    title: 'Work in motion',
    body: `<p>Spending most professional hours on finance, real-estate development, and the spaces where technology bends those industries. Open to interesting conversations — <a href="contact.html">say hi</a>.</p>`
  }
];
---
<Base
  title="Now — What Jevan Goldsmith is up to"
  description="A snapshot of what I'm working on, reading, and thinking about right now. Updated occasionally."
  canonical={canonical}
  pageType="AboutPage"
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://server.arcgisonline.com" crossorigin />
    <link rel="preload" as="image" fetchpriority="high" href={mapThumbUrl} crossorigin />
  </Fragment>
<main class="now-page">
  <header class="now-header">
    <h2 class="now-title">Now</h2>
    <div class="now-meta-row">
      <div class="now-updated">
        <span class="now-updated-label">Last updated</span>
        <strong class="now-updated-date">{lastUpdated}</strong>
      </div>
      <a class="now-map-thumb" id="now-map-thumb-link" href={mapLink} title={`Open ${lastUpdatedLocation} on the trip map`} aria-label={`Open ${lastUpdatedLocation} on the trip map`}
         data-now-lat={lastUpdatedLat} data-now-lng={lastUpdatedLng}>
        {/* Static img + marker shown until Leaflet hydrates the same
            container with a live map. After hydration the thumb is a
            real Leaflet instance, not a stretched satellite tile, so
            the click-to-expand animation stays sharp at any size and
            visually matches what /adventures shows. */}
        <img id="now-map-thumb-img" src={mapThumbUrl} alt={`Map showing current location: ${lastUpdatedLocation}`} fetchpriority="high" decoding="async" width="256" height="256" />
        <span class="now-map-thumb-marker" style={`left: ${pinLeftPct}%; top: ${pinTopPct}%;`} aria-hidden="true">
          <span class="now-marker-pulse"></span>
          <span class="now-marker-dot"></span>
        </span>
        <span class="now-map-thumb-label">{lastUpdatedLocation}</span>
        <div id="now-leaflet-host" class="now-leaflet-host"></div>
      </a>
    </div>
  </header>

  <div class="now-sections">
    {sections.map((section) => (
      <section class="now-section">
        <h2 class="now-section-title">{section.title}</h2>
        <div class="now-section-body" set:html={section.body} />
      </section>
    ))}
  </div>

  <footer class="now-footer">
    <p>Want to know what I think about something not on this list? <a href="contact.html">Send a note</a> or browse the <a href="essays.html">essays</a>.</p>
  </footer>
</main>

<style is:global>
  .now-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }
  .now-header { margin-bottom: 3.5rem; }
  .now-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--secondary-color);
    margin: 0 0 0.75rem;
  }
  h2.now-title {
    font-family: Chivo, Georgia, serif;
    /* Match Bookshelf (h2): 1.5rem mobile, 3rem desktop. */
    font-size: 1.5rem !important;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 1rem;
    color: var(--primary-color);
    letter-spacing: 0;
  }
  @media (min-width: 769px) {
    h2.now-title { font-size: 3rem !important; }
  }
  .now-subtitle {
    font-size: 1.05rem;
    color: var(--text-light);
    line-height: 1.55;
    margin: 0 0 1.5rem;
    max-width: 56ch;
  }
  .now-meta-row {
    display: flex;
    align-items: stretch;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .now-updated {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0;
    background: transparent;
    border: 0;
    min-width: 0;
  }
  .now-updated-label { letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.7rem; color: var(--text-light); font-weight: 600; }
  .now-updated-date { color: var(--primary-color); font-weight: 600; font-size: 0.95rem; letter-spacing: 0; }
  .now-map-thumb {
    position: relative;
    display: block;
    width: 180px;
    height: 110px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--background-alt);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    text-decoration: none;
    flex: 0 0 auto;
  }
  .now-map-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .now-map-thumb:hover {
    transform: translateY(-2px);
    /* More obvious gold highlight on hover — a 1px border alone barely
       registered on a busy satellite tile. Outline + glow ring make
       it unmistakable. */
    border-color: var(--secondary-color);
    outline: 2px solid var(--secondary-color);
    outline-offset: 0;
    box-shadow: 0 0 0 4px rgba(201, 168, 108, 0.35), 0 8px 22px rgba(0, 0, 0, 0.35);
  }
  .now-map-thumb-marker {
    position: absolute;
    /* left/top set inline from the lat/lng sub-tile offset */
    width: 22px;
    height: 22px;
    margin: -11px 0 0 -11px;
    pointer-events: none;
  }
  .now-map-thumb-marker .now-marker-dot {
    position: absolute;
    inset: 6px;
    background: gold;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.45);
  }
  .now-map-thumb-marker .now-marker-pulse {
    position: absolute;
    inset: 0;
    background: rgba(255, 215, 0, 0.5);
    border-radius: 50%;
    animation: nowPulse 1.8s ease-out infinite;
  }
  @keyframes nowPulse {
    0% { opacity: 0.9; transform: scale(0.6); }
    100% { opacity: 0; transform: scale(1.6); }
  }
  @media (prefers-reduced-motion: reduce) {
    .now-map-thumb-marker .now-marker-pulse { animation: none; opacity: 0.5; transform: scale(1); }
  }
  .now-map-thumb-label {
    position: absolute;
    left: 8px;
    bottom: 8px;
    right: 8px;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
    letter-spacing: 0.02em;
  }
  @media (max-width: 480px) {
    .now-map-thumb { width: 100%; height: 130px; }
  }

  .now-sections { display: grid; gap: 2.5rem; }
  .now-section {
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }
  .now-section:first-child { border-top: 0; padding-top: 0; }
  .now-section-title {
    font-family: Chivo, Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 1rem;
    color: var(--primary-color);
  }
  .now-section-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-color);
  }
  .now-section-body p { margin: 0 0 1rem; }
  .now-section-body p:last-child { margin-bottom: 0; }
  .now-section-body a { color: var(--secondary-color); text-decoration: underline; text-underline-offset: 3px; }
  .now-section-body a:hover { color: var(--accent-color); }
  .now-section-body ul { margin: 0 0 1rem 1.25rem; padding: 0; }
  .now-section-body li { margin: 0 0 0.4rem; }

  .now-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.9rem;
    color: var(--text-light);
  }
  .now-footer a { color: var(--secondary-color); text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 600px) {
    .now-page { padding: 2.5rem 1.25rem 4rem; }
    .now-header { margin-bottom: 2.5rem; }
    .now-sections { gap: 2rem; }
  }

  /* Live Leaflet thumb. The host div overlays the static image once
     Leaflet hydrates — same satellite imagery + marker + circle as the
     destination /adventures map. When the user clicks, the thumb's
     parent animates to fullscreen and the Leaflet instance is
     re-parented into the destination's #world-map via SPA-swap. Same
     instance, no re-init, no image stretch. */
  .now-leaflet-host {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    opacity: 0;
    transition: opacity 200ms ease-out;
    pointer-events: none;
  }
  .now-leaflet-host.is-ready { opacity: 1; }
  .now-map-thumb.is-live #now-map-thumb-img { opacity: 0; }
  .now-map-thumb.is-live .now-map-thumb-marker,
  .now-map-thumb.is-live .now-map-thumb-label { z-index: 5; pointer-events: none; }
  /* Expanding state: animate from thumb rect to fullscreen. */
  .now-map-thumb.is-expanding {
    position: fixed !important;
    z-index: 99999;
    border-radius: 0 !important;
    transition: top 320ms cubic-bezier(.22, 1, .36, 1),
                left 320ms cubic-bezier(.22, 1, .36, 1),
                width 320ms cubic-bezier(.22, 1, .36, 1),
                height 320ms cubic-bezier(.22, 1, .36, 1),
                border-radius 320ms cubic-bezier(.22, 1, .36, 1);
    box-shadow: none !important;
    outline: none !important;
  }
  /* While expanding, fade other now-page content out. */
  .now-page.is-now-zooming > *:not(.now-header),
  .now-page.is-now-zooming .now-header > *:not(.now-meta-row),
  .now-page.is-now-zooming .now-meta-row > *:not(.now-map-thumb) {
    transition: opacity 200ms ease-out;
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  import { loadLeaflet } from '../scripts/adventures-map-vendor';
  import { initAdventuresPage } from '../scripts/adventures.ts';

  // Mount a live Leaflet thumb on /now so its imagery EXACTLY matches
  // what /adventures shows. Clicking expands the thumb container to
  // fullscreen via CSS transition, then SPA-swaps to /adventures and
  // re-parents the Leaflet instance into the destination's #world-map
  // div. Same instance, same tiles — the user looks at one continuous
  // map throughout, no image stretch, no flash, no swap visible.
  const link = document.getElementById('now-map-thumb-link') as HTMLAnchorElement | null;
  let prefetchedDoc: Document | null = null;
  let leafletMap: any = null;

  async function mountLeafletThumb() {
    if (!link) return;
    const host = document.getElementById('now-leaflet-host');
    if (!host) return;
    const lat = parseFloat(link.dataset.nowLat || '');
    const lng = parseFloat(link.dataset.nowLng || '');
    if (!isFinite(lat) || !isFinite(lng)) return;
    const L = await loadLeaflet();
    if (!L) return;
    leafletMap = L.map(host, {
      zoomControl: false,
      attributionControl: false,
      dragging: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      touchZoom: false,
      keyboard: false,
      boxZoom: false,
      tap: false,
      fadeAnimation: false,
      zoomAnimation: false
    }).setView([lat, lng], 10);
    L.tileLayer(
      'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
      { maxZoom: 18, crossOrigin: true }
    ).addTo(leafletMap);
    // Match the destination state: yellow Now marker + 25km circle +
    // popup open. fitBounds to the circle so the on-screen framing
    // matches what /adventures shows after fitBounds-to-circle there.
    const html = '<span class="now-marker-pulse"></span><span class="now-marker-dot"></span>';
    const marker = L.marker([lat, lng], {
      icon: L.divIcon({
        className: 'now-marker',
        html,
        iconSize: [22, 22],
        iconAnchor: [11, 11]
      })
    }).addTo(leafletMap);
    const circle = L.circle([lat, lng], {
      radius: 25000,
      color: '#facc15',
      weight: 2,
      fillColor: '#facc15',
      fillOpacity: 0.05,
      interactive: false
    }).addTo(leafletMap);
    leafletMap.fitBounds(circle.getBounds(), { padding: [10, 10], animate: false });
    // Reveal the live map (the static fallback img hides via .is-live).
    requestAnimationFrame(() => {
      link.classList.add('is-live');
      host.classList.add('is-ready');
      // Hide the original marker overlay — the Leaflet marker draws
      // its own. Without this the user sees two pulse dots.
      const staticMarker = link.querySelector('.now-map-thumb-marker') as HTMLElement | null;
      if (staticMarker) staticMarker.style.display = 'none';
      void marker; // marker is added to map; keep ref alive
    });
  }

  if (link) {
    // Mount Leaflet after the page settles so it doesn't compete with
    // LCP. requestIdleCallback when available; setTimeout fallback.
    const mount = () => { mountLeafletThumb().catch(() => {}); };
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(mount, { timeout: 1200 });
    } else {
      setTimeout(mount, 800);
    }

    const prefetchDoc = async () => {
      if (prefetchedDoc) return;
      try {
        const res = await fetch(link.href, { credentials: 'same-origin' });
        if (!res.ok) return;
        prefetchedDoc = new DOMParser().parseFromString(await res.text(), 'text/html');
      } catch { /* ignore */ }
    };
    link.addEventListener('pointerenter', prefetchDoc, { once: true });
    link.addEventListener('focus', prefetchDoc, { once: true });

    link.addEventListener('click', async (event) => {
      const me = event as MouseEvent;
      if (me.metaKey || me.ctrlKey || me.shiftKey || me.altKey || me.button !== 0) return;
      event.preventDefault();
      const href = link.href;

      // Phase 1: pin the thumb to its current rect, then transition it
      // to fullscreen via CSS. Because the inside is a real Leaflet
      // map, the tiles stay sharp at any size — no image stretching.
      const rect = link.getBoundingClientRect();
      if (!rect.width || !rect.height) { window.location.href = href; return; }
      link.style.top = `${rect.top}px`;
      link.style.left = `${rect.left}px`;
      link.style.width = `${rect.width}px`;
      link.style.height = `${rect.height}px`;
      // Force layout to commit the inline rect BEFORE flipping to fixed.
      void link.offsetHeight;
      link.classList.add('is-expanding');
      // Force layout again so the browser registers the starting
      // position before the next style change initiates the transition.
      void link.offsetHeight;
      const nowPage = document.querySelector('.now-page') as HTMLElement | null;
      if (nowPage) nowPage.classList.add('is-now-zooming');
      // Animate to viewport-fill.
      link.style.top = '0px';
      link.style.left = '0px';
      link.style.width = '100vw';
      link.style.height = '100vh';

      // Phase 2: in parallel, fetch the destination doc.
      const docPromise = prefetchedDoc
        ? Promise.resolve(prefetchedDoc)
        : fetch(href, { credentials: 'same-origin' })
            .then((res) => res.ok ? res.text() : Promise.reject(new Error(String(res.status))))
            .then((html) => new DOMParser().parseFromString(html, 'text/html'))
            .catch(() => null);

      // Wait for the CSS transition AND the fetch to complete.
      const transitionDone = new Promise<void>((resolve) => {
        let resolved = false;
        const handler = (e: TransitionEvent) => {
          if (resolved || (e.target !== link)) return;
          if (e.propertyName !== 'width' && e.propertyName !== 'height') return;
          resolved = true;
          link.removeEventListener('transitionend', handler as any);
          resolve();
        };
        link.addEventListener('transitionend', handler);
        // Safety: resolve after 400ms even if transitionend doesn't fire.
        setTimeout(() => { if (!resolved) { resolved = true; resolve(); } }, 400);
      });

      const [doc] = await Promise.all([docPromise, transitionDone]);
      if (!doc) { window.location.href = href; return; }
      const newMain = doc.querySelector('main');
      const currentMain = document.querySelector('main');
      if (!newMain || !currentMain || !currentMain.parentNode) {
        window.location.href = href; return;
      }

      // Carry over destination inline styles + body class.
      doc.querySelectorAll('head style').forEach((style) => {
        const cloned = style.cloneNode(true) as HTMLStyleElement;
        cloned.setAttribute('data-now-spa-style', '1');
        document.head.appendChild(cloned);
      });
      document.documentElement.classList.add('adv-focus-now-pending');

      // Take the Leaflet host (still mounted with a live map) out of
      // the thumb and stash it for re-parenting.
      const host = document.getElementById('now-leaflet-host');

      // Swap main.
      currentMain.parentNode!.replaceChild(newMain, currentMain);
      document.title = doc.title;
      history.pushState({ nowSpa: true }, '', href);

      // Find the destination's #world-map div and replace its contents
      // with our live Leaflet host (re-parent the instance, no re-init).
      const worldMapEl = document.getElementById('world-map');
      if (worldMapEl && host && leafletMap) {
        // Make Leaflet think it's now mounted in the world-map div.
        // Easiest: insert host inside world-map and trigger
        // invalidateSize so it re-layouts to the new container size.
        host.style.position = 'absolute';
        host.style.inset = '0';
        host.style.opacity = '1';
        host.classList.add('is-ready');
        // Strip transition + thumb-specific styles.
        host.style.transition = 'none';
        worldMapEl.style.opacity = '1';
        worldMapEl.appendChild(host);
        // Tell Leaflet to recalc to the new (fullscreen) size.
        leafletMap.invalidateSize({ animate: false, pan: false });
      }

      // Now safely remove the empty thumb anchor leftover.
      link.remove();

      // Boot the rest of the adventures page (filters, carousel,
      // sidebar, etc). adventures.ts is smart enough that if the
      // map is already mounted we should detect it — but our
      // simplest move: let initAdventuresPage create a new
      // worldMap reference. The visible result is still our
      // existing tiles, since they're in the DOM.
      initAdventuresPage();
    });

    window.addEventListener('popstate', (event) => {
      const state = (event.state || {}) as Record<string, unknown>;
      if (state.nowSpa) window.location.reload();
    });
  }
</script>
</Base>
