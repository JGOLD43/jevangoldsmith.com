---
import Base from '../layouts/Base.astro';
---
<Base
  title="Field Notes Newsletter | Useful Ideas, Books, Tools &amp; Experiments | Jevan Goldsmith"
  description="One useful idea, object, book, question, or experiment each week from Jevan Goldsmith's living archive."
  canonical="https://jevangoldsmith.com/field-notes.html"
  pageType="CollectionPage"
>
<main class="field-notes-main">
    <section class="field-notes-hero">
        <p class="archive-kicker">Field Notes</p>
        <h1>One useful idea, object, book, question, or experiment each week.</h1>
        <p>Field Notes is where I send the useful things before they become polished essays: books worth reading, tools that stayed, questions I am stuck on, systems I am testing, and ideas I keep returning to.</p>
        <form class="field-notes-form field-notes-form-large" action="https://formsubmit.co/hello@jevangoldsmith.com" method="POST" data-newsletter-form data-endpoint="https://formsubmit.co/ajax/hello@jevangoldsmith.com">
            <input type="hidden" name="_subject" value="Field Notes signup">
            <input type="hidden" name="_template" value="table">
            <label class="sr-only" for="field-notes-hero-email">Email for Field Notes</label>
            <input id="field-notes-hero-email" type="email" name="email" placeholder="Your email" autocomplete="email" required>
            <button type="submit">Join Field Notes</button>
        </form>
        <p class="field-note-microcopy">Weekly-ish. Short. Useful. No spam.</p>
    </section>


</main>
</Base>

<script>
  import '../scripts/newsletter.ts';
</script>
