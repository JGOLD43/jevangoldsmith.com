---
// Legacy URL kept ONLY as a redirect to /newsletter.html. The "Field
// Notes" branding was retired; all inbound links inside the site now
// point at /newsletter.html. External backlinks (search results, old
// social posts) land here and get bounced.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting… | Jevan Goldsmith</title>
    <link rel="canonical" href="https://jevangoldsmith.com/newsletter.html" />
    <meta http-equiv="refresh" content="0; url=/newsletter.html" />
    <meta name="robots" content="noindex, follow" />
    <script>window.location.replace('/newsletter.html');</script>
  </head>
  <body>
    <p>Redirecting to <a href="/newsletter.html">/newsletter.html</a>…</p>
  </body>
</html>
