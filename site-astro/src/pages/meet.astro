---
// Ported from _src/content/meet/body.html via scripts/port-page.mjs.
// SEO mirrors tests/seo-fixture.json. JSON-LD lands in Phase 8.
import Base from '../layouts/Base.astro';
---
<Base
  title="Meet Jevan Goldsmith"
  description="A quick way to meet Jevan Goldsmith, scan contact details, and start a useful conversation."
  canonical="https://jevangoldsmith.com/meet.html"
  pageType="ContactPage"
  noChrome
>
<header class="meet-header">
    <a href="/index.html" class="meet-logo">
        <img src="images/generated/logo/logo-nav-352.png" alt="J.GOLD" height="50" srcset="images/generated/logo/logo-nav-88.png 88w, images/generated/logo/logo-nav-176.png 176w, images/generated/logo/logo-nav-264.png 264w, images/generated/logo/logo-nav-352.png 352w" sizes="88px" loading="lazy" decoding="async" width="88">
    </a>
    <a href="/index.html" class="meet-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </a>
</header>
<main class="meet-main">
    <div class="meet-container">
        <div class="meet-content-header">
            <h1>Let's Chat</h1>
            <p>Whether it's a coffee chat, business idea, or just to say hi — I'd love to hear from you.</p>
        </div>
        <form class="meet-form" action="mailto:hello@jevangoldsmith.com" method="get" enctype="text/plain">
            <p class="meet-form-note">Takes less than a minute</p>
            <div class="meet-form-group">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" required placeholder="First name is fine">
            </div>
            <div class="meet-form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="Where can I reach you?">
            </div>
            <div class="meet-form-group">
                <label for="reason">What brings you here?</label>
                <select id="reason" name="reason" required>
                    <option value="" disabled selected>Select one...</option>
                    <option value="coffee-chat">Coffee chat / networking</option>
                    <option value="business">Business opportunity</option>
                    <option value="collaboration">Collaboration idea</option>
                    <option value="saying-hi">Just saying hi</option>
                    <option value="other">Something else</option>
                </select>
            </div>
            <div class="meet-form-group">
                <label for="message">Anything you'd like to add?</label>
                <textarea id="message" name="message" rows="4" placeholder="Optional — but I'd love to know more!"></textarea>
            </div>
            <button type="submit" class="meet-submit">
                <span>Send Message</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="22" y1="2" x2="11" y2="13"></line>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                </svg>
            </button>
        </form>
        <div class="meet-footer">
            <p class="meet-response-time">I typically respond within 24-48 hours</p>
            <p class="meet-alternatives">
                Prefer another way?
                <a href="mailto:hello@jevangoldsmith.com" data-analytics="contact" data-cta-location="meet">Email</a> ·
                <a href="https://x.com/JevanGoldsmith" target="_blank">X</a> ·
                <a href="https://linkedin.com/in/jevan-goldsmith-7b885a185" target="_blank">LinkedIn</a>
            </p>
        </div>
    </div>
</main>
</Base>
