---
import Base from '../layouts/Base.astro';
---
<Base
  title="Meet Jevan Goldsmith"
  description="A quick way to meet Jevan Goldsmith, scan contact details, and start a useful conversation."
  canonical="https://jevangoldsmith.com/meet.html"
  pageType="ContactPage"
  noChrome
>
<header class="meet-header">
    <a href="/index.html" class="meet-logo">
        <picture><source type="image/avif" srcset="/images/generated/logo/logo-nav-88.avif 88w, /images/generated/logo/logo-nav-176.avif 176w, /images/generated/logo/logo-nav-264.avif 264w, /images/generated/logo/logo-nav-352.avif 352w" sizes="88px"><img src="/images/generated/logo/logo-nav-352.png" alt="J.GOLD" height="50" srcset="/images/generated/logo/logo-nav-88.png 88w, /images/generated/logo/logo-nav-176.png 176w, /images/generated/logo/logo-nav-264.png 264w, /images/generated/logo/logo-nav-352.png 352w" sizes="88px" loading="lazy" decoding="async" width="88"></picture>
    </a>
    <h1 class="meet-header-title">Let's Chat</h1>
    <a href="/index.html" class="meet-close" aria-label="Close">
        <svg class="ico-stroke" width="28" height="28" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-close"/></svg>
    </a>
</header>
<main class="meet-main">
    <div class="meet-container">
        <form class="meet-form" action="mailto:hello@jevangoldsmith.com" method="get" enctype="text/plain">
            <div class="meet-form-group">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" required placeholder="First name is fine">
            </div>
            <div class="meet-form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="Where can I reach you?">
            </div>
            <div class="meet-form-group">
                <label for="message">Anything you'd like to add?</label>
                <textarea id="message" name="message" rows="4" placeholder="Optional — but I'd love to know more!"></textarea>
            </div>
            <button type="submit" class="meet-submit">
                <span>Send Message</span>
                <svg class="ico-stroke" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-send"/></svg>
            </button>
        </form>
        <div class="meet-footer">
            <p class="meet-response-time">I typically respond within 24-48 hours</p>
            <p class="meet-alternatives">
                Prefer another way?
                <a href="mailto:hello@jevangoldsmith.com">Email</a> ·
                <a href="https://x.com/JevanGoldsmith" target="_blank">X</a> ·
                <a href="https://linkedin.com/in/jevan-goldsmith-7b885a185" target="_blank">LinkedIn</a>
            </p>
        </div>
    </div>
</main>
</Base>

<style is:inline>
  /* Single-row header: logo on the left, "Let's Chat" centered, close
     button on the right — all aligned on the same baseline so there's
     no awkward gap between the chrome and the headline. The form sits
     immediately below this band. */
  .meet-header,
  .meet-page .meet-header {
    padding-top: calc(env(safe-area-inset-top, 0px) + 1.25rem) !important;
    padding-bottom: 1rem !important;
    position: relative;
  }
  .meet-header-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    color: var(--text-color);
    font-family: Chivo, sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
  }
  .meet-main {
    padding-top: 1rem !important;
    align-items: flex-start !important;
  }
  /* Old centered headline block is gone; the form sits flush to the
     top of .meet-main. */
  @media (max-width: 480px) {
    .meet-header-title { font-size: 1.4rem; }
  }
</style>
