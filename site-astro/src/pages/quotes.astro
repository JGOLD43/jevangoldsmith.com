---
import data from '../../../data/quotes.json';
import Base from '../layouts/Base.astro';

interface Quote {
  id: string;
  slug?: string;
  text: string;
  author?: string;
  category?: string;
}

const featured = data.featuredQuote ?? null;
const quotes: Quote[] = data.fullQuotes ?? [];

// Distinct categories, alphabetical (mirrors legacy filter button order).
const categories: string[] = Array.from(
  new Set(quotes.map((q) => q.category).filter((c): c is string => Boolean(c)))
).sort();
function titleCase(s: string) {
  return s.replace(/\b\w/g, (c) => c.toUpperCase());
}
---
<Base
  title="Quotes That Shaped My Thinking | Jevan Goldsmith"
  description="A collection of quotes and durable ideas that shaped how Jevan Goldsmith thinks about life, business, growth, and decisions."
  canonical="https://jevangoldsmith.com/quotes.html"
  pageType="CollectionPage"
>
  <main>
    <section class="quotes-hero">
      <h1>Words That Shaped My Thinking</h1>
      <p>A collection of quotes that have influenced how I see the world, make decisions, and approach life. These are ideas I return to regularly.</p>
    </section>

    {featured && (
      <section class="featured-quote">
        <blockquote>&ldquo;{featured.text}&rdquo;</blockquote>
        {featured.author && <cite>- {featured.author}</cite>}
      </section>
    )}

    <div class="quote-filters" data-filter-group="quotes" data-filter-field="category">
      <button class="filter-btn active" type="button" data-filter-value="all">All Quotes</button>
      {categories.map((c) => (
        <button class="filter-btn " type="button" data-filter-value={c}>{titleCase(c)}</button>
      ))}
    </div>

    <div class="quotes-container">
      <div class="quotes-grid" id="quotes-grid">
        {quotes.map((q) => (
          <article class="quote-card" id={q.slug || q.id} data-category={q.category ?? ''}>
            <p class="quote-text">{q.text}</p>
            <div class="quote-footer">
              {q.author && <span class="quote-author">{q.author}</span>}
              {q.category && <span class="quote-category">{titleCase(q.category)}</span>}
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="submit-quote-section">
      <h2>Share a Quote</h2>
      <p>Have a quote that changed how you think? I'd love to hear it.</p>
      <a href="contact.html" class="btn-primary" data-analytics="cta" data-cta-id="contact" data-cta-location="quotes">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Send me a quote
      </a>
    </div>
  </main>
</Base>
