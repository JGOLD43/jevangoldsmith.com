---
// Ported from _src/pages/videos.html via scripts/port-page.mjs.
// SEO mirrors tests/seo-fixture.json.
import Base from '../layouts/Base.astro';
---
<Base
  title="Videos, Channels &amp; Useful Visual Learning | Jevan Goldsmith"
  description="A video archive of talks, channels, clips, and visual lessons Jevan Goldsmith found useful."
  canonical="https://jevangoldsmith.com/videos.html"
  pageType="CollectionPage"
>
<header class="page-header">
        <div class="container">
            <h1>Videos</h1>
            <p>My latest videos from YouTube</p>
        </div>
    </header>
    <main class="container">
        <div id="loading" class="loading">
            <p>Loading recent videos from YouTube...</p>
        </div>

        <div id="error" class="error-message" style="display: none;">
            <p>Unable to load videos from YouTube. Please try again later.</p>
        </div>

        <div id="videos-container" class="videos-grid" style="display: none;">
            <!-- Videos will be loaded here dynamically -->
        </div>

        <div class="channel-link">
            <a href="https://youtube.com/@JevanGoldsmith" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                Visit My YouTube Channel
            </a>
        </div>
</main>
</Base>
