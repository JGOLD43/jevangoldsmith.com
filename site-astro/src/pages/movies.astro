---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import moviesRuntimeData from '../../public/data/movies.json';
import CollectionPage from '../components/CollectionPage.astro';
import ContentVisibilityStyle from '../components/ContentVisibilityStyle.astro';
import InlineJson from '../components/InlineJson.astro';
import MovieModal from '../components/MovieModal.astro';
import MovieCard from '../components/MovieCard.astro';
import MovieStatsBody from '../components/MovieStatsBody.astro';
import SidebarRatingSliderFilters from '../components/SidebarRatingSliderFilters.astro';
import { MOVIE_SECTIONS, tasteListOptions } from '../lib/collection-sections';
import { slugify } from '../lib/slug';

const canonical = 'https://jevangoldsmith.com/movies.html';

// server-render every movie card. data/movies.json is
// kept fresh by `npm run movies:sync` (Letterboxd RSS sync). letterboxd.js
// detects the populated grid and skips the initial wipe, so SSR'd cards
// stay on screen until the runtime fetch completes (if it runs at all).

const movies = (await getCollection('movies') as CollectionEntry<'movies'>[]).map((m) => m.data);
const moviesByGenre = movies.reduce<Record<string, typeof movies>>((groups, movie) => {
  const genre = movie.genre || 'Uncategorized';
  (groups[genre] ||= []).push(movie);
  return groups;
}, {});

// "Recently Added" carousel — most recent 20 movies with a poster,
// SSR'd twice so the seamless-scroll loop is complete on first paint.
// Reuses the .recent-books-carousel / .carousel-* styles from books.
const recentMovies = [...movies]
  .filter((m) => m.poster)
  .sort((a, b) => new Date(b.date as string).getTime() - new Date(a.date as string).getTime())
  .slice(0, 20);
const carouselMovies = [...recentMovies, ...recentMovies].map((movie) => {
  const slug = slugify(movie.title || '');
  return {
    // Internal detail page — was pointing at movie.link (Letterboxd URL),
    // sending users off-site. Match the per-card slug routing used by
    // MovieCard so the carousel routes to the in-site detail page.
    href: slug ? `/movies/${slug}.html` : '#',
    title: `${movie.title} (${movie.year || ''})`,
    image: movie.poster as string,
    alt: movie.title
  };
});

// runtime payload (filter/star/genre state) inlined so letterboxd.ts can
// avoid the post-FCP fetch round-trip.
const moviesRuntimeJson = JSON.stringify(moviesRuntimeData);

// Build genre-folder cards for the Kindle-style grid view — mirrors the
// category-grid pattern on the books page. Each card shows up to 8
// poster thumbs + the genre name + count.
const genreGridCards = Object.entries(moviesByGenre)
  .sort((a, b) => b[1].length - a[1].length)
  .map(([genre, genreMovies]) => ({
    genre,
    count: genreMovies.length,
    covers: genreMovies.slice(0, 8).map((movie) => ({
      src: movie.poster || '',
      alt: movie.title || ''
    })),
    emptySlots: Math.max(0, 8 - Math.min(8, genreMovies.length))
  }));

const config = ({
  layout: { id: 'movies-layout', className: 'movies-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'movies-sidebar',
    className: 'movies-sidebar collection-sidebar collection-sidebar--taste collapsed',
    collapseAction: 'toggleSidebar',
    listAction: 'toggleListDropdown',
    currentListName: 'Movies',
    listOptions: tasteListOptions('movies'),
    search: {
      inputId: 'movie-search',
      inputClass: 'movie-search-input collection-search-input',
      placeholder: 'Search movies...',
      clearButtonId: 'movie-search-clear-btn',
      clearAction: 'clearMovieSearch',
      searchAction: 'searchMovies',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    loadingMessage: 'Loading...',
    sectionsWrapperId: 'sidebar-content',
    footerText: 'Movies with a badge have my full review',
    footerId: 'sidebar-footer',
    footerHidden: true,
    sections: MOVIE_SECTIONS.map((section) => {
      const genre = section.attrs?.['data-genre'];
      if (!section.panelId || !genre || genre === 'all') return section;
      const list = moviesByGenre[genre] || [];
      return {
        ...section,
        count: String(list.length),
        panelLinks: list.map((movie) => ({
          href: '#',
          className: 'movie-link',
          label: movie.title,
          meta: movie.year ? String(movie.year) : '',
          coverUrl: movie.poster ?? undefined,
          attrs: {
            'data-action': 'scrollToMovie',
            'data-action-args': encodeURIComponent(movie.title),
            'data-action-eventobj': 'true'
          }
        }))
      };
    })
  },
  main: {
    className: 'movies-main collection-main',
    titleTag: 'h2',
    title: 'Movie Lists',
    mobileGridLabel: 'Movies',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="movie-philosophy.html" class="header-subtitle-link">My Movie Philosophy</a><span class="read-first-note">read this first</span></div>',
    counterId: 'movie-count',
    counterLabel: 'Movies Watched',
    counterGroupClass: 'movie-counter-group'
  }
});
---
<CollectionPage
  config={config}
  title="Movie Reviews, Watchlist &amp; Taste Notes"
  description="A film archive of movies Jevan Goldsmith has watched, rated, revisited, and used to sharpen taste."
  canonical={canonical}
>
  <Fragment slot="sidebar-extra">
    <SidebarRatingSliderFilters clearAction="clearAllFilters" preventDefaultOnClear sliderLabel="Filter by Times Watched" sliderIcon="🎬" sliderId="timeswatched" />
  </Fragment>
  {recentMovies.length > 0 && (
    <Fragment slot="header-extra">
      <div class="recent-books-carousel">
        <span class="carousel-label">Recently Added</span>
        <div class="carousel-track" id="carousel-track" style={`animation-duration:${recentMovies.length * 3}s`}>
          {carouselMovies.map((movie) => (
            <a class="carousel-book-link" href={movie.href} title={movie.title}>
              <img class="carousel-book" src={movie.image} alt={movie.alt} decoding="async" loading="lazy" data-remove-on-error="true" />
            </a>
          ))}
        </div>
      </div>
    </Fragment>
  )}
  <Fragment slot="counter-extra">
    <div class="movie-counter-row">
      <button type="button" class="stats-toggle" aria-expanded="false" aria-controls="movie-stats-panel" aria-label="Show watch stats">Stats <span aria-hidden="true">▾</span></button>
      <button class="view-toggle-single" id="movies-view-toggle" data-action="toggle-movies-view-mode" data-current-mode="list" aria-label="Switch to genre grid view" title="Switch to genre grid view">
        <svg class="ico-stroke view-icon view-icon-list" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-listView"></use></svg>
        <svg class="ico-stroke view-icon view-icon-grid" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-gridView"></use></svg>
      </button>
    </div>
  </Fragment>
  <div id="error" class="error-message" style="display: none;">
    <p>Unable to load movies from Letterboxd. Please check the username in the code or try again later.</p>
  </div>
  <section id="movie-stats-panel" class="movie-stats-panel collapsed" aria-label="Watch stats" hidden>
    <div class="stats-body" data-initial-count={Array.isArray(moviesRuntimeData) ? moviesRuntimeData.length : 0}>
      <MovieStatsBody movies={Array.isArray(moviesRuntimeData) ? moviesRuntimeData : []} />
    </div>
  </section>
  <div id="movies-container" class="movies-grid">
    {movies.map((m) => <MovieCard movie={m} />)}
  </div>
  <div class="category-grid-view" id="movies-genre-grid-view" style="display: none;">
    <div class="category-grid" id="movies-genre-grid">
      {genreGridCards.map((g) => (
        <div class="category-card" data-action="open-genre-modal" data-genre={g.genre}>
          <div class="category-card-books">
            {g.covers.map((cover) => (
              cover.src ? <img src={cover.src} alt={cover.alt} loading="lazy" decoding="async" data-remove-on-error="true" /> : <div class="empty-slot"></div>
            ))}
            {Array.from({ length: g.emptySlots }).map(() => <div class="empty-slot"></div>)}
          </div>
          <div class="category-card-info">
            <span class="category-card-name">{g.genre}</span>
            <span class="category-card-count">{g.count}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
  <div id="genre-expanded-modal" class="category-expanded" role="dialog" aria-modal="true" aria-labelledby="genre-expanded-title">
    <div class="category-modal-backdrop" data-action="close-genre-modal"></div>
    <div class="category-modal-content">
      <div class="category-expanded-header">
        <h2 class="category-expanded-title" id="genre-expanded-title"></h2>
        <button class="category-expanded-close" data-action="close-genre-modal" aria-label="Close">&times;</button>
      </div>
      <div class="category-expanded-books" id="genre-expanded-movies"></div>
    </div>
    <template id="genre-expanded-movie-template">
      <div class="category-expanded-book" data-action="open-movie-from-grid" data-slug="" tabindex="0" role="button" aria-label="">
        <img src="" alt="" title="" decoding="async" data-remove-on-error="true">
      </div>
    </template>
  </div>
  <MovieModal slot="after-main" />
</CollectionPage>

<ContentVisibilityStyle selector=".movie-card" intrinsicSize="220px 360px" />

<style is:inline>
  .movie-counter-group {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }
  /* Stats + grid toggle on the same row, matching the books page
     layout. */
  .movie-counter-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }
</style>

<InlineJson id="jg-movies-data" json={moviesRuntimeJson} />

<script>
  // letterboxd transitively imports movie-stats; load order is implicit.
  import '../scripts/letterboxd.ts';
  import '../scripts/movies-folder-view.ts';
</script>
