---
import CollectionPage from '../components/CollectionPage.astro';
import { getCollection } from 'astro:content';
import {
  tasteListOptions,
  MOVIE_SECTIONS
} from '../lib/collection-chrome';
import { renderMovieCardHtml } from '../lib/movie-card';
import sidebarFiltersRaw from '../legacy/collections/movies/sidebar-filters.html?raw';
import mainBodyRaw from '../legacy/collections/movies/main-body.html?raw';

const canonical = 'https://jevangoldsmith.com/movies.html';

// Phase 1 slice 1.2: server-render every movie card. data/movies.json is
// kept fresh by `npm run movies:sync` (Letterboxd RSS sync). letterboxd.js
// detects the populated grid and skips the initial wipe, so SSR'd cards
// stay on screen until the runtime fetch completes (if it runs at all).

const movies = (await getCollection('movies')).map((m: any) => m.data);
const movieCardsHtml = movies.map((m: any) => renderMovieCardHtml(m)).join('');
const populatedMainBody = mainBodyRaw
  .trim()
  .replace(
    '<div id="movies-container" class="movies-grid"></div>',
    `<div id="movies-container" class="movies-grid">${movieCardsHtml}</div>`
  );

const movieModal = `<div id="movie-modal" class="modal">
    <div class="modal-content">
        <span class="modal-close" data-action="closeMovieModal">&times;</span>
        <div class="modal-body">
            <div class="modal-header">
                <img id="modal-movie-poster" src="" alt="" class="modal-cover" decoding="async">
                <div class="modal-info">
                    <h2 id="modal-movie-title"></h2>
                    <p id="modal-movie-year" class="modal-author"></p>
                    <div id="modal-movie-rating" class="modal-rating"></div>
                    <p id="modal-movie-date" style="color: var(--text-light); margin-top: 0.5rem;"></p>
                </div>
            </div>
            <div class="modal-review">
                <h3>My Review</h3>
                <p id="modal-movie-review" class="review-text"></p>
                <a id="modal-letterboxd-link" href="" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin-top: 1rem; color: var(--secondary-color); font-weight: 500;">View on Letterboxd →</a>
            </div>
        </div>
    </div>
</div>`;

const config = ({
  layout: { id: 'movies-layout', className: 'movies-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'movies-sidebar',
    className: 'movies-sidebar collection-sidebar collection-sidebar--taste collapsed',
    collapseAction: 'toggleSidebar',
    listAction: 'toggleListDropdown',
    currentListName: 'Movies',
    listOptions: tasteListOptions('movies', 'movies'),
    search: {
      inputId: 'movie-search',
      inputClass: 'movie-search-input collection-search-input',
      placeholder: 'Search movies...',
      clearButtonId: 'movie-search-clear-btn',
      clearAction: 'clearMovieSearch',
      searchAction: 'searchMovies',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    extraHtml: sidebarFiltersRaw.trim(),
    loadingMessage: 'Loading...',
    sectionsWrapperId: 'sidebar-content',
    footerText: 'Movies with a badge have my full review',
    footerId: 'sidebar-footer',
    footerHidden: true,
    sections: MOVIE_SECTIONS
  },
  main: {
    className: 'movies-main collection-main',
    title: 'My Movie Reviews',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="movie-philosophy.html" class="header-subtitle-link">My Movie Philosophy</a><span class="read-first-note">← read this first</span></div>',
    counterId: 'movie-count',
    counterLabel: 'Movies Watched',
    bodyHtml: populatedMainBody
  },
  afterMainHtml: movieModal
});
---
<CollectionPage
  config={config}
  title="Movie Reviews, Watchlist &amp; Taste Notes"
  description="A film archive of movies Jevan Goldsmith has watched, rated, revisited, and used to sharpen taste."
  canonical={canonical}
/>

<script>
  // Phase 5 (slice 10) + Phase 7 (slice 4): movies + infra deps as native modules.
  import '../scripts/grid-zoom.js';
  import '../scripts/collection-ui.js';
  import '../scripts/collection-runtime.js';
  import '../scripts/collection-helpers.js';
  import '../scripts/data-fetch.js';
  import '../scripts/action-dispatcher.js';
  import '../scripts/sanitize.js';
  // movie-stats must run before letterboxd so window.MovieStats is registered.
  import '../scripts/movie-stats.js';
  import '../scripts/letterboxd.js';
</script>
