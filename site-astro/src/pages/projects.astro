---
import raw from '../../../data/projects.json';
import Base from '../layouts/Base.astro';
import {
  renderTaskListMain,
  renderProjectCard,
  PROJECTS_TASK_CONFIG
} from '../lib/collection-chrome';

interface Project {
  id: string;
  slug?: string;
  title: string;
  status?: string;
  category?: string;
  shortDescription?: string;
  description?: string;
  visibility?: string;
  tags?: string[];
  technologies?: string[];
  topics?: string[];
}

const allProjects: Project[] = (raw as { projects?: Project[] }).projects ?? [];
const projects = allProjects.filter((p) => p.status !== 'draft' && p.visibility !== 'private');

const main = renderTaskListMain(projects, PROJECTS_TASK_CONFIG, renderProjectCard);
---
<Base
  title="Projects Jevan Goldsmith Is Building &amp; Exploring"
  description="A build log of projects Jevan Goldsmith is creating, testing, and turning into useful systems."
  canonical="https://jevangoldsmith.com/projects.html"
  pageType="CollectionPage"
>
  <Fragment set:html={main} />
</Base>
