---
import raw from '../../../data/challenges.json';
import Base from '../layouts/Base.astro';
import {
  renderTaskListMain,
  renderChallengeCard,
  CHALLENGES_TASK_CONFIG
} from '../lib/collection-chrome';

interface Challenge {
  id: string;
  slug?: string;
  title: string;
  status?: string;
  category?: string;
  timeframe?: string;
  shortDescription?: string;
  description?: string;
  visibility?: string;
  tags?: string[];
  searchTerms?: string[];
  icon?: string;
  progress?: { label?: string; value?: string; percent?: number | string };
}

const allChallenges: Challenge[] = (raw as { challenges?: Challenge[] }).challenges ?? [];
const challenges = allChallenges.filter((c) => c.status !== 'draft' && c.visibility !== 'private');

const main = renderTaskListMain(challenges, CHALLENGES_TASK_CONFIG, renderChallengeCard);
---
<Base
  title="Challenges, Constraints &amp; Personal Experiments"
  description="A record of challenges, constraints, and experiments Jevan Goldsmith uses to test ideas in real life."
  canonical="https://jevangoldsmith.com/challenges.html"
  pageType="CollectionPage"
>
  <Fragment set:html={main} />
</Base>
