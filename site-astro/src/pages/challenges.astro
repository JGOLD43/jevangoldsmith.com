---
import raw from '../../../data/challenges.json';
import TaskListPage from '../components/TaskListPage.astro';
import type { Challenge } from '../lib/collection-sections';
import { CHALLENGES_TASK_CONFIG } from '../lib/collection-sections';

const allChallenges: Challenge[] = (raw as { challenges?: Challenge[] }).challenges ?? [];
const challenges = allChallenges.filter((c) => c.status !== 'draft' && c.visibility !== 'private');
const lcpCoverUrl = challenges[0]?.image;
---
<TaskListPage
  type="challenge"
  items={challenges}
  config={CHALLENGES_TASK_CONFIG}
  title="Challenges, Constraints &amp; Personal Experiments"
  description="A record of challenges, constraints, and experiments Jevan Goldsmith uses to test ideas in real life."
  canonical="https://jevangoldsmith.com/challenges.html"
>
  {lcpCoverUrl && (
    <Fragment slot="head">
      <link rel="preload" as="image" fetchpriority="high" href={lcpCoverUrl} />
    </Fragment>
  )}
</TaskListPage>

<style is:inline>
  body.is-challenge-launching .movies-main,
  body.is-challenge-launching .movies-sidebar {
    opacity: 0;
    transition: opacity .32s cubic-bezier(.22, 1, .36, 1);
    pointer-events: none;
  }
  main.detail-page--challenge.is-challenge-arrival > * { opacity: 0; }
  main.detail-page--challenge.is-challenge-arrival .challenge-hero-image,
  main.detail-page--challenge.is-challenge-arrival .challenge-hero-image * { opacity: 0; }
  main.detail-page--challenge.is-challenge-arrival.is-challenge-revealed > * {
    opacity: 1;
    transition: opacity .28s cubic-bezier(.22, 1, .36, 1);
  }
  main.detail-page--challenge.is-challenge-arrival.is-challenge-cover-revealed .challenge-hero-image,
  main.detail-page--challenge.is-challenge-arrival.is-challenge-cover-revealed .challenge-hero-image * {
    opacity: 1;
    transition: none;
  }
  @media (prefers-reduced-motion: reduce) {
    main.detail-page--challenge.is-challenge-arrival > *,
    main.detail-page--challenge.is-challenge-arrival .challenge-hero-image,
    main.detail-page--challenge.is-challenge-arrival .challenge-hero-image * { opacity: 1; }
    body.is-challenge-launching .movies-main,
    body.is-challenge-launching .movies-sidebar { transition: none; }
  }
</style>

<script>
  import { initTaskListPage } from '../scripts/task-list-page';

  initTaskListPage({
    actions: {
      clearSearch: 'clearChallengeSearch',
      filter: 'filterChallenges',
      search: 'searchChallenges',
      toggleDropdown: 'toggleChallengeListDropdown',
      toggleSidebar: 'toggleChallengeSidebar'
    },
    cardSelector: '.challenge-card',
    counterId: 'challenge-count',
    gridId: 'challenges-container',
    layoutId: 'challenges-layout',
    searchClearButtonId: 'challenge-search-clear-btn',
    searchInputId: 'challenge-search',
    sidebarId: 'challenges-sidebar',
    storageKey: 'challenges-sidebar-collapsed',
    // No grid-zoom: cover-flight owns the click animation.
    flight: {
      cardSelector: 'a.challenge-card',
      coverSelector: 'img.project-cover',
      detailMainSelector: 'main.detail-page--challenge',
      detailHeroImgSelector: '.challenge-hero-image img',
      bodyLaunchClass: 'is-challenge-launching',
      arrivalKey: 'challenge',
      listingBackSelectors: ['.movies-sidebar', '.collection-sidebar']
    }
  });
</script>
