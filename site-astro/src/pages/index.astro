---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import indexBodyRaw from '../legacy/pages/index.html?raw';

// Strip the legacy YAML-style frontmatter (lines between leading --- markers).
function stripFrontmatter(raw: string): string {
  const lines = raw.split('\n');
  if (lines[0]?.trim() !== '---') return raw;
  let end = -1;
  for (let i = 1; i < lines.length; i++) {
    if (lines[i].trim() === '---') {
      end = i;
      break;
    }
  }
  if (end < 0) return raw;
  return lines.slice(end + 1).join('\n').trimStart();
}

const essays = await getCollection('essays', ({ data }: any) => data.status !== 'draft');
const books = await getCollection('books');
const projects = await getCollection('projects', ({ data }: any) => data.status !== 'draft').catch(() => []);

const counts: Record<string, number> = {
  essays: essays.length,
  books: books.length,
  projects: projects.length,
  resources: 0
};

let body = stripFrontmatter(indexBodyRaw);
body = body.replace(
  /<span class="stat-number" data-home-stat="([a-z]+)">[^<]*<\/span>/g,
  (match, key) => Object.prototype.hasOwnProperty.call(counts, key)
    ? `<span class="stat-number" data-home-stat="${key}">${counts[key]}</span>`
    : match
);
---
<Base
  title="Jevan Goldsmith - Finance, Real Estate Development, Writing & Tech"
  description="Personal website of Jevan Goldsmith: real estate development, writing, technology, books, adventures, and useful ideas."
  canonical="https://jevangoldsmith.com/"
  pageType="WebSite"
>
  <Fragment set:html={body} />
</Base>

<script>
  // Phase 5 (slice 14) + Phase 7 (slice 5): home + newsletter + sanitize as native.
  import '../scripts/sanitize.js';
  import '../scripts/home.js';
  import '../scripts/newsletter.js';
</script>
