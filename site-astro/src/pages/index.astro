---
import { getCollection } from 'astro:content';
import remoteAssets from '../../../data/remote-assets.generated.json';
import Base from '../layouts/Base.astro';

interface RemoteAssetEntry { widths?: number[]; formats?: Record<string, Record<string, string>>; }

// Convert remote Unsplash URLs into locally cached asset paths. The
// perf:budget check fails the build if any HTML references unsplash at
// runtime, so every dynamic image on this page MUST go through here.
function remoteAssetFor(url: string | undefined | null, preferredWidth = 800, format = 'jpg'): string {
  if (!url || !/^https?:\/\//i.test(url)) return url ?? '';
  const map = remoteAssets as Record<string, RemoteAssetEntry>;
  const entry = map[url.replace(/&amp;/g, '&')];
  if (!entry) return url;
  const widths = (entry.widths ?? Object.keys(entry.formats ?? {}).map(Number)).sort((a, b) => a - b);
  const width = widths.find((w) => w >= preferredWidth) ?? widths[widths.length - 1];
  return entry.formats?.[String(width)]?.[format] ?? entry.formats?.[String(width)]?.jpg ?? url;
}

// Pull one fresh item from each of the four feature sections so this
// carousel stays current with no hand-editing. Sorting prefers explicit
// dates where available; otherwise we trust the source array order
// (curated newest-first in the JSONs).
type FeatureCard = { href: string; image: string; kicker: string; title: string; meta: string; description: string };

// Looser typing on purpose — the collection schemas use z.looseObject so
// each item carries arbitrary extra fields. A narrow generic constraint
// here would discard everything except date/startDate.
const sortByDateDesc = (arr: any[]): any[] =>
  [...arr].sort((a, b) => {
    const aDate = (a?.date as string) || (a?.startDate as string) || '';
    const bDate = (b?.date as string) || (b?.startDate as string) || '';
    return bDate.localeCompare(aDate);
  });

const adventuresAll = await getCollection('adventures');
const essaysAll = await getCollection('essays');
const projectsAll = await getCollection('projects');
const challengesAll = await getCollection('challenges');

const latestAdventure: any = sortByDateDesc(adventuresAll.map((a: any) => a.data))[0];
const latestEssay: any = sortByDateDesc(essaysAll.map((e: any) => e.data).filter((e: any) => e.status !== 'draft'))[0];
const latestProject: any = projectsAll.map((p: any) => p.data).filter((p: any) => p.status !== 'draft' && p.visibility !== 'private')[0];
const latestChallenge: any = challengesAll.map((c: any) => c.data).filter((c: any) => c.status !== 'draft')[0];

const featureCards: FeatureCard[] = [];
if (latestAdventure) {
  featureCards.push({
    // Route through the polished /adventures overlay rather than the
    // standalone /adventure-<slug>.html legacy page — the two render
    // very differently and clicking from the homepage carousel should
    // land users in the same view as clicking from the trips list /
    // map. adventures.ts reads ?trip= and opens the overlay on load.
    href: `/adventures.html?trip=${latestAdventure.id}`,
    image: remoteAssetFor(latestAdventure.heroImage) || '/images/generated/remote/bedf9633d8221e-800.jpg',
    kicker: 'Adventure',
    title: latestAdventure.title,
    meta: [latestAdventure.location, latestAdventure.duration].filter(Boolean).join(' • '),
    description: latestAdventure.subtitle || latestAdventure.shortDescription || ''
  });
}
if (latestEssay) {
  featureCards.push({
    href: `/essays.html#${latestEssay.id}`,
    image: remoteAssetFor((latestEssay as any).featuredImage) || '/images/generated/remote/cd2aacee7b912f-800.jpg',
    kicker: 'Essay',
    title: latestEssay.title,
    meta: latestEssay.category || '',
    description: latestEssay.subtitle || latestEssay.category || ''
  });
}
if (latestProject) {
  featureCards.push({
    href: `/projects/${latestProject.slug || latestProject.id}.html`,
    image: remoteAssetFor(latestProject.image) || '/images/generated/remote/3764adabb88a12-800.jpg',
    kicker: 'Project',
    title: latestProject.title,
    meta: latestProject.category || '',
    description: latestProject.shortDescription || latestProject.description || ''
  });
}
if (latestChallenge) {
  featureCards.push({
    href: `/challenges/${latestChallenge.slug || latestChallenge.id}.html`,
    image: remoteAssetFor(latestChallenge.image) || '/images/generated/remote/0c026ddcd6c4bb-800.jpg',
    kicker: 'Challenge',
    title: latestChallenge.title,
    meta: latestChallenge.timeframe || '',
    description: latestChallenge.shortDescription || ''
  });
}
---
<Base
  title="Jevan Goldsmith - Finance, Real Estate Development, Writing & Tech"
  description="Personal website of Jevan Goldsmith: real estate development, writing, technology, books, adventures, and useful ideas."
  canonical="https://jevangoldsmith.com/"
  pageType="WebSite"
>
  <Fragment slot="head">
    {/* LCP candidate — profile portrait. Preload BOTH the AVIF
        srcset and the JPG fallback, with matching imagesizes, so the
        browser preloads the exact variant it will actually display.
        Previously only the 720 JPG was preloaded, but the <img> uses
        responsive AVIF srcset — so the variant the browser picked
        (e.g. AVIF 520 on a 414px viewport) wasn't preloaded and the
        portrait visibly faded in after HTML parse reached the img. */}
    <link
      rel="preload"
      as="image"
      type="image/avif"
      imagesrcset="/images/generated/profile/profile-360.avif 360w, /images/generated/profile/profile-520.avif 520w, /images/generated/profile/profile-720.avif 720w, /images/generated/profile/profile-960.avif 960w"
      imagesizes="(max-width: 768px) 82vw, 42vw"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      type="image/jpeg"
      imagesrcset="/images/generated/profile/profile-360.jpg 360w, /images/generated/profile/profile-520.jpg 520w, /images/generated/profile/profile-720.jpg 720w, /images/generated/profile/profile-960.jpg 960w"
      imagesizes="(max-width: 768px) 82vw, 42vw"
      fetchpriority="high"
    />
  </Fragment>
    <!-- Side Navigation Dots -->
    <nav class="side-nav" id="side-nav">
        <a href="#hero" class="side-nav-dot active" data-section="hero" title="Intro" aria-label="Intro"></a>
        <a href="#newsletter-cta" class="side-nav-dot" data-section="newsletter-cta" title="Newsletter" aria-label="Newsletter"></a>
        <a href="#featured" class="side-nav-dot" data-section="featured" title="Featured" aria-label="Featured"></a>
        <a href="#value-prop" class="side-nav-dot" data-section="value-prop" title="What I Do" aria-label="What I Do"></a>
        <a href="#essays" class="side-nav-dot" data-section="essays" title="Essays" aria-label="Essays"></a>
        <a href="#focus" class="side-nav-dot" data-section="focus" title="Current Focus" aria-label="Current Focus"></a>
    </nav>

    <header class="hero" id="hero">
        <div class="hero-container">
            <div class="hero-left">
                <h1 class="hero-headline">
                    <span class="mode-work">Jevan Goldsmith<br><span class="hero-welcome-work">Project Coordinator</span></span>
                    <span class="mode-personal">Hi I'm Jevan.</span>
                </h1>
                <p class="hero-welcome">
                    <span class="mode-work hero-work-now">What I'm working on <a href="/now.html" class="hero-now-link">now</a></span>
                    <span class="mode-personal">In the effort to better remember my life I had an idea that I needed to keep a better tab on it. Maybe I took that too literally.</span>
                </p>
                <!-- Hidden for now; uncomment to re-enable.
                <a href="meet.html" class="hero-cta-left">
                    <span class="cta-title">Schedule a meeting / coffee chat</span>
                    <p class="cta-text">Best way to reach me is <span class="cta-link">email</span> or <span class="cta-link">X</span></p>
                </a>
                -->

            </div>
            <div class="hero-right">
                <div class="profile-container">
                    <picture class="hero-picture">
                        <source type="image/avif" srcset="/images/generated/profile/profile-360.avif 360w, /images/generated/profile/profile-520.avif 520w, /images/generated/profile/profile-720.avif 720w, /images/generated/profile/profile-960.avif 960w" sizes="(max-width: 768px) 82vw, 42vw">
                        <img src="/images/generated/profile/profile-720.jpg" srcset="/images/generated/profile/profile-360.jpg 360w, /images/generated/profile/profile-520.jpg 520w, /images/generated/profile/profile-720.jpg 720w, /images/generated/profile/profile-960.jpg 960w" sizes="(max-width: 768px) 82vw, 42vw" alt="Jevan Goldsmith" class="hero-image" width="713" height="778" decoding="async" fetchpriority="high">
                    </picture>

                    <!-- Animated Snapshot Card (Hidden by default) -->
                    <div class="snapshot-card" id="snapshot-card">
                        <div class="snapshot-header">
                            <span class="snapshot-eyebrow">QUICK SNAPSHOT</span>
                            <svg class="snapshot-camera-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 32 32">
                                <!-- Flash starburst -->
                                <g class="flash-burst">
                                    <polygon points="26,2 27,5 30,4 28,7 31,9 28,10 29,13 26,11 24,14 24,11 21,12 23,9 20,8 23,6 22,3 25,5" fill="#FFD700"/>
                                    <circle cx="25" cy="8" r="2" fill="#FFF5CC"/>
                                </g>
                                <!-- Retro camera body - black -->
                                <rect x="2" y="10" width="22" height="16" rx="2" fill="#1a1a1a" stroke="#333" stroke-width="0.5"/>
                                <!-- Viewfinder bump -->
                                <rect x="6" y="6" width="8" height="5" rx="1" fill="#1a1a1a" stroke="#333" stroke-width="0.5"/>
                                <!-- Flash cube on top -->
                                <rect x="16" y="7" width="4" height="4" fill="#444" stroke="#555" stroke-width="0.5"/>
                                <!-- Main lens ring - silver -->
                                <circle cx="13" cy="18" r="6" fill="#2a2a2a" stroke="#666" stroke-width="1"/>
                                <circle cx="13" cy="18" r="4.5" fill="#1a1a1a" stroke="#888" stroke-width="0.5"/>
                                <!-- Lens glass - dark with reflection -->
                                <circle cx="13" cy="18" r="3" fill="#0a0a0a"/>
                                <ellipse cx="12" cy="17" rx="1" ry="0.6" fill="rgba(255,255,255,0.15)"/>
                                <!-- Shutter button - red accent -->
                                <circle cx="20" cy="13" r="1.5" fill="#cc3333"/>
                                <!-- Grip lines -->
                                <line x1="3" y1="14" x2="3" y2="22" stroke="#333" stroke-width="0.5"/>
                                <line x1="4.5" y1="14" x2="4.5" y2="22" stroke="#333" stroke-width="0.5"/>
                            </svg>
                            <button class="snapshot-close" data-snapshot-toggle aria-label="Close">&times;</button>
                        </div>
                        <div class="snapshot-content">
                            <a class="snapshot-row" href="/about.html#focus" aria-label="Read more about my focus">
                                <div class="snapshot-label">Focus</div>
                                <div class="snapshot-value">Building Beautiful Products</div>
                            </a>
                            <a class="snapshot-row" href="/about.html#values" aria-label="Read more about my values">
                                <div class="snapshot-label">Values</div>
                                <div class="snapshot-value">Impact • Mastery • Adventure</div>
                            </a>
                            <a class="snapshot-row" href="/about.html#stats" aria-label="Read more about my stats">
                                <div class="snapshot-label">Stats</div>
                                <div class="snapshot-value">Height 183cm • <img src="/images/flags/au.png" alt="Australian Flag" class="snapshot-flag" width="80" height="40" loading="lazy" decoding="async"></div>
                            </a>
                            <a href="about.html" class="snapshot-bio-link">Read Full Bio</a>
                        </div>
                    </div>

                    <!-- Quick Snapshot Toggle Button — placed AFTER the
                         snapshot card in DOM so it paints on top in 2D
                         stacking order regardless of 3D context tricks. -->
                    <button class="snapshot-toggle" data-snapshot-toggle aria-label="Toggle profile snapshot">
                        PROFILE
                    </button>
                </div>
                <div class="hero-social-links">
                    <a href="https://x.com/JevanGoldsmith" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
                        <svg class="ico-fill ico-24" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-x"/></svg>
                    </a>
                    <a href="https://youtube.com/@JevanGoldsmith" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                        <svg class="ico-fill ico-24" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-youtube"/></svg>
                    </a>
                    <a href="https://letterboxd.com/contentwatch" target="_blank" rel="noopener noreferrer" aria-label="Letterboxd">
                        <svg class="ico-fill ico-24" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-letterboxd"/></svg>
                    </a>
                    <a href="https://linkedin.com/in/jevan-goldsmith-7b885a185" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <svg class="ico-fill ico-24" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-linkedin"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Newsletter CTA Section -->
    <section class="newsletter-cta-section newsletter-cta-section--minimal" id="newsletter-cta">
        <div class="newsletter-cta-container">
            <div class="newsletter-cta-content">
                <h2 class="newsletter-cta-title">Newsletter</h2>
                <p class="newsletter-cta-description">Exclusive, newsletter-only content once a month. No spam, no nonsense.</p>
                <form class="newsletter-cta-form newsletter-cta-form--inline" action="https://formsubmit.co/hello@jevangoldsmith.com" method="POST" data-newsletter-form data-endpoint="https://formsubmit.co/ajax/hello@jevangoldsmith.com">
                    <input type="hidden" name="_subject" value="Newsletter signup">
                    <input type="hidden" name="_template" value="table">
                    <label class="sr-only" for="home-field-notes-email">Email for newsletter</label>
                    <input id="home-field-notes-email" type="email" placeholder="Enter your email" class="newsletter-cta-input" name="email" autocomplete="email" required>
                    <button type="submit" class="newsletter-cta-button">Subscribe</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Featured Carousel Section -->
    <section class="featured-carousel-section" id="featured">
        <div class="carousel-header">
            <h2 class="carousel-title">Things I have been up to</h2>
            <a href="search.html" class="carousel-discover">Explore everything →</a>
        </div>
        <div class="carousel-controls">
            <button class="carousel-arrow carousel-prev" data-carousel-direction="-1" aria-label="Previous">‹</button>
            <button class="carousel-arrow carousel-next" data-carousel-direction="1" aria-label="Next">›</button>
        </div>
        <div class="carousel-container">
            <div class="feature-carousel-track" id="carousel-track">
                {featureCards.map((card) => (
                    <a href={card.href} class="feature-card">
                        <img src={card.image} alt={card.title} class="feature-image" width="800" height="600" loading="lazy" decoding="async">
                        <div class="feature-content">
                            <span class="feature-kicker">{card.kicker}</span>
                            <h3 class="feature-title">{card.title}</h3>
                            {card.meta && <p class="feature-meta">{card.meta}</p>}
                            {card.description && <p class="feature-description">{card.description}</p>}
                        </div>
                    </a>
                ))}
            </div>
        </div>
        <div class="carousel-dots" id="carousel-dots">
            {featureCards.map((_, i) => (
                <span class={i === 0 ? 'dot active' : 'dot'} data-carousel-slide={i}></span>
            ))}
        </div>
    </section>

</Base>

<style is:inline>
  /* Minimal newsletter section — clean, low-key block with a single-row
     pill input that has the Subscribe button tucked inside the right edge. */
  /* Edge-to-edge horizontal band, bounded by hairlines top + bottom —
     matches the dark-mode treatment shown in the original design. Fill
     is white in light mode so it pops against the creamy --background,
     transparent in dark mode (page bg already provides contrast). */
  .newsletter-cta-section--minimal {
    background: #fff;
    padding: 3rem 1.25rem;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }
  [data-theme="dark"] .newsletter-cta-section--minimal {
    background: transparent;
  }
  .newsletter-cta-section--minimal .newsletter-cta-container { max-width: 720px; margin: 0 auto; }
  .newsletter-cta-section--minimal .newsletter-cta-content { text-align: left; }
  .newsletter-cta-section--minimal .newsletter-cta-title {
    color: var(--text-color);
    font-family: Chivo, sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    letter-spacing: 0;
  }
  .newsletter-cta-section--minimal .newsletter-cta-description {
    color: var(--text-light);
    font-size: 1rem;
    line-height: 1.5;
    margin: 0 0 1.5rem;
    max-width: 640px;
  }
  .newsletter-cta-form.newsletter-cta-form--inline {
    position: relative;
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    background: var(--background);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    padding: 4px 4px 4px 18px;
    max-width: 640px;
    gap: 0;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .newsletter-cta-form--inline:focus-within {
    border-color: var(--text-color);
    box-shadow: 0 0 0 3px rgba(0,0,0,0.04);
  }
  .newsletter-cta-form.newsletter-cta-form--inline .newsletter-cta-input {
    flex: 1 1 auto !important;
    width: auto !important;
    border: none !important;
    background: transparent !important;
    color: var(--text-color) !important;
    font-size: 0.95rem !important;
    padding: 0.65rem 0.5rem !important;
    outline: none !important;
    min-width: 0 !important;
    font-family: inherit;
    box-shadow: none !important;
  }
  .newsletter-cta-form.newsletter-cta-form--inline .newsletter-cta-input::placeholder { color: var(--text-light); opacity: 0.7; }
  /* Match the navbar "Follow" button: gold pill with a black border
     and black text. Hover inverts to black background with gold text
     so the affordance pattern reads the same across the site. */
  .newsletter-cta-form.newsletter-cta-form--inline .newsletter-cta-button {
    flex: 0 0 auto !important;
    width: auto !important;
    background: gold !important;
    color: #000 !important;
    border: 2px solid #000 !important;
    border-radius: 999px !important;
    padding: 0.55rem 1.25rem !important;
    font-size: 0.9rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.5px;
    font-family: inherit;
    cursor: pointer;
    transition: background .2s ease, color .2s ease, transform .15s ease, box-shadow .2s ease;
    margin: 0 !important;
  }
  .newsletter-cta-form--inline .newsletter-cta-button:hover {
    background: #000 !important;
    color: gold !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px #0003;
  }
  @media (max-width: 480px) {
    .newsletter-cta-form--inline { padding-left: 14px; }
    .newsletter-cta-form--inline .newsletter-cta-button { padding: 0.55rem 1rem; font-size: 0.85rem; }
  }

  /* Mobile only: PROFILE tap slides the snapshot up from the bottom of
     the profile picture, covering it with a frosted-glass panel. */
  @media (max-width: 768px) {
    .profile-container {
      position: relative;
      overflow: hidden;
      border-radius: 12px;
    }
    /* Slide-up snapshot panel. Transform is driven by inline style from
       JS (the legacy stylesheet has a handful of !important transforms
       on .snapshot-card variants that win against any CSS-cascade
       attempt to override them on this page). The CSS here owns
       everything except the transform. */
    .profile-container .snapshot-card {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      max-width: none !important;
      margin: 0 !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: none;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.45);
      /* Border matches the glass instead of the legacy dark outline,
         so the panel reads as one continuous frosted surface. */
      border: 1px solid rgba(255, 255, 255, 0.12) !important;
      background: rgba(20, 20, 20, 0.55) !important;
      backdrop-filter: blur(20px) saturate(160%);
      -webkit-backdrop-filter: blur(20px) saturate(160%);
      /* GPU-composite the slide so backdrop-filter doesn't re-rasterize
         every frame — without this the slide-up visibly stutters on
         mid-range phones. */
      will-change: transform;
      transform: translate3d(0, 100%, 0);
      contain: layout paint;
      /* No CSS transition — animation is driven by the Web Animations
         API in home.ts (bypasses cascade fights with legacy rules). */
    }
    .profile-container.is-flipped .snapshot-card { pointer-events: auto; }
    /* Header inside the glass panel — no separate solid bar, just a
       hairline divider so the whole panel reads as one piece of glass. */
    .profile-container .snapshot-header {
      background: transparent !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.18) !important;
      color: #fff !important;
      justify-content: flex-start !important;
      gap: 0.55rem !important;
    }
    .profile-container .snapshot-header .snapshot-camera-icon {
      order: 0;
      margin-right: auto;
    }
    .profile-container .snapshot-header .snapshot-eyebrow,
    .profile-container .snapshot-header h4 { color: #fff !important; }
    .profile-container .snapshot-content { color: #fff; }
    .profile-container .snapshot-label { color: rgba(255, 255, 255, 0.65) !important; }
    .profile-container .snapshot-value {
      color: #fff !important;
      /* Match the "What I'm working on now" hero text exactly —
         same Inter font stack, same letter-spacing, lighter weight
         so the values read as body copy rather than headings. */
      font-family: Inter, -apple-system, BlinkMacSystemFont, Chivo, sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: -0.01em !important;
    }
    .profile-container .snapshot-bio-link {
      font-family: Inter, -apple-system, BlinkMacSystemFont, Chivo, sans-serif !important;
      font-weight: 500 !important;
      letter-spacing: -0.01em !important;
    }
    /* Each snapshot row is now a link to a specific section on the
       About page — strip the default link colour/underline, then
       add a subtle background highlight on hover to signal that the
       row is clickable. Same affordance pattern as the essay rows. */
    .profile-container .snapshot-row {
      display: block;
      text-decoration: none;
      color: inherit;
      transition: background 0.18s ease;
      border-radius: 6px;
      margin: 0 -0.5rem;
      padding: 0.85rem 0.5rem;
    }
    .profile-container .snapshot-row:hover {
      background: rgba(255, 255, 255, 0.06);
    }
    .profile-container .snapshot-row:focus-visible {
      outline: 2px solid var(--secondary-color);
      outline-offset: 2px;
    }
    .profile-container .snapshot-row { border-bottom-color: rgba(255, 255, 255, 0.12) !important; }
    /* The last snapshot-row (Stats) AND the bio-link below it BOTH had a
       border, stacking into a double hairline above Read Full Bio. Drop
       the bio-link's top border — the row's bottom border serves as the
       divider. Keep the spacing (margin/padding) so the bio-link still
       breathes below the row. */
    .snapshot-content > .snapshot-row + .snapshot-bio-link { border-top: 0 !important; }
    .profile-container .snapshot-bio-link {
      color: #fff !important;
      border-top: 0 !important;
    }
    /* PROFILE button stays anchored in the bottom-right of the card.
       Always on top of both photo and the sliding snapshot. */
    .profile-container .snapshot-toggle {
      position: absolute !important;
      bottom: 12px !important;
      right: 12px !important;
      top: auto !important;
      left: auto !important;
      z-index: 100 !important;
      background: var(--background) !important;
