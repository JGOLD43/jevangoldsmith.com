---
import Base from '../layouts/Base.astro';
import coolShitData from '../../public/data/cool-shit.json';

const coolShitJson = JSON.stringify(coolShitData);
---
<Base
  title="Cool Shit: Objects, Ideas &amp; Useful Finds | Jevan Goldsmith"
  description="A taste archive of interesting objects, tools, ideas, links, and finds that earned Jevan Goldsmith's attention."
  canonical="https://jevangoldsmith.com/cool-shit.html"
  pageType="CollectionPage"
>
<main class="cool-page" data-active="feed">
        <div class="cool-content">
            <div class="container">
                <header class="cool-page-header">
                    <p class="feed-eyebrow">Field Archive · Cool Shit</p>
                    <h1>Cool Shit</h1>
                    <p>Interesting objects, tools, ideas, links, and finds that earned a permanent place in my attention.</p>
                </header>

                <div class="cool-layout">
                    <section class="cool-col-feed" aria-label="Feed">
                        <div class="feed-head">
                            <span class="feed-eyebrow">Field Archive · Cool Shit</span>
                            <span class="feed-count" id="feed-count"></span>
                        </div>
                        <div class="feed" id="feed"></div>
                        <div class="cool-empty" id="feed-empty" hidden>Nothing in this category yet.</div>
                    </section>
                    <aside class="cool-col-rail" aria-label="Filter by category">
                        <div class="cool-rail-head"><span>Filter</span></div>
                        <nav class="cool-tag-rail" id="tag-rail"></nav>
                        <div class="cool-rail-stats">
                            <span id="hero-count">—</span> finds · <span id="hero-cats">—</span> cats · last <span id="hero-updated">—</span>
                        </div>
                    </aside>
                </div>

            </div>
        </div>
</main>

{/* Timeline sidebar removed: the 260px sidebar column + per-month
    render/scroll-spy logic was deadweight (~150 LOC + ~3KB JS, plus
    layout cost). Override the legacy two-col grid so the remaining
    feed fills the row. */}
<style is:global>
  .cool-page { grid-template-columns: 1fr; }
</style>

<script type="application/json" id="jg-cool-shit-data" set:html={coolShitJson} />

<script>
  import '../scripts/sanitize.ts';
  import '../scripts/cool-shit.ts';
</script>
</Base>
