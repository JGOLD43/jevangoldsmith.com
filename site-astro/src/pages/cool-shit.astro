---
import coolShitData from '../../public/data/cool-shit.json';
import Base from '../layouts/Base.astro';
import { dayLabel, monthKey } from '../lib/dates';
import { sanitizeUrl as sanitizeUrlServer } from '../lib/url-server';

const coolShitJson = JSON.stringify(coolShitData);

const items = [...coolShitData.items].sort((a, b) => b.date.localeCompare(a.date));
const cats = coolShitData.categories;
const catLookup = Object.fromEntries(cats.map((c) => [c.id, c]));
const usedCatIds = new Set(items.map((it) => it.category));
const orderedCats = cats.filter((c) => usedCatIds.has(c.id));
const byCat: Record<string, number> = {};
for (const it of items) byCat[it.category] = (byCat[it.category] || 0) + 1;

// Variant B (Are.na Wall) tile-size + tone assignment.
// Deterministic per-index so layout is stable across renders.
const IMG_SIZES = ['s-3x3', 's-2x2', 's-3x2', 's-2x3', 's-2x2', 's-2x2', 's-3x2'];
const TEXT_SIZES = ['s-2x2', 's-2x3', 's-2x2', 's-3x2'];
const TEXT_TONES = ['', 'sage', 'rose', 'dark', '', 'sage'];

function tileFor(idx: number, hasImage: boolean) {
  if (hasImage) {
    return { size: IMG_SIZES[idx % IMG_SIZES.length], tone: '' };
  }
  return { size: TEXT_SIZES[idx % TEXT_SIZES.length], tone: TEXT_TONES[idx % TEXT_TONES.length] };
}
---
<Base
  title="Cool Shit: Objects, Ideas &amp; Useful Finds | Jevan Goldsmith"
  description="A taste archive of interesting objects, tools, ideas, links, and finds that earned Jevan Goldsmith's attention."
  canonical="https://jevangoldsmith.com/cool-shit.html"
  pageType="CollectionPage"
>
<main class="cool-page wall-mode" data-active="feed">
  <header class="wall-topbar">
    <div class="wall-brand">interests<span class="wall-count" id="feed-count">{items.length}</span></div>
    <nav class="wall-rail" id="tag-rail" aria-label="Filter by category">
      <button type="button" class="cool-tag-pill active" data-cat="all">all<span class="count">{items.length}</span></button>
      {orderedCats.map((c) => (
        <button type="button" class="cool-tag-pill" data-cat={c.id}>
          {c.label.toLowerCase()}<span class="count">{byCat[c.id]}</span>
        </button>
      ))}
    </nav>
  </header>

  <div class="wall-grid" id="feed">
    {items.map((item, idx) => {
      const cat = catLookup[item.category] || { label: item.category, emoji: '' };
      const t = tileFor(idx, !!item.image);
      const classes = ['feed-item', `wall-tile`, t.size, item.image ? 'wall-img' : `wall-text${t.tone ? ` ${t.tone}` : ''}`].join(' ');
      return (
        <article
          class={classes}
          id={`item-${item.id}`}
          data-id={item.id}
          data-month={monthKey(item.date)}
          data-category={item.category}
        >
          {item.image && (
            <img
              class="feed-item-image"
              src={item.image}
              alt={item.title}
              loading="lazy"
              decoding="async"
            />
          )}
          {item.image ? (
            <div class="wall-label">
              <span class="feed-item-tag">{cat.label}</span>
              <span class="feed-item-title">{item.title}</span>
              <span class="feed-item-date">{dayLabel(item.date)}</span>
            </div>
          ) : (
            <div class="wall-text-body feed-item-body">
              <h3 class="feed-item-title">{item.title}</h3>
              <div class="feed-item-meta">
                <span class="feed-item-tag">{cat.label}</span>
                <span class="feed-item-date">{dayLabel(item.date)}</span>
                <span class="feed-item-source">{item.source || ''}</span>
              </div>
              {item.url && (
                <a class="feed-item-link" href={sanitizeUrlServer(item.url)} target="_blank" rel="noopener">visit {item.source} →</a>
              )}
            </div>
          )}
        </article>
      );
    })}
  </div>

  <div class="cool-empty wall-empty" id="feed-empty" hidden>Nothing in this category yet.</div>
</main>

<style is:global>
  /* ============================================================
     Variant B — "Are.na Wall" mode.
     Scope everything under .wall-mode so legacy .cool-page rules
     in legacy.src.css don't leak in.
     ============================================================ */
  .wall-mode {
    /* Light mode: warm cream Are.na aesthetic. Matches the body /
       footer --background token (#f5f3ed) so the page reads as one
       continuous surface from header through grid through footer.
       Previously: #f4f0e8 (slightly warmer/yellower) created a
       visible seam where the wall ended and the footer began. */
    --wall-bg: #f5f3ed;
    --wall-ink: #1a1a1a;
    --wall-muted: #7a7468;
    --wall-line: #d9d3c4;
    --wall-cream: #ece2c8;
    --wall-sage: #c9d3bf;
    --wall-rose: #e8c9c1;
    --wall-charcoal: #2a2a26;
    --wall-tile-bg: #ddd;
    --wall-label-text: #f4f0e8;
    --wall-charcoal-text: #f4f0e8;
    --wall-charcoal-muted: #a8a298;

    background: var(--wall-bg);
    color: var(--wall-ink);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    line-height: 1.4;
    grid-template-columns: 1fr;
    min-height: 100vh;
  }

  /* Dark mode: same wall layout, dark palette. Keeps the colored tile
     variants (cream/sage/rose) but shifts each to its dark-friendly
     counterpart so the page reads as one piece, not light squares on
     a dark background. */
  [data-theme="dark"] .wall-mode {
    --wall-bg: #0f0f0f;
    --wall-ink: #f0f0f0;
    --wall-muted: #8a8a8a;
    --wall-line: #2a2a2a;
    --wall-cream: #1f1d18;
    --wall-sage: #1d2620;
    --wall-rose: #261d1d;
    --wall-charcoal: #050505;
    --wall-tile-bg: #1a1a1a;
    --wall-charcoal-text: #ececec;
    --wall-charcoal-muted: #777;
  }

  .wall-mode .wall-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px 32px;
    border-bottom: 1px solid var(--wall-line);
    position: sticky;
    top: 0;
    background: var(--wall-bg);
    z-index: 20;
    flex-wrap: wrap;
  }
  .wall-mode .wall-brand {
    font-weight: 700;
    letter-spacing: .05em;
    font-size: 14px;
  }
  .wall-mode .wall-brand .wall-count {
    color: var(--wall-muted);
    margin-left: 8px;
    font-weight: 400;
  }
  .wall-mode .wall-brand .wall-count::before { content: '/ '; }

  .wall-mode .wall-rail {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .wall-mode .cool-tag-pill {
    background: transparent;
    border: none;
    color: var(--wall-muted);
    font-family: inherit;
    font-size: 12px;
    padding: 4px 8px;
    cursor: pointer;
    letter-spacing: .04em;
    border-radius: 0;
  }
  .wall-mode .cool-tag-pill:hover { color: var(--wall-ink); }
  .wall-mode .cool-tag-pill.active {
    color: var(--wall-ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .wall-mode .cool-tag-pill .count {
    margin-left: 4px;
    color: var(--wall-muted);
    font-size: 11px;
    background: none;
    padding: 0;
  }
  .wall-mode .cool-tag-pill.active .count { color: var(--wall-ink); opacity: .55; }

  .wall-mode .wall-grid {
    --cols: 12;
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    grid-auto-rows: 70px;
    grid-auto-flow: dense;
    gap: 8px;
    padding: 24px 32px 96px;
  }

  .wall-mode .wall-tile {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    background: var(--wall-tile-bg);
    outline: 1px solid transparent;
    transition: outline-color .15s;
    cursor: pointer;
    margin: 0;
  }
  .wall-mode .wall-tile:hover { outline-color: var(--wall-ink); }

  .wall-mode .wall-img .feed-item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .wall-mode .wall-img .wall-label {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 8px 10px;
    background: linear-gradient(transparent, rgba(0,0,0,.6));
    color: #f4f0e8;
    font-size: 10px;
    letter-spacing: .06em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    transition: opacity .2s;
    pointer-events: none;
  }
  .wall-mode .wall-img:hover .wall-label { opacity: 1; }
  .wall-mode .wall-img .wall-label .feed-item-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: none;
    letter-spacing: -.01em;
  }
  .wall-mode .wall-img .wall-label .feed-item-date { opacity: .7; }

  .wall-mode .wall-text {
    background: var(--wall-cream);
    color: var(--wall-ink);
    padding: 16px;
    display: flex;
    align-items: center;
  }
  .wall-mode .wall-text.sage { background: var(--wall-sage); }
  .wall-mode .wall-text.rose { background: var(--wall-rose); }
  .wall-mode .wall-text.dark { background: var(--wall-charcoal); color: var(--wall-charcoal-text); }
  .wall-mode .wall-text .wall-text-body { width: 100%; }
  .wall-mode .wall-text .feed-item-title {
    font-family: inherit;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -.01em;
    margin: 0 0 8px;
    color: inherit;
  }
  .wall-mode .wall-text .feed-item-meta {
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--wall-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .wall-mode .wall-text.dark .feed-item-meta { color: var(--wall-charcoal-muted); }
  .wall-mode .wall-text .feed-item-tag { color: inherit; background: none; padding: 0; }
  .wall-mode .wall-text .feed-item-source::before { content: '· '; }
  .wall-mode .wall-text .feed-item-link {
    display: inline-block;
    margin-top: 10px;
    font-size: 11px;
    color: inherit;
    border-bottom: 1px solid currentColor;
    text-decoration: none;
    padding-bottom: 1px;
  }

  /* Tile sizes — column × row spans */
  .wall-mode .s-2x1 { grid-column: span 2; grid-row: span 1; }
  .wall-mode .s-2x2 { grid-column: span 2; grid-row: span 2; }
  .wall-mode .s-2x3 { grid-column: span 2; grid-row: span 3; }
  .wall-mode .s-3x2 { grid-column: span 3; grid-row: span 2; }
  .wall-mode .s-3x3 { grid-column: span 3; grid-row: span 3; }
  .wall-mode .s-4x2 { grid-column: span 4; grid-row: span 2; }

  .wall-mode .wall-empty {
    padding: 64px 32px;
    text-align: center;
    color: var(--wall-muted);
  }

  /* Hidden filter state — keep the dense grid from collapsing weirdly:
     hidden items leave their slot empty; grid-auto-flow: dense reflows. */
  .wall-mode .wall-tile[hidden] { display: none; }

  /* Tablet */
  @media (max-width: 1024px) {
    .wall-mode .wall-grid { --cols: 8; padding: 20px 20px 80px; }
  }
  /* Mobile: collapse to 4 cols, normalize tile sizes so everything fits */
  @media (max-width: 640px) {
    .wall-mode .wall-grid { --cols: 4; padding: 16px 14px 64px; gap: 6px; grid-auto-rows: 60px; }
    .wall-mode .s-2x1,
    .wall-mode .s-2x2,
    .wall-mode .s-2x3 { grid-column: span 2; grid-row: span 2; }
    .wall-mode .s-3x2,
    .wall-mode .s-3x3,
    .wall-mode .s-4x2 { grid-column: span 4; grid-row: span 3; }
    .wall-mode .wall-topbar { padding: 14px 16px; }
    /* On touch devices the hover label never shows — pin it visible */
    .wall-mode .wall-img .wall-label { opacity: 1; background: linear-gradient(transparent, rgba(0,0,0,.7)); }
  }

  /* === Card text + tag cleanup ===
     The default .feed-item-tag is a gold pill that competes with
     the imagery and shouts on every card. Strip the bubble — keep
     just an uppercase category label as small uppercase text in
     the corner. Also strengthen the image-overlay gradient and
     brighten + shadow the title text so it stays readable on
     bright photos. */
  .wall-mode .feed-item-tag {
    background: none !important;
    color: inherit !important;
    padding: 0 !important;
    border-radius: 0 !important;
    font-weight: 700 !important;
    opacity: 0.85;
  }

  /* Image tiles: stronger gradient + brighter title with text-shadow
     so it survives against high-key photos (sky, snow, neon). */
  .wall-mode .wall-img .wall-label {
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.55) 45%, transparent 100%) !important;
    color: #fff !important;
    padding: 14px 12px 10px !important;
    gap: 4px !important;
  }
  .wall-mode .wall-img .wall-label .feed-item-title {
    color: #fff !important;
    font-weight: 600 !important;
    font-size: 13px !important;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }
  .wall-mode .wall-img .wall-label .feed-item-tag,
  .wall-mode .wall-img .wall-label .feed-item-date {
    color: rgba(255, 255, 255, 0.85) !important;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
  }

  /* Text tiles (no image): label uses theme colours already, just
     keep the tag stripped of its pill background and ensure the
     title is plenty contrasted with the cream / sage / rose / dark
     panel backgrounds (which the legacy CSS already handles). */
  .wall-mode .wall-text .feed-item-tag {
    opacity: 0.7;
  }

  /* === Tag rail alignment ===
     The pills have 4px 8px padding, so the text of the "all" pill
     sits 8px inset from the rail's left edge. The brand text
     ("interests") has no such inset. Shift the rail left by the
     pill's horizontal padding so the first pill's TEXT aligns with
     the brand text (and the tile grid edges align too). */
  .wall-mode .wall-rail {
    margin-left: -8px;
  }

  /* === Text-tile layout polish ===
     Rework the entire text-tile vertical rhythm:
       - body flex-column, anchored to TOP (not center) so title
         doesn't float and cards read predictably
       - title font-size clamps to the tile width so big tiles get
         a larger headline and small ones don't overflow
       - meta row stays compact, single-line where possible
       - SOURCE text is hidden when a "visit" link is present —
         the link itself shows the URL, so showing it twice was
         the main source of the duplicated/cluttered look
       - link sits inline at the bottom, no wrap, no border that
         wraps onto multiple lines */
  .wall-mode .wall-text {
    align-items: stretch !important;
    padding: 14px !important;
  }
  .wall-mode .wall-text .wall-text-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
    width: 100%;
    height: 100%;
    justify-content: flex-start;
  }
  .wall-mode .wall-text .feed-item-title {
    margin: 0 !important;
    font-size: clamp(13px, 2.4cqi + 10px, 22px) !important;
    line-height: 1.18 !important;
    font-weight: 600 !important;
    overflow-wrap: anywhere;
  }
  .wall-mode .wall-text .feed-item-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 4px 6px;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
    margin-top: 2px;
  }
  /* Hide the source span entirely when a visit-link follows it
     (the link text already shows the URL). Use :has() to scope. */
  .wall-mode .wall-text .feed-item-body:has(.feed-item-link) .feed-item-source {
    display: none !important;
  }
  /* If no visit link, source still shows with a leading bullet
     that wraps WITH the source text (no orphan dots). */
  .wall-mode .wall-text .feed-item-source::before {
    content: none !important;
  }
  .wall-mode .wall-text .feed-item-source:not(:empty)::before {
    content: "· ";
    opacity: 0.5;
    margin-right: 2px;
  }
  .wall-mode .wall-text .feed-item-source:empty {
    display: none;
  }

  /* "visit raycast.com →" link: stays on one row, ellipsis if the
     URL is long, sits just below the meta row. Container queries
     scale the link size with the tile so it doesn't dominate. */
  .wall-mode .wall-text {
    container-type: inline-size;
  }
  .wall-mode .wall-text .feed-item-link {
    margin-top: auto !important;
    padding-top: 8px;
    font-size: 11px !important;
    letter-spacing: 0.02em;
    text-transform: none;
    border-bottom: none !important;
    text-decoration: underline;
    text-underline-offset: 3px;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: inline-block !important;
    transition: opacity 0.2s ease;
  }
  .wall-mode .wall-text .feed-item-link:hover { opacity: 0.7; }

  /* On very small/short tiles the link still needs to be readable
     — drop it to 10px if the tile is narrower than 200px. */
  @container (max-width: 200px) {
    .wall-mode .wall-text .feed-item-link {
      font-size: 10px !important;
    }
    .wall-mode .wall-text .feed-item-title {
      font-size: clamp(12px, 2cqi + 9px, 16px) !important;
    }
  }
</style>

<script is:inline type="application/json" id="jg-cool-shit-data" set:html={coolShitJson} />

<script>
  import '../scripts/cool-shit.ts';
</script>
</Base>
