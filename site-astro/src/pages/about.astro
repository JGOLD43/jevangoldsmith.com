---
// Ported from _src/content/about/body.html via scripts/port-page.mjs.
// SEO mirrors tests/seo-fixture.json. JSON-LD lands in Phase 8.
import Base from '../layouts/Base.astro';
---
<Base
  title="About Jevan Goldsmith"
  description="A short introduction to Jevan Goldsmith, the archive he is building, and the themes behind his work."
  canonical="https://jevangoldsmith.com/about.html"
  pageType="AboutPage"
>
<main class="about-content">
        <div class="about-layout">
            <div class="about-col-images left">
                <img src="images/generated/profile/profile-720.jpg" class="img-tall" alt="" aria-hidden="true" loading="lazy" decoding="async" srcset="images/generated/profile/profile-360.jpg 360w, images/generated/profile/profile-520.jpg 520w, images/generated/profile/profile-720.jpg 720w" sizes="160px">
                <img src="images/generated/content/zen-nature-720.jpg" class="img-square" alt="" aria-hidden="true" loading="lazy" decoding="async" srcset="images/generated/content/zen-nature-320.jpg 320w, images/generated/content/zen-nature-480.jpg 480w, images/generated/content/zen-nature-720.jpg 720w" sizes="160px">
                <img src="images/generated/profile/profile-720.jpg" class="img-wide" alt="" aria-hidden="true" loading="lazy" decoding="async" srcset="images/generated/profile/profile-360.jpg 360w, images/generated/profile/profile-520.jpg 520w, images/generated/profile/profile-720.jpg 720w" sizes="160px">
            </div>
            <div class="about-sections">
                <section class="about-section">
                    <p class="section-eyebrow">The Story</p>
                    <h1 class="section-title">How I Got Here</h1>
                    <p class="section-text">After completing my degree in finance, I discovered that my interests extended far beyond spreadsheets and balance sheets. I became fascinated by how technology is reshaping industries, how great companies build lasting cultures, and how ideas can be communicated effectively through writing.</p>
                    <p class="section-text">Currently, I spend my time exploring the intersection of finance, real estate development, and technology. My approach is simple: stay curious, think critically, and share openly.</p>
                </section>
            </div>
            <div class="about-col-images right">
                <img src="images/generated/content/zen-nature-720.jpg" class="img-square" alt="" aria-hidden="true" loading="lazy" decoding="async" srcset="images/generated/content/zen-nature-320.jpg 320w, images/generated/content/zen-nature-480.jpg 480w, images/generated/content/zen-nature-720.jpg 720w" sizes="160px">
                <img src="images/generated/logo/logo-nav-352.png" class="img-square" alt="" aria-hidden="true" loading="lazy" decoding="async" srcset="images/generated/logo/logo-nav-88.png 88w, images/generated/logo/logo-nav-176.png 176w, images/generated/logo/logo-nav-264.png 264w, images/generated/logo/logo-nav-352.png 352w" sizes="160px" width="88" height="80">
                <img src="images/generated/content/zen-nature-720.jpg" class="img-tall" alt="" aria-hidden="true" loading="lazy" decoding="async" srcset="images/generated/content/zen-nature-320.jpg 320w, images/generated/content/zen-nature-480.jpg 480w, images/generated/content/zen-nature-720.jpg 720w" sizes="160px">
            </div>
        </div>
</main>
</Base>
