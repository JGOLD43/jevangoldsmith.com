---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import AdventureMap from '../components/AdventureMap.astro';

const adventures = (await getCollection('adventures')).sort((a, b) =>
  String(b.data.startDate ?? '').localeCompare(String(a.data.startDate ?? ''))
);

function shortDate(start?: string | null, _end?: string | null): string {
  if (!start) return '';
  const d = new Date(start);
  if (Number.isNaN(d.getTime())) return start;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---
<Base
  title="Adventures, Travel Notes & Places Worth Remembering | Jevan Goldsmith"
  description="Travel notes, maps, photos, and reflections from places Jevan Goldsmith has explored."
  canonical="https://jevangoldsmith.com/adventures.html"
  bodyClass="nav-compact"
>
  <main>
    <div class="adventures-page-split">
      <aside class="adventures-sidebar">
        <div class="adventures-sidebar-header">
          <h1>Adventures</h1>
          <span class="adventures-count">{adventures.length} trips</span>
        </div>
        <div class="adventures-compact-list" id="adventures-container">
          {adventures.map((a) => (
            <a class="adventure-compact-card" href={`/adventure-${a.id}.html`} data-adventure-id={a.id}>
              {a.data.heroImage && (
                <img
                  src={a.data.heroImage}
                  alt={a.data.title}
                  class="adventure-compact-image"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="adventure-compact-info">
                {a.data.location && (
                  <div class="adventure-compact-location">{a.data.location}</div>
                )}
                <h3 class="adventure-compact-title">{a.data.title}</h3>
                <div class="adventure-compact-meta">
                  {shortDate(a.data.startDate, a.data.endDate)}
                  {a.data.duration && ` · ${a.data.duration}`}
                </div>
              </div>
            </a>
          ))}
        </div>
      </aside>
      <div class="adventures-map-panel">
        <AdventureMap adventures={adventures} />
      </div>
    </div>
  </main>
</Base>
