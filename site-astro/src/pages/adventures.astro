---
import { getCollection } from 'astro:content';
import remoteAssets from '../../../data/remote-assets.generated.json';
import Base from '../layouts/Base.astro';

interface RemoteAssetEntry {
  widths?: number[];
  formats?: Record<string, Record<string, string>>;
}

interface CarouselAdventure {
  id: string;
  title: string;
  year: string;
  place: string;
  image: string;
}

// Mirrors scripts/legacy-build/build/html-normalize.js remoteAssetFor:
// resolve a remote URL to its localized generated raster at the requested
// width (or the next-larger available width).
function remoteAssetFor(url: string | undefined, preferredWidth = 800, format = 'jpg'): string {
  if (!url || !/^https?:\/\//i.test(url)) return url ?? '';
  const map = remoteAssets as Record<string, RemoteAssetEntry>;
  let entry = map[url.replace(/&amp;/g, '&')];
  if (!entry) return url;
  const widths = (entry.widths ?? Object.keys(entry.formats ?? {}).map(Number)).sort((a, b) => a - b);
  const width = widths.find((w) => w >= preferredWidth) ?? widths[widths.length - 1];
  return entry.formats?.[String(width)]?.[format] ?? entry.formats?.[String(width)]?.jpg ?? url;
}

const adventures = (await getCollection('adventures')).sort((a: any, b: any) =>
  String(b.data.startDate ?? '').localeCompare(String(a.data.startDate ?? ''))
);

function shortDateRange(start?: string | null, end?: string | null): string {
  if (!start) return '';
  const s = new Date(start);
  if (Number.isNaN(s.getTime())) return start;
  const sLabel = s.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  if (!end) return sLabel;
  const e = new Date(end);
  if (Number.isNaN(e.getTime())) return sLabel;
  const eLabel = e.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  return sLabel === eLabel ? sLabel : `${s.toLocaleDateString('en-US', { month: 'short' })} - ${eLabel}`;
}

const canonical = 'https://jevangoldsmith.com/adventures.html';
const carouselAdventures: CarouselAdventure[] = adventures.map((adventure: any) => ({
  id: adventure.id,
  title: adventure.data.title,
  year: adventure.data.startDate ? String(adventure.data.startDate).slice(0, 4) : '',
  place: adventure.data.location || '',
  image: remoteAssetFor(adventure.data.heroImage, 240)
}));
---
<Base
  title="Adventures, Travel Notes &amp; Places Worth Remembering"
  description="Travel notes, maps, photos, and reflections from places Jevan Goldsmith has explored."
  canonical={canonical}
  pageType="CollectionPage"
  noFooter
>
  {/* Map fast-path: kick off Leaflet JS/CSS + ESRI TLS handshake during
      HTML parse. The z=2 tile grid is warmed AFTER window.load via
      requestIdleCallback in adventures.ts — keeps the critical path
      free of 32 cross-origin image fetches that would compete with LCP. */}
  <Fragment slot="head">
    <link rel="preload" as="script" href="/vendor/leaflet/leaflet.js" />
    <link rel="preload" as="style" href="/vendor/leaflet/leaflet.css" />
    <link rel="preconnect" href="https://server.arcgisonline.com" crossorigin />
    {adventures[0]?.data.heroImage && (
      <link rel="preload" as="image" fetchpriority="high" href={remoteAssetFor(adventures[0].data.heroImage, 240)} />
    )}
    {/* Strip the SSR'd .map-view class on desktop before first paint so the
        side-by-side list/map layout renders without flicker. Mobile keeps
        it → lands directly on the map. */}
    <script is:inline>
      (function () {
        if (window.matchMedia('(min-width: 769px)').matches) {
          document.documentElement.classList.add('adv-desktop');
        }
        try {
          var p = new URLSearchParams(window.location.search);
          if (p.get('focus') === 'now') {
            document.documentElement.classList.add('adv-focus-now-pending');
            // Compute the same satellite tile URL /now used for its
            // thumb, so the overlay shows the IDENTICAL image. The
            // browser then has a same-named, same-source img on both
            // pages and morphs them into each other — no fade gap.
            var lat = parseFloat(p.get('lat') || '');
            var lng = parseFloat(p.get('lng') || '');
            if (isFinite(lat) && isFinite(lng)) {
              var z = 10;
              var x = Math.floor((lng + 180) / 360 * Math.pow(2, z));
              var y = Math.floor((1 - Math.log(Math.tan(lat * Math.PI / 180) + 1 / Math.cos(lat * Math.PI / 180)) / Math.PI) / 2 * Math.pow(2, z));
              var url = 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/' + z + '/' + y + '/' + x;
              document.documentElement.setAttribute('data-now-overlay-src', url);
            }
          }
        } catch (e) { /* noop */ }
      })();
      // Apply the overlay src as soon as the img element exists.
      document.addEventListener('DOMContentLoaded', function () {
        var src = document.documentElement.getAttribute('data-now-overlay-src');
        if (!src) return;
        var img = document.getElementById('now-thumb-overlay');
        if (img) {
          img.src = src;
          img.classList.add('show');
        }
      });
    </script>
    <style is:inline set:html={`
      html.adv-focus-now-pending #world-map { opacity: 0; }
      .now-thumb-overlay {
        display: none;
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 50;
        pointer-events: none;
        view-transition-name: now-thumb-image;
      }
      .now-thumb-overlay.show { display: block; }
      .now-thumb-overlay.fading-out {
        transition: opacity 100ms cubic-bezier(.22, 1, .36, 1);
        opacity: 0;
      }
    `} />
  </Fragment>
  <main>
    {/* Phase H: SSR with `sidebar-collapsed` matching the JS default
        (localStorage 'adventures-sidebar-collapsed' is unset on first
        visit → JS would add this class anyway). Without it, the filters
        bar renders visible for ~50ms before JS hides it, causing a
        ~120px layout shift that drove CLS to 0.20+. */}
    {/* SSR with .map-view active so mobile lands directly on the map with
        no flash of list-then-map. A tiny inline script below strips it on
        desktop before paint so the side-by-side layout is preserved. */}
    <div
      class="adventures-page-split sidebar-collapsed map-view"
      data-now-lat="-19.5765"
      data-now-lng="147.4035"
      data-now-place="Ayr, QLD"
      data-now-date="May 12, 2026"
    >
      <div class="adventures-mobile-toggle">
        <button class="mobile-view-btn" data-view="list" data-action="switchMobileView" data-action-args="list">
          <svg class="ico-stroke" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-listView"/></svg>
          List
        </button>
        <button class="mobile-view-btn active" data-view="map" data-action="switchMobileView" data-action-args="map">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon>
            <line x1="8" y1="2" x2="8" y2="18"></line>
            <line x1="16" y1="6" x2="16" y2="22"></line>
          </svg>
          Map
        </button>
      </div>

      <aside class="adventures-sidebar">
        <div class="adventures-sidebar-header">
          <h1>Trips</h1>
          <span class="adventures-count"><span id="adventure-count">{adventures.length}</span> trips</span>
          <button type="button" class="adventures-sidebar-toggle" id="adventures-sidebar-toggle" aria-label="Collapse sidebar" aria-expanded="true">
            <svg class="ico-stroke" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-chevronLeft"/></svg>
          </button>
        </div>

        <div class="adventures-filters">
          <button class="filter-pill active" data-region="all" data-action="resetFilters" data-action-this="true">All</button>
          <button class="filter-pill" data-region="europe" data-action="toggleFilter" data-action-args="" data-action-this="true">Europe <span id="count-europe"></span></button>
          <button class="filter-pill" data-region="asia" data-action="toggleFilter" data-action-args="" data-action-this="true">Asia <span id="count-asia"></span></button>
          <button class="filter-pill" data-region="australia" data-action="toggleFilter" data-action-args="" data-action-this="true">Australia <span id="count-australia"></span></button>
          <button class="filter-pill" data-region="americas" data-action="toggleFilter" data-action-args="" data-action-this="true">Americas <span id="count-americas"></span></button>
        </div>

        <div class="adventures-compact-list" id="adventures-container">
          {adventures.map((a: any, i: number) => (
            <div class="adventure-compact-card" id={`card-${a.id}`} data-adventure-id={a.id}>
              {a.data.heroImage && (
                <img
                  src={remoteAssetFor(a.data.heroImage, 240)}
                  alt={a.data.title}
                  class="adventure-compact-image"
                  width="80"
                  height="80"
                  loading="eager"
                  decoding="async"
                  fetchpriority={i === 0 ? 'high' : undefined}
                />
              )}
              <div class="adventure-compact-info">
                {a.data.location && (
                  <div class="adventure-compact-location">{a.data.location}</div>
                )}
                <h3 class="adventure-compact-title">{a.data.title}</h3>
                <div class="adventure-compact-meta">
                  {shortDateRange(a.data.startDate, a.data.endDate)}
                  {a.data.duration && ` · ${a.data.duration}`}
                </div>
              </div>
            </div>
          ))}
        </div>
      </aside>

      <div class="adventures-map-panel">
        <div class="adventures-main-map" id="world-map" aria-label="Interactive adventures map"></div>
        {/* Same-image overlay used for the seamless morph from /now's
            map thumb. The img shares view-transition-name with the
            thumb, so the browser morphs the small thumb into this large
            overlay. Then adventures.ts crossfades the overlay out once
            Leaflet's tiles have painted underneath. SSR-hidden by
            default; the inline script in head adds .show when ?focus=now
            is in the URL so the overlay only appears for that path. */}
        <img id="now-thumb-overlay" class="now-thumb-overlay" alt="" aria-hidden="true" decoding="async" />

        {/* Horizontal trip carousel along the bottom of the map (mobile + tablet).
            Populated by adventures.ts after the data loads; tap an item to fly
            the map to that trip. The wrap has a drag handle so the user can
            swipe / tap to hide the strip and free up map space. */}
        <div class="adventures-map-carousel-wrap" id="adventures-map-carousel-wrap" hidden>
          <button type="button" class="adv-carousel-handle" id="adv-carousel-handle" aria-label="Hide trips" aria-controls="adventures-map-carousel" aria-expanded="true">
            <svg class="adv-carousel-handle-chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="adventures-map-carousel" id="adventures-map-carousel" aria-label="Trips">
            {carouselAdventures.map((adventure) => (
              <button type="button" class="adv-carousel-card" data-adventure-id={adventure.id}>
                {adventure.image
                  ? <img class="adv-carousel-img" src={adventure.image} alt={adventure.title} loading="lazy" decoding="async" />
                  : <span class="adv-carousel-img adv-carousel-img-fallback" aria-hidden="true"></span>}
                <span class="adv-carousel-meta">
                  <span class="adv-carousel-place">{adventure.place}</span>
                  {adventure.year && <span class="adv-carousel-year">{adventure.year}</span>}
                </span>
              </button>
            ))}
          </div>
        </div>

        <div class="adventure-detail-overlay" id="adventure-detail-overlay">
          <button class="detail-close-btn" data-action="closeAdventureDetail">&times;</button>
          <div class="adventure-detail-content" id="adventure-detail-content">
            <img id="adventure-detail-hero" src="" alt="" class="adventure-detail-hero" loading="lazy" decoding="async">
            <div class="adventure-detail-body">
              <div class="adventure-location" id="adventure-detail-location"></div>
              <h2 class="adventure-title" id="adventure-detail-title"></h2>
              <div class="adventure-meta">
                <span id="adventure-detail-date"></span>
                <span id="adventure-detail-duration"></span>
              </div>
              <p class="adventure-description" id="adventure-detail-description"></p>
              <button type="button" class="view-full-story-btn" data-action="scrollToStory">Read Full Story</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="adventure-story-inline" id="adventure-story-inline" hidden>
      <div class="adventure-story-inner" id="adventure-story-inner">
        <button type="button" class="adventure-story-close" data-action="closeInlineStory" aria-label="Close story">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="20" height="20"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="adventure-story-hero">
          <img id="adventure-story-hero-image" src="" alt="" loading="lazy" decoding="async">
          <div class="adventure-story-hero-overlay">
            <div class="adventure-story-location" id="adventure-story-location"></div>
            <h2 class="adventure-story-title" id="adventure-story-title"></h2>
            <p class="adventure-story-subtitle" id="adventure-story-subtitle"></p>
          </div>
        </div>
        <div class="adventure-story-body">
          <div class="adventure-story-meta">
            <span id="adventure-story-date"></span>
            <span id="adventure-story-duration"></span>
          </div>
          <div class="adventure-story-content" id="adventure-story-content"></div>
          <div class="adventure-story-highlights" id="adventure-story-highlights" hidden>
            <h3>Highlights</h3>
            <ul id="adventure-story-highlights-list"></ul>
          </div>
          <div class="adventure-story-gallery" id="adventure-story-gallery" hidden>
            <h3>Gallery</h3>
            <div class="adventure-story-gallery-grid" id="adventure-story-gallery-grid"></div>
          </div>
          <template id="adventure-highlight-template">
            <li></li>
          </template>
          <template id="adventure-gallery-item-template">
            <figure class="adventure-story-gallery-item" data-action="open-adventure-lightbox" data-adventure-id="" data-index="">
              <img src="" alt="" loading="lazy" decoding="async">
              <figcaption hidden></figcaption>
            </figure>
          </template>
        </div>
      </div>
    </section>
  </main>

  <div id="lightbox" class="lightbox">
    <span class="lightbox-close" data-action="closeLightbox">&times;</span>
    <span class="lightbox-prev" data-action="prevImage">&#10094;</span>
    <img id="lightbox-image" src="" alt="" decoding="async">
    <span class="lightbox-next" data-action="nextImage">&#10095;</span>
    <div class="lightbox-caption" id="lightbox-caption"></div>
    <div class="lightbox-counter" id="lightbox-counter"></div>
  </div>
</Base>

<style is:inline>
  /* The site-wide body has padding-bottom:72px to clear the mobile
     book-detail toolbar. The adventures page has its OWN fixed
     bottom toggle (54px, already accounted for in the page-split
     height calc), so the extra 72px padding here just adds dead
     space below the map that shows as a cream strip when the user
     exits a trip and lands back on the map. Zero it out on this
     page only. */
  body:has(.adventures-page-split) {
    padding-bottom: 0 !important;
  }

  /* Mobile bottom toggle band matches the navbar (pure white in light
     mode) rather than the page's creamy --background, so the chrome
     reads as a single continuous frame around the map. Dark mode
     keeps a neutral dark surface for the same reason.
     Top edge mirrors the navbar's bottom border (1px solid black in
     light mode) — clean hairline, no heavy box-shadow smudge. */
  @media (max-width: 968px) {
    .adventures-mobile-toggle {
      background: #fff !important;
      border-top: 1px solid #000 !important;
      box-shadow: none !important;
    }
    [data-theme="dark"] .adventures-mobile-toggle {
      background: #1a1a1a !important;
      border-top: 1px solid #2a2a2a !important;
    }
  }

  /* Trip list: no box by default; only reveal background/border on hover or
     when the trip is the active selection. */
  .adventure-compact-card {
    background: transparent !important;
    border: 1px solid transparent !important;
    box-shadow: none !important;
    transition: background-color .15s ease, border-color .15s ease, box-shadow .15s ease;
  }
  .adventure-compact-card:hover {
    background: var(--card-bg) !important;
    border-color: var(--border-color) !important;
  }
  .adventure-compact-card.active {
    background: rgba(201, 168, 108, 0.10) !important;
    border-color: var(--secondary-color) !important;
    box-shadow: 0 2px 12px rgba(201, 168, 108, 0.18) !important;
  }
  [data-theme="dark"] .adventure-compact-card:hover {
    background: rgba(255, 255, 255, 0.04) !important;
    border-color: rgba(255, 255, 255, 0.10) !important;
  }
  [data-theme="dark"] .adventure-compact-card.active {
    background: rgba(212, 184, 122, 0.10) !important;
    border-color: var(--secondary-color) !important;
  }
  /* Square thumbnail; height is sized from the info column's natural
     three-line text height by JS below (CSS can't express that
     without inflating the row with the image's intrinsic size). */
  .adventures-compact-list .adventure-compact-card { align-items: center; }
  .adventures-compact-list .adventure-compact-image {
    aspect-ratio: 1 / 1 !important;
    object-fit: cover;
    flex: 0 0 auto;
  }
  /* Adventure detail hero — straight corners and force the overlay
     text white in both themes (the base h2 rule applies primary-color
     which made the title nearly invisible on light mode). */
  .adventure-story-hero { border-radius: 0 !important; }
  .adventure-story-hero img { border-radius: 0 !important; }
  .adventure-story-hero-overlay {
    background: linear-gradient(rgba(0,0,0,0), rgba(0,0,0,0.78)) !important;
  }
  .adventure-story-hero-overlay .adventure-story-location,
  .adventure-story-hero-overlay .adventure-story-title,
  .adventure-story-hero-overlay .adventure-story-subtitle {
    color: #ffffff !important;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.55);
  }
</style>
<script is:inline>
  (() => {
    const fit = () => {
      document.querySelectorAll('.adventures-compact-list .adventure-compact-card').forEach((card) => {
        const info = card.querySelector('.adventure-compact-info');
        const img = card.querySelector('.adventure-compact-image');
        if (!info || !img) return;
        const h = Math.round(info.getBoundingClientRect().height);
        if (h > 0) {
          img.style.width = h + 'px';
          img.style.height = h + 'px';
        }
      });
    };
    const onReady = () => {
      fit();
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(fit);
      window.addEventListener('resize', fit, { passive: true });
      // Sidebar visibility flips after first click on mobile-view buttons;
      // re-fit when the layout container's classes change.
      const split = document.querySelector('.adventures-page-split');
      if (split) new MutationObserver(fit).observe(split, { attributes: true, attributeFilter: ['class'] });
    };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', onReady);
    else onReady();
  })();
</script>

<script>
  // adventures.ts imports action-dispatcher transitively; the map
  // module is dynamically imported on first map view.
  import '../scripts/adventures.ts';
</script>
