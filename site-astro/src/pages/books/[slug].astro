---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { bookCoverUrl } from '../../lib/book-card';
import { renderCommentary, renderNotes } from '../../lib/notes-render';
import { bookSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((entry: any) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: any };
const b = entry.data;
const canonical = `https://jevangoldsmith.com/books/${entry.id}.html`;

const cover = bookCoverUrl(b, 'large');
const ratingValue = Number(b.rating ?? 0);
const reReads = Number(b.reReads ?? 0);
const isUnread = b.read === false;
const hasRating = !isUnread && ratingValue > 0;
const stars = hasRating ? '★'.repeat(ratingValue) + '☆'.repeat(5 - ratingValue) : '';
const timesRead = reReads + 1;

const notesHtml = renderNotes(b.notes);
const commentaryHtml = renderCommentary(b.commentary);

const schema = bookSchema({
  canonical,
  title: b.title,
  author: b.author,
  isbn: b.isbn,
  year: b.year,
  image: cover && cover.startsWith('http') ? cover : undefined,
  rating: hasRating ? ratingValue : null,
  review: b.review
});
---
<Base
  title={`${b.title} by ${b.author} - Books - Jevan Goldsmith`}
  description={b.review || b.shortDescription || `Notes on ${b.title} by ${b.author}.`}
  canonical={canonical}
  bodyClass="nav-compact"
  pageType="Article"
  ogImage={cover && cover.startsWith('http') ? cover : undefined}
  breadcrumbs={[
    { name: 'Home', url: 'https://jevangoldsmith.com/' },
    { name: 'Books', url: 'https://jevangoldsmith.com/books.html' },
    { name: b.title, url: canonical }
  ]}
  extraSchema={[schema]}
>
  <Fragment slot="head">
    {cover && <link rel="preload" as="image" fetchpriority="high" href={cover} />}
    {/* Detects the flight-arrival flag set by the books grid before
        navigation. Runs synchronously before first paint so the page
        starts hidden and the dark backdrop persists from books → here,
        making the navigation read as a continuous crossfade rather
        than a hard page swap. */}
    <script is:inline set:html={`(function(){try{var f=sessionStorage.getItem('book-flight-arrival');if(!f)return;sessionStorage.removeItem('book-flight-arrival');document.documentElement.classList.add('is-flight-arrival');}catch(e){}})();`} />
    <style is:inline set:html={`
      /* Showcase hero — large, centered cover at the top, content
         below. Matches the visual weight of The Shelf's zoomed product
         so the book-card flight has a dramatic destination to land at. */
      .detail-page--book .detail-hero {
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
        flex-wrap: nowrap;
      }
      .detail-page--book .detail-hero-cover {
        flex: none;
        max-width: none;
        width: min(72vw, 340px);
        height: auto;
        margin: 0 auto;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
        background: #1a1a1a;
      }
      /* Match the grid card's framing exactly so the flying clone and
         the hero render the same image with the same crop/letterbox.
         Grid uses object-fit: contain with letterboxed sides; force the
         hero to do the same so the final frame of the flight matches
         the hero pixel-for-pixel. */
      .detail-page--book .detail-hero-cover img {
        width: 100%;
        height: auto;
        display: block;
        aspect-ratio: auto !important;
        object-fit: contain !important;
        background: #1a1a1a;
      }
      .detail-page--book .detail-hero-body {
        flex: none;
        max-width: 640px;
        margin: 0 auto;
      }
      @media (max-width: 640px) {
        .detail-page--book .detail-hero-cover {
          width: min(78vw, 320px);
        }
      }

      /* On flight arrival, hide only the page content (main + footer)
         and the back link — the navbar matches the one on /books so it
         stays put (no fade flicker). The hero cover stays at opacity 1
         so the flying clone reads as continuous with it. */
      html.is-flight-arrival body > main,
      html.is-flight-arrival body > footer { opacity: 0; }
      html.is-flight-arrival body > main .detail-hero-cover,
      html.is-flight-arrival body > main .detail-hero-cover * { opacity: 1; }
      html.is-flight-arrival.is-flight-revealed body > main,
      html.is-flight-arrival.is-flight-revealed body > footer {
        opacity: 1;
        transition: opacity .28s cubic-bezier(.22, 1, .36, 1);
      }
      @media (prefers-reduced-motion: reduce) {
        html.is-flight-arrival body > main,
        html.is-flight-arrival body > footer { opacity: 1; }
      }
    `} />
  </Fragment>
  <main class="detail-page detail-page--book">
    <a href="/books.html" class="detail-back">← Back to Books</a>

    <header class="detail-hero detail-hero--book">
      {cover && (
        <div class="detail-hero-cover">
          <img src={cover} alt={`${b.title} cover`} loading="eager" decoding="async" fetchpriority="high" width="240" height="360" style={`view-transition-name: book-cover-${entry.id}`} />
        </div>
      )}
      <div class="detail-hero-body">
        <p class="detail-kicker">
          {isUnread && <span class="detail-status-badge status-planned">To Read</span>}
          {b.category && <span class="detail-category-pill">{b.category}</span>}
          {b.year && <span class="detail-year-pill">{b.year}</span>}
        </p>
        <h1 class="detail-title">{b.title}</h1>
        <p class="detail-meta-line">by {b.author}</p>
        {hasRating && (
          <p class="detail-rating">
            <span class="detail-rating-stars">{stars}</span>
            <span class="detail-rating-num">{ratingValue}/5</span>
          </p>
        )}
        {timesRead > 1 && <p class="detail-meta-line">Read {timesRead}× total</p>}
        {b.shortDescription && <p class="detail-lead">{b.shortDescription}</p>}
      </div>
    </header>

    {b.review && (
      <section class="detail-section">
        <h2 class="detail-h2">Quick Review</h2>
        <p class="detail-pullquote">{b.review}</p>
      </section>
    )}

    <section class="detail-section detail-section--notes">
      <h2 class="detail-h2">My Notes</h2>
      {notesHtml ? (
        <div class="detail-notes-body" set:html={notesHtml} />
      ) : (
        <p class="detail-notes-empty">
          Quotes that stuck, ideas to apply, what I'd push back on. Add a <code>notes</code> field to this book in
          <code>data/books.json</code>.
        </p>
      )}
    </section>

    {commentaryHtml && (
      <section class="detail-section">
        <h2 class="detail-h2">Re-Read Log</h2>
        <div set:html={commentaryHtml} />
      </section>
    )}
  </main>

  <script is:inline set:html={`(function(){if(!document.documentElement.classList.contains('is-flight-arrival'))return;requestAnimationFrame(function(){requestAnimationFrame(function(){document.documentElement.classList.add('is-flight-revealed');setTimeout(function(){document.documentElement.classList.remove('is-flight-arrival','is-flight-revealed');},420);});});})();`} />
</Base>
