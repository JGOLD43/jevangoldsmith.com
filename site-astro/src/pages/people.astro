---
import CollectionPage from '../components/CollectionPage.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { PEOPLE_SECTIONS } from '../lib/collection-sections';
import { renderPersonCardHtml } from '../lib/person-card';
import type { PeopleMerged } from '../content.config';

const canonical = 'https://jevangoldsmith.com/people.html';

// SSR all 98 cards from the build-time-merged collection.
// scripts/merge-people.js generates data/people.merged.generated.json
// before astro build. people.js no longer fetches books/movies/profiles —
// it reads the inline JSON below for modal interaction.
const peopleEntries = await getCollection('peopleMerged') as CollectionEntry<'peopleMerged'>[];
const peopleCardsHtml = peopleEntries
  .map((p, i) => renderPersonCardHtml(p.data, i))
  .join('');

// legacy fragments inlined directly into the page. The
// sidebar source filter + main body wrapper used to live as raw HTML
// imports under src/legacy/collections/people/.
const sidebarFiltersHtml = `<div class="people-source-filter sidebar-filter-section" aria-label="Filter people by source">
    <div class="filter-header">
        <span class="filter-label">Source</span>
    </div>
    <div class="people-source-filter-list">
        <button class="people-source-filter-btn active" type="button" data-action="filterPeopleSource" data-action-args="all" data-action-eventobj="true">
            <span class="people-source-label">All</span>
            <span class="people-source-count" id="people-source-count-all">0</span>
        </button>
        <button class="people-source-filter-btn" type="button" data-action="filterPeopleSource" data-action-args="nonfiction" data-action-eventobj="true">
            <span class="people-source-label">Non-fiction</span>
            <span class="people-source-count" id="people-source-count-nonfiction">0</span>
        </button>
        <button class="people-source-filter-btn" type="button" data-action="filterPeopleSource" data-action-args="fiction" data-action-eventobj="true">
            <span class="people-source-label">Fiction</span>
            <span class="people-source-count" id="people-source-count-fiction">0</span>
        </button>
    </div>
</div>`;

const populatedMainBody = `<div id="people-container">
    <div class="people-grid" id="people-grid">${peopleCardsHtml}</div>
</div>`;

// Inline merged data for the modal so people.js avoids a runtime fetch.
const mergedPeople = peopleEntries.map((p) => p.data) satisfies PeopleMerged[];
const peopleMergedJson = JSON.stringify(mergedPeople);

const config = ({
  layout: { id: 'people-layout', className: 'people-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'people-sidebar',
    className: 'people-sidebar collection-sidebar collapsed',
    collapseAction: 'togglePeopleSidebar',
    search: {
      inputId: 'people-search',
      inputClass: 'collection-search-input',
      placeholder: 'Search people...',
      clearButtonId: 'people-search-clear-btn',
      clearAction: 'clearPeopleSearch',
      searchAction: 'filterPeople',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-bubble'
    },
    extraHtml: sidebarFiltersHtml,
    sections: PEOPLE_SECTIONS
  },
  main: {
    className: 'people-main collection-main',
    title: 'People of History',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="people-philosophy.html" class="header-subtitle-link">My People Philosophy</a><span class="read-first-note">← read this first</span></div>',
    counterId: 'people-count',
    counterLabel: 'People Listed',
    bodyHtml: populatedMainBody
  }
});
---
<CollectionPage
  config={config}
  title="People of History"
  description="A people-of-history archive of thinkers, builders, writers, and creators who shaped Jevan Goldsmith's taste and judgment."
  canonical={canonical}
/>

<style is:inline>
  /* content-visibility lets the browser skip layout + paint for cards
     that are off-screen until they scroll into view. contain-intrinsic
     size reserves the slot so scrollbar + scroll position stay stable
     (no CLS). person-card is a fixed-aspect grid item so a static size
     is safe. Browsers without support (older Safari) just paint
     normally. Zero behavior change for users. */
  .person-card {
    content-visibility: auto;
    contain-intrinsic-size: 320px 380px;
  }
</style>

<script is:inline type="application/json" id="people-merged-data" set:html={peopleMergedJson} />

<script>
  import '../scripts/collection-ui.ts';
  import '../scripts/collection-runtime.ts';
  import '../scripts/action-dispatcher.ts';
  import '../scripts/people.ts';
</script>
