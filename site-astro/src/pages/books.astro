---
import CollectionPage from '../components/CollectionPage.astro';
import { getCollection } from 'astro:content';
import { tasteListOptions, BOOK_SECTIONS } from '../lib/collection-sections';
import { renderBookCardHtml } from '../lib/book-card';
import { escapeAttr } from '../lib/html-escape';
import remoteAssets from '../../../data/remote-assets.generated.json';
import { CATEGORY_MAP } from '../lib/book-categories';

const canonical = 'https://jevangoldsmith.com/books.html';

// server-render every book card at build time. books.js detects
// an already-populated container and skips the initial wipe-and-render.
const books = await getCollection('books');
// First 16 cards sit above the fold across desktop + tablet — flag them
// eager + fetchpriority="high" so their covers paint without waiting for
// the lazy-loading IntersectionObserver. Cards 16+ stay lazy.
const bookCardsHtml = books
  .map((b: any, i: number) => renderBookCardHtml(b.data, i < 16))
  .join('');

// Resolve a remote OpenLibrary cover URL to a local pre-generated jpg.
// remote-assets.generated.json holds the mapping built by
// scripts/optimize-assets.js (cover widths: 160, 240, 360, 480). Local
// paths paint instantly from /images/generated/remote/. Without this the
// browser still hits openlibrary on first visit and covers visibly load
// in below the fold even on a fast connection.
type RemoteEntry = { source: string; widths: number[]; formats: Record<string, { avif?: string; jpg?: string }> };
const REMOTE = remoteAssets as Record<string, RemoteEntry>;
function localizeCover(url: string, size: 'medium' | 'large'): string {
  // optimize-assets indexes ISBN covers under the -L URL only (it
  // generates 160/240/360/480 widths from that single source). Normalize
  // an -M lookup back to its -L key so the manifest hit lands.
  const lookupKey = url.replace(/-M\.jpg(\?.*)?$/, '-L.jpg');
  const entry = REMOTE[lookupKey] || REMOTE[url];
  if (!entry) return url;
  const targetWidth = size === 'medium' ? 240 : 480;
  const jpg = entry.formats[String(targetWidth)]?.jpg;
  return jpg ? `/${jpg}` : url;
}

function coverUrl(book: any, size: 'medium' | 'large' = 'large'): string {
  if (book.coverImage) return localizeCover(book.coverImage, size);
  const isbn = String(book.isbn || '').replace(/[^0-9X]/gi, '');
  if (!isbn) return '';
  const remote = `https://covers.openlibrary.org/b/isbn/${isbn}-L.jpg`;
  return localizeCover(remote, size);
}

const booksByCategoryKey: Record<string, any[]> = {};
for (const entry of books) {
  const data = entry.data as any;
  const key = CATEGORY_MAP[data.category];
  if (!key) continue;
  (booksByCategoryKey[key] ||= []).push(data);
}

// Inject per-category list HTML + counts into the cloned section configs.
const SIDEBAR_SECTIONS = BOOK_SECTIONS.map((section: any) => {
  // The "All Books" section has no panelId — just stamp the total count
  // so the badge ships with 122 instead of the placeholder 0.
  if (!section.panelId) return { ...section, count: String(books.length) };
  const key = section.panelId.replace(/^category-/, '');
  const list = booksByCategoryKey[key] || [];
  const innerHtml = list.map((book) => `
                <a href="#" class="book-link" data-action="book-link" data-book-title="${escapeAttr(book.title)}">
                    <div>${escapeAttr(book.title)}</div>
                    <div class="book-link-author">${escapeAttr(book.author)}</div>
                </a>
              `).join('');
  return { ...section, count: String(list.length), panelInnerHtml: innerHtml };
});

// Carousel: most recent 20 books, doubled for the seamless scroll loop.
const recentBooks = books.slice(-20).reverse().map((b: any) => b.data);
const carouselBooks = [...recentBooks, ...recentBooks];
const carouselTrackInner = carouselBooks
  .map((book: any) => {
    const url = coverUrl(book, 'medium');
    // Skip books with no resolvable cover (no ISBN, no coverImage). An
    // empty src renders as a broken-image icon AND fires a fetch of the
    // current page URL — both visible and wasteful.
    if (!url) return '';
    return `<img class="carousel-book" src="${escapeAttr(url)}" alt="${escapeAttr(book.title)}" title="${escapeAttr(book.title)} by ${escapeAttr(book.author)}" decoding="async" data-action="carousel-book" data-isbn="${escapeAttr(book.isbn)}" data-remove-on-error="true">`;
  })
  .join('');

// legacy fragments inlined directly into the page.
const sidebarFiltersHtml = `<div class="sidebar-filter-section">
    <div class="filter-header">
        <div class="filter-label">Filter by Rating</div>
        <a href="#" class="show-all-link" data-action="clear-star-filter">Show All</a>
    </div>
    <div class="star-rating-filter">
        <div class="star-filter-container" id="star-filter-container">
            <span class="filter-star" data-star="1">★</span>
            <span class="filter-star" data-star="2">★</span>
            <span class="filter-star" data-star="3">★</span>
            <span class="filter-star" data-star="4">★</span>
            <span class="filter-star" data-star="5">★</span>
            <span class="filter-rating-text" id="filter-rating-text"></span>
        </div>
    </div>
</div>

<div class="sidebar-filter-section">
    <div class="filter-header">
        <div class="filter-label">Filter by Times Read</div>
    </div>
    <div class="timesread-filter">
        <div class="timesread-filter-container">
            <span class="filter-timesread-icon">📖</span>
            <div class="timesread-slider-wrapper">
                <input type="range" min="0" max="10" value="0" class="timesread-slider" id="timesread-slider">
                <div class="timesread-ticks" id="timesread-ticks">
                    <span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span><span class="tick"></span>
                </div>
            </div>
            <span class="filter-timesread-text" id="filter-timesread-text"></span>
        </div>
    </div>
</div>`;

const headerCarouselHtml = `<div class="recent-books-carousel">
    <span class="carousel-label">Recently Added</span>
    <div class="carousel-track" id="carousel-track" style="animation-duration:${recentBooks.length * 3}s">${carouselTrackInner}</div>
</div>`;

const headerViewToggleHtml = `<div class="view-toggle main-view-toggle">
    <button class="view-toggle-btn active" id="list-view-btn-main" data-action="set-view-mode" data-mode="list" title="List view">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line>
        </svg>
    </button>
    <button class="view-toggle-btn" id="grid-view-btn-main" data-action="set-view-mode" data-mode="grid" title="Grid view">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>
        </svg>
    </button>
</div>`;

const populatedMainBody = `<div id="books-container" class="books-grid">${bookCardsHtml}</div>
<div class="category-grid-view" id="category-grid-view" style="display: none;">
    <header class="main-header grid-view-header">
        <div class="header-content">
            <h1>Bookshelf</h1>
            <div class="philosophy-link-wrapper">
                <a href="reading-philosophy.html" class="header-subtitle-link">My Reading Philosophy</a>
                <span class="read-first-note">← read this first</span>
            </div>
        </div>
        <div class="view-toggle grid-view-toggle">
            <button class="view-toggle-btn" id="list-view-btn-grid" data-action="set-view-mode" data-mode="list" title="List view">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="8" y1="6" x2="21" y2="6"></line>
                    <line x1="8" y1="12" x2="21" y2="12"></line>
                    <line x1="8" y1="18" x2="21" y2="18"></line>
                    <line x1="3" y1="6" x2="3.01" y2="6"></line>
                    <line x1="3" y1="12" x2="3.01" y2="12"></line>
                    <line x1="3" y1="18" x2="3.01" y2="18"></line>
                </svg>
            </button>
            <button class="view-toggle-btn active" id="grid-view-btn-grid" data-action="set-view-mode" data-mode="grid" title="Grid view">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                </svg>
            </button>
        </div>
    </header>
    <div class="category-grid" id="category-grid"></div>
</div>`;

const afterMainHtml = `<section class="seo-related-section" data-seo-related>
    <p class="seo-related-eyebrow">Related thread</p>
    <h2>Keep exploring this idea</h2>
    <p class="seo-related-intro">A few adjacent notes and pages that connect this topic to the wider archive. These links are chosen from shared topics and intent, so each page leads toward a more specific skill, resource, essay, or collection instead of sending you back through generic navigation. Follow the thread that best matches what you are trying to learn next.</p>
    <div class="seo-related-grid">
        <a class="seo-related-card" href="reading-philosophy.html"><span>How I Read: A Practical Reading Philosophy</span><p>Notes on reading for judgment, taste, decision-making, and a better personal operating system.</p></a>
        <a class="seo-related-card" href="field-notes.html" data-analytics="cta" data-cta-id="newsletter" data-cta-location="books"><span>Field Notes Newsletter | Useful Ideas, Books, Tools &amp; Experiments</span><p>One useful idea, object, book, question, or experiment each week from Jevan Goldsmith&#39;s living archive.</p></a>
        <a class="seo-related-card" href="index.html"><span>Jevan Goldsmith - Finance, Real Estate Development, Writing &amp; Tech</span><p>Personal website of Jevan Goldsmith: real estate development, writing, technology, books, adventures, and useful ideas.</p></a>
        <a class="seo-related-card" href="free-resources.html" data-analytics="cta" data-cta-id="free-resources" data-cta-location="books"><span>Useful Resources for Thinking, Building &amp; Learning</span><p>Templates, guides, and practical tools from Jevan Goldsmith for reflection, better thinking, reading, and useful work.</p></a>
    </div>
</section>

<div id="book-modal" class="modal">
    <div class="modal-content">
        <span class="modal-close" data-action="close-book-modal">&times;</span>
        <div class="modal-body">
            <div class="modal-header">
                <img id="modal-book-cover" src="" alt="" class="modal-cover" decoding="async">
                <div class="modal-info">
                    <h2 id="modal-book-title"></h2>
                    <p id="modal-book-author" class="modal-author"></p>
                    <div id="modal-book-rating" class="modal-rating"></div>
                </div>
            </div>
            <div class="modal-review">
                <h3>My Review</h3>
                <p id="modal-book-review" class="review-text"></p>
            </div>
        </div>
    </div>
</div>`;

const config = ({
  layout: { id: 'books-layout', className: 'books-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'books-sidebar',
    className: 'books-sidebar collection-sidebar collection-sidebar--taste collapsed',
    collapseAction: 'toggle-sidebar',
    listAction: 'toggle-list-dropdown',
    currentListName: 'Books',
    listOptions: tasteListOptions('books', 'books'),
    search: {
      inputId: 'book-search',
      inputClass: 'book-search-input collection-search-input',
      placeholder: 'Search books...',
      clearButtonId: 'search-clear-btn',
      clearAction: 'clear-search',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    extraHtml: sidebarFiltersHtml,
    footerText: 'Books with a badge have my full review',
    sections: SIDEBAR_SECTIONS
  },
  main: {
    className: 'books-main collection-main',
    titleTag: 'h2',
    title: 'Bookshelf',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="reading-philosophy.html" class="header-subtitle-link">My Reading Philosophy</a><span class="read-first-note">← read this first</span></div>',
    headerExtraHtml: headerCarouselHtml,
    counterExtraHtml: headerViewToggleHtml,
    counterGroupClass: 'header-right',
    counterId: 'book-count',
    counterLabelId: 'counter-label',
    counterLabel: 'Total Books Read',
    bodyHtml: populatedMainBody
  },
  afterMainHtml: afterMainHtml
});
---
<CollectionPage
  config={config}
  title="Books I Recommend &amp; Notes From My Reading System"
  description="A living bookshelf of books Jevan Goldsmith recommends, rereads, and uses to shape decisions, taste, work, and personal systems."
  canonical={canonical}
/>

<script>
  // (slice 11) + Phase 7 (slice 4): books + infra deps as native modules.
  import '../scripts/grid-zoom.ts';
  import '../scripts/collection-ui.ts';
  import '../scripts/collection-runtime.ts';
  import '../scripts/collection-helpers.ts';
  import '../scripts/data-fetch.ts';
  import '../scripts/sanitize.ts';
  import '../scripts/books.ts';
</script>
