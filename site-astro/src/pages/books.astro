---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BookCard from '../components/BookCard.astro';
import BookCategoryModal from '../components/BookCategoryModal.astro';
import BookModal from '../components/BookModal.astro';
import CollectionPage from '../components/CollectionPage.astro';
import ContentVisibilityStyle from '../components/ContentVisibilityStyle.astro';
import InlineJson from '../components/InlineJson.astro';
import SidebarRatingSliderFilters from '../components/SidebarRatingSliderFilters.astro';
import type { Book } from '../content.config';
import { bookCoverUrl } from '../lib/book-card';
import { CATEGORY_MAP } from '../lib/book-categories';
import { BOOK_SECTIONS, tasteListOptions } from '../lib/collection-sections';
import { categoryDisplayNames } from '../scripts/books-state';
import { slugify } from '../lib/slug';
import booksRuntimeData from '../../../data/books.generated.json';

// Books data is fetched at runtime from /data/books.generated.json.
// books.ts adopts SSR'd cards in place and only re-renders for filter changes.

const canonical = 'https://jevangoldsmith.com/books.html';

const books = await getCollection('books') as CollectionEntry<'books'>[];

const booksByCategoryKey: Record<string, Book[]> = {};
const booksByCategoryName: Record<string, Book[]> = {};
for (const entry of books) {
  const data = entry.data;
  (booksByCategoryName[data.category] ||= []).push(data);
  const key = CATEGORY_MAP[data.category];
  if (!key) continue;
  (booksByCategoryKey[key] ||= []).push(data);
}

// LCP candidate: the first book card's cover image. Preload it during
// HTML parse so the LCP paint isn't waiting on the cover-grid img to be
// discovered by the parser further down the document.
const lcpCoverUrl = books[0] ? bookCoverUrl(books[0].data) : '';

// Sidebar lists hydrate at runtime from the books.generated.json fetch.
// SSR ships only the per-section counts so the badges paint correctly.
const SIDEBAR_SECTIONS = BOOK_SECTIONS.map((section) => {
  if (!section.panelId) return { ...section, count: String(books.length) };
  const key = section.panelId.replace(/^category-/, '');
  const list = booksByCategoryKey[key] || [];
  return { ...section, count: String(list.length) };
});

// Carousel: most recent 20 books that have a resolvable cover, SSR'd
// twice so the seamless-scroll loop is complete on first paint. (books.ts
// used to clone the 20 nodes to 40 at runtime, but that doubled the
// track's width post-paint and contributed to CLS. The runtime detects
// ≥40 children and skips the clone.)
const recentBooks = books
  .filter((b) => bookCoverUrl(b.data, 'medium'))
  .slice(-20)
  .reverse()
  .map((b) => b.data);
const carouselBooks = [...recentBooks, ...recentBooks].map((book) => {
  const slug = book.isbn || slugify(`${book.title}-${book.author}`);
  return {
    href: slug ? `/books/${slug}.html` : '#',
    title: `${book.title} by ${book.author}`,
    image: bookCoverUrl(book, 'medium'),
    alt: book.title,
    isbn: book.isbn
  };
});
const categoryGridCards = Object.entries(booksByCategoryName)
  .sort((a, b) => b[1].length - a[1].length)
  .map(([category, categoryBooks]) => ({
    category,
    displayName: categoryDisplayNames[category] || category,
    count: categoryBooks.length,
    covers: categoryBooks.slice(0, 8).map((book) => ({
      src: bookCoverUrl(book, 'medium'),
      alt: book.title
    })),
    emptySlots: Math.max(0, 8 - Math.min(8, categoryBooks.length))
  }));

const config = ({
  layout: { id: 'books-layout', className: 'books-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'books-sidebar',
    className: 'books-sidebar collection-sidebar collection-sidebar--taste collapsed',
    collapseAction: 'toggle-sidebar',
    listAction: 'toggle-list-dropdown',
    currentListName: 'Books',
    listOptions: tasteListOptions('books'),
    search: {
      inputId: 'book-search',
      inputClass: 'book-search-input collection-search-input',
      placeholder: 'Search books...',
      clearButtonId: 'search-clear-btn',
      clearAction: 'clear-search',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    footerText: 'Books with a badge have my full review',
    sections: SIDEBAR_SECTIONS
  },
  main: {
    className: 'books-main collection-main',
    titleTag: 'h2',
    title: 'Bookshelf',
    mobileGridLabel: 'Gallery',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="reading-philosophy.html" class="header-subtitle-link">My Reading Philosophy</a><span class="read-first-note">read this first</span></div>',
    counterGroupClass: 'header-right',
    counterId: 'book-count',
    counterLabelId: 'counter-label',
    counterLabel: 'Total Books Read'
  }
});
---
<CollectionPage
  config={config}
  title="Books I Recommend &amp; Notes From My Reading System"
  description="A living bookshelf of books Jevan Goldsmith recommends, rereads, and uses to shape decisions, taste, work, and personal systems."
  canonical={canonical}
>
  {lcpCoverUrl && (
    <Fragment slot="head">
      <link rel="preload" as="image" fetchpriority="high" href={lcpCoverUrl} />
    </Fragment>
  )}
  <Fragment slot="sidebar-extra">
    <SidebarRatingSliderFilters clearAction="clear-star-filter" sliderLabel="Filter by Times Read" sliderIcon="📖" sliderId="timesread" />
  </Fragment>
  <Fragment slot="header-extra">
    <div class="recent-books-carousel">
      <span class="carousel-label">Recently Added</span>
      <div class="carousel-track" id="carousel-track" style={`animation-duration:${recentBooks.length * 3}s`}>
        {carouselBooks.map((book) => (
          <a class="carousel-book-link" href={book.href} title={book.title}>
            <img class="carousel-book" src={book.image} alt={book.alt} decoding="async" data-isbn={book.isbn} data-remove-on-error="true" />
          </a>
        ))}
      </div>
    </div>
  </Fragment>
  <Fragment slot="counter-extra">
    <button class="view-toggle-single" id="view-toggle-main" data-action="toggle-view-mode" data-current-mode="list" aria-label="Switch to grid view" title="Switch to grid view">
      <svg class="ico-stroke view-icon view-icon-list" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-listView"></use></svg>
      <svg class="ico-stroke view-icon view-icon-grid" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-gridView"></use></svg>
    </button>
  </Fragment>
  <div id="books-container" class="books-grid">
    {books.map((b, i) => <BookCard book={b.data} eager={i < 6} />)}
  </div>
  <div class="category-grid-view" id="category-grid-view" style="display: none;">
    {/* No internal header — .books-main's .main-header is already
        visible above and contains the toggle button. A second
        Bookshelf header here would just duplicate it. */}
    <div class="category-grid" id="category-grid">
      {categoryGridCards.map((category) => (
        <div class="category-card" data-action="open-category-modal" data-category={category.category}>
          <div class="category-card-books">
            {category.covers.map((cover) => (
              cover.src ? <img src={cover.src} alt={cover.alt} loading="lazy" decoding="async" data-remove-on-error="true" /> : <div class="empty-slot"></div>
            ))}
            {Array.from({ length: category.emptySlots }).map(() => <div class="empty-slot"></div>)}
          </div>
          <div class="category-card-info">
            <span class="category-card-name">{category.displayName}</span>
            <span class="category-card-count">{category.count}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
  <Fragment slot="after-main">
    <BookModal />
    <BookCategoryModal />
  </Fragment>
</CollectionPage>

<InlineJson id="jg-books-data" data={booksRuntimeData} />

<ContentVisibilityStyle selector=".book-card" intrinsicSize="220px 360px" />

<style is:inline>
  /* While a book cover is flying to the detail page, fade out the page
     content (main + sidebar) — but NOT the navbar, which renders the
     same on both pages. Fading the navbar would flicker between two
     identical navbars. The flight clone is appended to <body> with
     z-index 99999, so it stays visible above the fade. */
  body.is-book-launching .books-main,
  body.is-book-launching .books-sidebar {
    opacity: 0;
    transition: opacity .32s cubic-bezier(.22, 1, .36, 1);
    pointer-events: none;
  }

  /* Showcase hero — mirrored from books/[slug].astro so SPA-injected
     detail mains render with the same layout/aspect as a direct visit. */
  .detail-page--book .detail-hero {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    flex-wrap: nowrap;
  }
  .detail-page--book .detail-hero-cover {
    flex: none;
    max-width: none;
    width: min(72vw, 340px);
    height: auto;
    margin: 0 auto;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
    background: #1a1a1a;
  }
  .detail-page--book .detail-hero-cover img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: auto !important;
    object-fit: contain !important;
    background: #1a1a1a;
  }
  .detail-page--book .detail-hero-body {
    flex: none;
    max-width: 640px;
    margin: 0 auto;
  }
  @media (max-width: 640px) {
    .detail-page--book .detail-hero-cover {
      width: min(78vw, 320px);
    }
  }

  /* SPA-injected detail main: hide content from initial paint, then
     fade in around the still-flying cover clone (and the eventual
     hero hand-off). All children of the new main, plus the hero
     internals, start at opacity 0. Reveal class fades them in. */
  main.detail-page--book.is-spa-arrival > * {
    opacity: 0;
  }
  main.detail-page--book.is-spa-arrival .detail-hero-cover,
  main.detail-page--book.is-spa-arrival .detail-hero-cover * {
    opacity: 0;
  }
  /* Belt-and-suspenders against a late-flight flash: even at opacity 0
     the wrapper's dark background (#1a1a1a) and heavy box-shadow have
     been reported to render as a black-rectangle flash a frame before
     handoff in some browsers. Null both during arrival so there's
     literally nothing to paint until the cover-revealed swap. */
  main.detail-page--book.is-spa-arrival .detail-hero-cover {
    background: transparent !important;
    box-shadow: none !important;
  }
  /* Restore the wrapper's bg + shadow instantly (no transition) at
     is-spa-cover-revealed, exactly when the clone's box-shadow is
     cleared to 'none' in handoff(). The simultaneous swap (clone
     shadow off, wrapper shadow on) keeps the net visible shadow
     constant — no progressive brighten, no perceptible flicker. */
  main.detail-page--book.is-spa-arrival.is-spa-cover-revealed .detail-hero-cover {
    background: #1a1a1a !important;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55) !important;
  }
  main.detail-page--book.is-spa-arrival.is-spa-revealed > * {
    opacity: 1;
    /* Was .28s — that ran past the flight's 320ms handoff, so the
       wrapper's shadow inside .detail-hero kept brightening for ~90ms
       after the cover landed and read as a delayed shadow flicker.
       .14s ensures the reveal is fully complete before handoff. */
    transition: opacity .14s cubic-bezier(.22, 1, .36, 1);
  }
  main.detail-page--book.is-spa-arrival.is-spa-cover-revealed .detail-hero-cover,
  main.detail-page--book.is-spa-arrival.is-spa-cover-revealed .detail-hero-cover * {
    opacity: 1;
    /* No transition — the clone is removed in the same frame the hero
       is revealed. A non-zero duration here creates a momentary fade
       between clone-removed and hero-fully-opaque that reads as a flash. */
    transition: none;
  }
  @media (prefers-reduced-motion: reduce) {
    main.detail-page--book.is-spa-arrival > *,
    main.detail-page--book.is-spa-arrival .detail-hero-cover,
    main.detail-page--book.is-spa-arrival .detail-hero-cover * { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    body.is-book-launching .books-main,
    body.is-book-launching .books-sidebar {
      transition: none;
    }
  }

  /* --- Sidebar layout polish (filter sections + active state) --- */
  .books-sidebar .sidebar-search { margin: 14px 0 6px; }

  .books-sidebar .sidebar-filter-section { padding: 10px 24px 14px; }
  .books-sidebar .sidebar-filter-section + .sidebar-filter-section { padding-top: 4px; }

  .books-sidebar .filter-header {
    margin-bottom: 8px;
    align-items: baseline;
  }
  .books-sidebar .filter-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8a8a;
  }
  .books-sidebar .show-all-link {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: #888;
    transition: color .15s ease;
  }
  .books-sidebar .show-all-link:hover { color: var(--secondary-color); }

  .books-sidebar .star-rating-filter { padding: 2px 0; }
  .books-sidebar .star-filter-container { gap: 4px; }
  .books-sidebar .filter-star {
    font-size: 1.05rem;
    line-height: 1;
    transition: color .15s ease, transform .15s ease;
  }
  .books-sidebar .filter-star:hover { transform: scale(1.1); }

  /* Soft divider above the category list (replaces the harsh white line) */
  .books-sidebar .sidebar-list-container,
  .books-sidebar .sidebar-categories {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 6px;
  }

  /* --- Dark-mode-friendly selected category --- */
  [data-theme="dark"] .books-sidebar .sidebar-category {
    border-left: 3px solid transparent;
  }
  [data-theme="dark"] .books-sidebar .sidebar-category.active {
    background: rgba(212, 184, 122, 0.12);
    color: var(--secondary-color);
    border-left-color: var(--secondary-color);
    font-weight: 600;
  }
  [data-theme="dark"] .books-sidebar .sidebar-category.active .category-name {
    color: var(--secondary-color);
  }
  [data-theme="dark"] .books-sidebar .sidebar-category.active .category-icon svg {
    stroke: var(--secondary-color);
  }
  [data-theme="dark"] .books-sidebar .sidebar-category.active .category-count {
    background: rgba(212, 184, 122, 0.18);
    color: var(--secondary-color);
  }
  [data-theme="dark"] .books-sidebar .sidebar-category:hover:not(.active) {
    background: rgba(255, 255, 255, 0.04);
  }
</style>

<script>
  import '../scripts/books.ts';
</script>
