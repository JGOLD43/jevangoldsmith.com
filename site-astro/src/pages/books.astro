---
import CollectionPage from '../components/CollectionPage.astro';
import { getCollection } from 'astro:content';
import {
  tasteListOptions,
  BOOK_SECTIONS
} from '../lib/collection-chrome';
import { renderBookCardHtml } from '../lib/book-card';
import sidebarFiltersRaw from '../legacy/collections/books/sidebar-filters.html?raw';
import mainBodyRaw from '../legacy/collections/books/main-body.html?raw';
import headerCarouselRaw from '../legacy/collections/books/header-carousel.html?raw';
import headerViewToggleRaw from '../legacy/collections/books/header-view-toggle.html?raw';
import afterMainRaw from '../legacy/collections/books/after-main.html?raw';

const canonical = 'https://jevangoldsmith.com/books.html';

// Phase B: server-render every book card at build time. books.js detects
// an already-populated container and skips the initial wipe-and-render.
const books = await getCollection('books');
const bookCardsHtml = books.map((b: any) => renderBookCardHtml(b.data)).join('');
const populatedMainBody = mainBodyRaw
  .trim()
  .replace(
    '<div id="books-container" class="books-grid"></div>',
    `<div id="books-container" class="books-grid">${bookCardsHtml}</div>`
  );

const config = ({
  layout: { id: 'books-layout', className: 'books-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'books-sidebar',
    className: 'books-sidebar collection-sidebar collection-sidebar--taste collapsed',
    collapseAction: 'toggle-sidebar',
    listAction: 'toggle-list-dropdown',
    currentListName: 'Books',
    listOptions: tasteListOptions('books', 'books'),
    search: {
      inputId: 'book-search',
      inputClass: 'book-search-input collection-search-input',
      placeholder: 'Search books...',
      clearButtonId: 'search-clear-btn',
      clearAction: 'clear-search',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    extraHtml: sidebarFiltersRaw.trim(),
    footerText: 'Books with a badge have my full review',
    sections: BOOK_SECTIONS
  },
  main: {
    className: 'books-main collection-main',
    titleTag: 'h2',
    title: 'Bookshelf',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="reading-philosophy.html" class="header-subtitle-link">My Reading Philosophy</a><span class="read-first-note">← read this first</span></div>',
    headerExtraHtml: headerCarouselRaw.trim(),
    counterExtraHtml: headerViewToggleRaw.trim(),
    counterGroupClass: 'header-right',
    counterId: 'book-count',
    counterLabelId: 'counter-label',
    counterLabel: 'Total Books Read',
    bodyHtml: populatedMainBody
  },
  afterMainHtml: afterMainRaw.trim()
});
---
<CollectionPage
  config={config}
  title="Books I Recommend &amp; Notes From My Reading System"
  description="A living bookshelf of books Jevan Goldsmith recommends, rereads, and uses to shape decisions, taste, work, and personal systems."
  canonical={canonical}
/>

<script>
  // Phase 5 (slice 11) + Phase 7 (slice 4): books + infra deps as native modules.
  import '../scripts/grid-zoom.js';
  import '../scripts/collection-ui.js';
  import '../scripts/collection-runtime.js';
  import '../scripts/collection-helpers.js';
  import '../scripts/data-fetch.js';
  import '../scripts/sanitize.js';
  import '../scripts/books.js';
</script>
