---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact Jevan Goldsmith"
  description="Contact Jevan Goldsmith about projects, ideas, useful resources, the newsletter, or collaboration."
  canonical="https://jevangoldsmith.com/contact.html"
  pageType="ContactPage"
>
<main class="container">
<header class="page-header">
  <h1>Contact</h1>
  <p>Send a note, ask a question, or just say hi.</p>
</header>
<div class="content-section">
<form class="contact-form" action="https://formsubmit.co/hello@jevangoldsmith.com" method="POST" data-contact-form data-endpoint="https://formsubmit.co/ajax/hello@jevangoldsmith.com">
    <input type="hidden" name="_subject" value="Contact form: new message">
    <input type="hidden" name="_template" value="table">
    <input type="text" name="_honey" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true">
    <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" autocomplete="name" required>
    </div>
    <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" autocomplete="email" required>
    </div>
    <div class="form-group">
        <label for="subject">Subject</label>
        <input type="text" id="subject" name="subject" required>
    </div>
    <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" required></textarea>
    </div>
    <button type="submit">Send Message</button>
</form>
<div style="margin-top: 3rem; text-align: center;">
    <h3>Or reach out directly:</h3>
    <div class="social-links" style="margin-top: 2rem;">
        <a href="https://x.com/JevanGoldsmith" target="_blank" aria-label="X (Twitter)">
            <svg class="ico-fill ico-24" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-x"/></svg>
        </a>
        <a href="https://letterboxd.com/contentwatch" target="_blank" aria-label="Letterboxd">
            <svg class="ico-fill ico-24" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-letterboxd"/></svg>
        </a>
        <a href="https://linkedin.com/in/jevan-goldsmith-7b885a185" target="_blank" aria-label="LinkedIn">
            <svg class="ico-fill ico-24" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-linkedin"/></svg>
        </a>
    </div>
    <p style="margin-top: 2rem; color: var(--text-light);">
        <em>I typically respond within 24–48 hours.</em>
    </p>
</div>
</div>
</main>
<script>
  import '../scripts/contact-form.ts';
</script>
<style is:inline>
  .contact-form-status { margin-top: 1rem; text-align: center; font-size: 0.95rem; }
  .contact-form-status[data-state="ok"] { color: var(--accent-color, #2e7d32); }
  .contact-form-status[data-state="error"] { color: #c0392b; }
</style>
</Base>
