---
// Legacy standalone trip page kept ONLY as a redirect to the polished
// in-page overlay on /adventures.html. Previously this route rendered
// a completely different layout from clicking the same trip on the
// /adventures list or map (different hero treatment, photo locations
// map, photo grid) — confusingly divergent for the same data. The
// homepage carousel and any internal link now points at
// /adventures.html?trip=<id>, which auto-opens the overlay via
// adventures.ts. External backlinks (search results, old social
// posts) still resolve here and get bounced.
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const adventures = await getCollection('adventures');
  return adventures.map((entry: any) => ({ params: { slug: entry.id }, props: { id: entry.id } }));
}

const { id } = Astro.props as { id: string };
const target = `/adventures.html?trip=${id}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting… | Jevan Goldsmith</title>
    <link rel="canonical" href={`https://jevangoldsmith.com${target}`} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex, follow" />
    <script set:html={`window.location.replace(${JSON.stringify(target)});`}></script>
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>…</p>
  </body>
</html>
