---
import essaysData from '../../public/data/essays.json';
import CollectionPage from '../components/CollectionPage.astro';
import InlineJson from '../components/InlineJson.astro';
import { ESSAY_LIST_OPTIONS, ESSAY_SECTIONS } from '../lib/collection-sections';
import { formatDate, formatDateShort } from '../lib/dates';

const canonical = 'https://jevangoldsmith.com/essays.html';

// SSR the first (most recent) published essay so the page reaches its
// final layout in one paint — eliminates the JS-driven CLS that shows
// up after hydration. essays.ts adopts the SSR'd DOM and only re-renders
// for filter / search / nav-button changes.
const sortedEssays = (essaysData.essays as Array<Record<string, unknown>>)
  .filter((essay) => essay.status === 'published')
  .sort((a, b) => new Date(b.date as string).getTime() - new Date(a.date as string).getTime());
const firstEssay = sortedEssays[0];
const total = sortedEssays.length;
const nextTitle = sortedEssays[1]?.title as string | undefined;

function essayExcerpt(html: string, max = 160): string {
  const text = String(html || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  if (text.length <= max) return text;
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

function categorySlugOf(cat: string): string {
  return String(cat || '').toLowerCase().replace(/[^a-z0-9]+/g, '-');
}

function subtitleFor(essay: Record<string, unknown>): string {
  const sub = String(essay.subtitle || '').trim();
  if (sub) return sub;
  return essayExcerpt((essay.content as string) || '', 100);
}

// Group by category for a minimal list layout (one section per category).
const byCategory = new Map<string, Array<Record<string, unknown>>>();
for (const essay of sortedEssays) {
  const cat = (essay.category as string) || 'Other';
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(essay);
}

// Use canonical category order from section-presets, with any extras after.
const CATEGORY_ORDER = ['Philosophy', 'Management', 'Technology', 'Personal', 'Finance', 'Writing'];
const orderedCategories = [
  ...CATEGORY_ORDER.filter((c) => byCategory.has(c)),
  ...Array.from(byCategory.keys()).filter((c) => !CATEGORY_ORDER.includes(c))
];
const essaySections = ESSAY_SECTIONS.map((section) => {
  if (!section.panelId) return { ...section, count: String(sortedEssays.length) };
  const categoryKey = section.panelId.replace(/^category-/, '');
  const list = byCategory.get(CATEGORY_ORDER.find((cat) => categorySlugOf(cat) === categoryKey) || '') || [];
  return {
    ...section,
    count: String(list.length),
    panelLinks: list.map((essay) => ({
      href: `#${essay.id as string}`,
      className: 'essay-link',
      label: essay.title as string || '',
      meta: formatDateShort(essay.date as string),
      attrs: {
        'data-action': 'scrollToEssay',
        'data-action-args': encodeURIComponent(essay.id as string),
        'data-action-eventobj': 'true'
      }
    }))
  };
});

// Build the data the cards-view and category-grid-view consume up
// front — Astro/JSX parses the actual template easier when each map
// callback returns plain values, no inline type casts.
const categoryCards = orderedCategories.map((cat) => {
  const slug = categorySlugOf(cat);
  const list = byCategory.get(cat) || [];
  const sample = list.slice(0, 4).map((e) => ({
    title: (e.title as string) || ''
  }));
  return {
    cat,
    slug,
    count: list.length,
    sample,
    emptySlots: Math.max(0, 4 - sample.length)
  };
});

// after-main.html (field-notes inline CTA + seo-related) is added by the
// post-build normalizer + Base layout, so we leave it out here.
const config = ({
  layout: { id: 'essays-layout', className: 'essays-layout collection-layout' },
  sidebar: {
    id: 'essays-sidebar',
    className: 'essays-sidebar collection-sidebar',
    collapseAction: 'toggleEssaysSidebar',
    listAction: 'toggleListDropdown',
    currentListName: 'Essays',
    listOptions: ESSAY_LIST_OPTIONS,
    search: {
      inputId: 'essay-search',
      inputClass: 'book-search-input collection-search-input',
      placeholder: 'Search essays...',
      clearButtonId: 'search-clear-btn',
      clearAction: 'clearEssaySearch',
      searchAction: 'searchEssays',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    sections: essaySections
  },
  main: {
    className: 'essays-main collection-main',
    titleTag: 'h2',
    title: 'Essays',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="writing-philosophy.html" class="header-subtitle-link">My Writing Philosophy</a><span class="read-first-note">read this first</span></div>',
    counterGroupClass: 'header-right',
    counterId: 'essay-count',
    counterLabel: 'Total Essays'
  }
});
---
<CollectionPage
  config={config}
  title="Essays on Thinking, Business, Culture &amp; Personal Systems"
  description="Longer essays from Jevan Goldsmith on attention, business, culture, decisions, money, meaning, and useful systems."
  canonical={canonical}
>
  <Fragment slot="counter-extra">
    <button class="view-toggle-single" id="essays-view-toggle" data-action="toggleEssayCardsView" data-current-mode="list" aria-label="Switch to category grid view" title="Switch to category grid view">
      <svg class="ico-stroke view-icon view-icon-list" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-listView"></use></svg>
      <svg class="ico-stroke view-icon view-icon-grid" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-gridView"></use></svg>
    </button>
  </Fragment>
  <button type="button" class="essay-back-to-list" data-action="setEssayView" data-action-args="cards" data-view="reader">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
    All essays
  </button>
  <div id="essays-container" class="content-section essays-view-reader" data-view="reader" hidden>
    {firstEssay && (
      <>
        <article class="article-full" id={firstEssay.id as string}>
          <div class="post-meta">
            <span class="post-date">{formatDate(firstEssay.date as string)}</span>
          </div>
          <h2>{firstEssay.title as string || ''}</h2>
          <p hidden={!firstEssay.subtitle}><em>{firstEssay.subtitle as string || ''}</em></p>
          <div data-essay-content set:html={(firstEssay.content as string) || ''}></div>
        </article>
        <div class="essay-nav">
          <button class="essay-nav-btn essay-nav-prev" disabled data-action="prevEssay">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            <span class="essay-nav-label">
              <span class="essay-nav-direction">Previous</span>
              <span class="essay-nav-title" data-essay-prev-title></span>
            </span>
          </button>
          <span class="essay-nav-counter">1 / {total}</span>
          <button class="essay-nav-btn essay-nav-next" disabled={total <= 1} data-action="nextEssay">
            <span class="essay-nav-label essay-nav-label-right">
              <span class="essay-nav-direction">Next</span>
              <span class="essay-nav-title" data-essay-next-title>{nextTitle || ''}</span>
            </span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </>
    )}
  </div>
  <template id="essay-empty-template">
    <p class="essay-runtime-message">No essays published yet.</p>
  </template>
  <template id="essay-render-error-template">
    <p class="essay-runtime-message">Unable to render essay.</p>
  </template>
  <template id="essay-load-error-template">
    <div class="essay-runtime-message essay-runtime-message--error">
      <p class="essay-runtime-title">Unable to load essays</p>
      <p>Please try refreshing the page.</p>
    </div>
  </template>
  <template id="essay-sidebar-link-template">
    <a href="#" class="essay-link" data-action="scrollToEssay" data-action-args="" data-action-eventobj="true">
      <div data-essay-link-title></div>
      <div class="essay-link-date" data-essay-link-date></div>
    </a>
  </template>
  <div id="essays-cards" class="essays-cards essays-view-cards" data-view="cards">
    {orderedCategories.map((cat) => {
      const slug = categorySlugOf(cat);
      const rows = (byCategory.get(cat) || []).map((e) => ({
        id: e.id as string,
        title: e.title as string || '',
        subtitle: subtitleFor(e)
      }));
      return (
        <section class="essay-section" data-category={slug}>
          <h3 class="essay-section-title">{cat}</h3>
          <ul class="essay-list">
            {rows.map((essay) => (
              <li class="essay-row" data-essay-id={essay.id} data-category={slug}>
                <a href={`#${essay.id}`} class="essay-row-link" data-action="openEssayFromCard" data-action-args={essay.id} data-action-eventobj="true">
                  <span class="essay-row-title">{essay.title}</span>
                  <span class="essay-row-subtitle">{essay.subtitle}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    })}
  </div>
  {/* Category-folder grid view — one card per category, click to filter
      the cards list down to that category. Toggled in by
      #essays-view-toggle. */}
  <div id="essays-category-grid-view" class="essays-category-grid-view" hidden>
    <div class="essays-category-grid">
      {categoryCards.map((card) => (
        <button class="essays-category-card" type="button" data-action="filterEssaysByCategory" data-action-args={card.slug}>
          <div class="essays-category-previews">
            {card.sample.map((s) => (
              <div class="essays-category-preview">
                <div class="essays-category-preview-title">{s.title}</div>
              </div>
            ))}
            {Array.from({ length: card.emptySlots }).map(() => <div class="essays-category-preview empty"></div>)}
          </div>
          <div class="essays-category-info">
            <span class="essays-category-name">{card.cat}</span>
            <span class="essays-category-count">{card.count}</span>
          </div>
        </button>
      ))}
    </div>
  </div>
  <section class="field-notes-inline-cta" data-field-notes-inline>
    <p class="archive-kicker">Newsletter</p>
    <h2>Want more notes like this?</h2>
    <p>Exclusive, newsletter-only content once a month: books, objects, questions, and experiments worth keeping. No spam, no nonsense.</p>
    <a href="/newsletter.html" class="btn-primary">Subscribe</a>
  </section>
</CollectionPage>

<InlineJson id="jg-essays-data" data={essaysData} />

<style is:inline>
  /* Smooth open transitions for essay reader (emilkowal.ski-style:
     fade + tiny rise instead of a hard hide/show swap). */
  .essays-view-reader,
  .essays-view-cards {
    transition: opacity 220ms cubic-bezier(.22, 1, .36, 1),
                transform 220ms cubic-bezier(.22, 1, .36, 1);
  }
  .essays-view-reader[hidden],
  .essays-view-cards[hidden] {
    display: block !important;
    visibility: hidden;
    pointer-events: none;
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
  }
  .essays-view-reader:not([hidden]),
  .essays-view-cards:not([hidden]) {
    opacity: 1;
    transform: none;
  }

  /* Category-folder grid view — one card per category, mirroring the
     books/movies folder view but with text previews instead of covers. */
  .essays-category-grid-view { padding: 1rem 0; }
  .essays-category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .essays-category-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-color);
    text-align: left;
    cursor: pointer;
    transition: background 0.18s ease, transform 0.18s ease, border-color 0.18s ease;
    font: inherit;
  }
  .essays-category-card:hover {
    background: rgba(0, 0, 0, 0.04);
    border-color: var(--text-light);
    transform: translateY(-2px);
  }
  [data-theme="dark"] .essays-category-card:hover {
    background: rgba(255, 255, 255, 0.06);
  }
  .essays-category-previews {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem;
  }
  .essays-category-preview {
    aspect-ratio: 1;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.04);
    padding: 0.5rem;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  [data-theme="dark"] .essays-category-preview {
    background: rgba(255, 255, 255, 0.04);
  }
  .essays-category-preview.empty { background: transparent; }
  .essays-category-preview-title {
    font-size: 0.7rem;
    line-height: 1.25;
    font-weight: 500;
    color: var(--text-color);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }
  .essays-category-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 0.25rem;
  }
  .essays-category-name {
    font-weight: 700;
    font-size: 1rem;
  }
  .essays-category-count {
    font-family: Chivo, sans-serif;
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    color: var(--text-light);
  }
</style>

<script>
  // Toggle button + category-filter handlers. Mounts after essays.ts
  // has already set up the runtime registry; we just wire two new
  // actions: toggleEssayCardsView (swap the cards/list view with the
  // category-folder grid view) and filterEssaysByCategory (click a
  // category card → show only that category in the cards view).
  document.addEventListener('click', (event) => {
    const target = event.target as Element | null;
    if (!target) return;

    const toggle = target.closest?.('[data-action="toggleEssayCardsView"]') as HTMLElement | null;
    if (toggle) {
      event.preventDefault();
      const cards = document.getElementById('essays-cards');
      const grid = document.getElementById('essays-category-grid-view');
      const reader = document.getElementById('essays-container');
      const main = document.querySelector('.essays-main') as HTMLElement | null;
      if (!cards || !grid) return;
      // If the reader is currently open, the toggle should first take the
      // user back to the cards/list view (matching the "All essays" back
      // link's job), then proceed with the grid/list toggle.
      if (reader && !reader.hidden) {
        reader.hidden = true;
        cards.hidden = false;
        if (main) main.setAttribute('data-view', 'cards');
      }
      const showingGrid = !grid.hidden;
      grid.hidden = showingGrid;
      cards.hidden = !showingGrid;
      // Always reset any prior per-section display:none from a filter
      // click so toggling back to the cards view shows ALL essays.
      cards.querySelectorAll<HTMLElement>('.essay-section').forEach((sec) => {
        sec.style.display = '';
      });
      const nextLabel = showingGrid ? 'Switch to category grid view' : 'Switch to list view';
      toggle.dataset.currentMode = showingGrid ? 'list' : 'grid';
      toggle.setAttribute('aria-label', nextLabel);
      toggle.setAttribute('title', nextLabel);
      // Reset scroll to the very top of the document. Doubled rAF
      // schedules the scroll AFTER layout has reflowed for the new view
      // — otherwise mobile Safari occasionally lands on a stale layout
      // and leaves the page scrolled mid-list, hiding the collection
      // header and the first row's title behind the fixed navbar.
      const hardScrollTop = () => {
        // Cover both scroll roots (some mobile browsers anchor to one
        // or the other depending on body/html overflow).
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
      };
      hardScrollTop();
      requestAnimationFrame(() => {
        hardScrollTop();
        requestAnimationFrame(hardScrollTop);
      });
      return;
    }

    const filterBtn = target.closest?.('[data-action="filterEssaysByCategory"]') as HTMLElement | null;
    if (filterBtn) {
      event.preventDefault();
      const slug = (filterBtn.getAttribute('data-action-args') || '').toLowerCase();
      const cards = document.getElementById('essays-cards');
      const grid = document.getElementById('essays-category-grid-view');
      if (!cards || !grid) return;
      // Show only the matching section.
      cards.querySelectorAll<HTMLElement>('.essay-section').forEach((sec) => {
        sec.style.display = sec.dataset.category === slug ? '' : 'none';
      });
      // Swap to cards view.
      grid.hidden = true;
      cards.hidden = false;
      const toggle = document.getElementById('essays-view-toggle');
      if (toggle) {
        toggle.dataset.currentMode = 'list';
        toggle.setAttribute('aria-label', 'Switch to category grid view');
      }
      // Scroll to the TOP of the document, not the cards container.
      // scrollIntoView put .essays-cards at viewport top — but the
      // .essays-main section above it (header + counter) was getting
      // pushed BEHIND the fixed navbar, cutting off the nav row and
      // the first essay row. Hard scroll to 0 with a triple-rAF so
      // the layout settles, then the natural document flow places
      // the navbar at top → header → cards beneath.
      const hardScrollTop = () => {
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
      };
      hardScrollTop();
      requestAnimationFrame(() => {
        hardScrollTop();
        requestAnimationFrame(hardScrollTop);
      });
    }
  });
</script>

<script>
  import '../scripts/essays.ts';
</script>

<style is:global>
  /* Index view — minimal grouped list, inspired by emilkowal.ski */
  .essay-runtime-message {
    text-align: center;
    color: var(--text-light);
    padding: 3rem;
  }
  .essay-runtime-message--error .essay-runtime-title {
    color: var(--accent-color);
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }
  .essays-cards {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 0.5rem 4rem;
    display: block;
  }
  .essay-section { margin-bottom: 3rem; }
  .essay-section:last-child { margin-bottom: 0; }
  .essay-section-title {
    font-family: Chivo, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-light);
    text-transform: none;
    letter-spacing: 0;
    margin: 0 0 0.5rem;
    padding: 0 0.75rem;
  }
  .essay-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .essay-row { background: transparent; }
  .essay-row-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
    transition: background .15s ease;
  }
  .essay-row-link:hover,
  .essay-row-link:focus-visible {
    background: rgba(0, 0, 0, 0.06);
    outline: none;
  }
  [data-theme="dark"] .essay-row-link:hover,
  [data-theme="dark"] .essay-row-link:focus-visible {
    background: rgba(255, 255, 255, 0.08);
  }
  .essay-row-title {
    font-family: Chivo, sans-serif;
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--primary-color);
    line-height: 1.35;
  }
  .essay-row-subtitle {
    font-size: 0.96rem;
    color: var(--text-light);
    line-height: 1.45;
  }

  /* "All essays" back link shown in reader view only */
  .essay-back-to-list {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 1rem;
    padding: 6px 10px 6px 0;
    background: transparent;
    border: 0;
    color: var(--text-light);
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    transition: color .15s ease;
  }
  .essay-back-to-list:hover,
  .essay-back-to-list:focus-visible {
    color: var(--primary-color);
    outline: none;
  }

  /* On mobile, widen the essays page to go edge-to-edge with the
     navbar chrome (logo on the left, hamburger on the right). The
     .essays-main wrapper's default 2rem padding was indenting the
     content well inside the logo edge — drop it to 1rem and zero
     out the per-card / per-row paddings so everything aligns. */
  @media (max-width: 768px) {
    .essays-main { padding: 1rem; }
    .essays-cards { padding: 0.5rem 0 3rem; max-width: none; }
    .essay-section-title { padding: 0; }
    /* Negative margin offsets the inner padding so the row text still
       aligns with the section title, but the hover pill extends outside
       the text edge — gives breathing room between text and box edge. */
    .essay-row-link { padding-left: 0.6rem; padding-right: 0.6rem; margin-left: -0.6rem; margin-right: -0.6rem; }
  }
  @media (max-width: 640px) {
    .essay-section { margin-bottom: 2.25rem; }
    .essay-section-title { font-size: 0.92rem; }
    .essay-row-title { font-size: 1rem; }
    .essay-row-subtitle { font-size: 0.93rem; }
  }

  /* When cards view is active, hide the reader nav, back link, and field-notes CTA */
  .essays-main[data-view="cards"] .essay-nav,
  .essays-main[data-view="cards"] .essay-back-to-list,
  .essays-main[data-view="cards"] .field-notes-inline-cta {
    display: none;
  }

  /* When an essay is open (reader view), strip the surrounding collection
     chrome — title block ("Essays / My Writing Philosophy / N Total"),
     the browse sidebar, and the newsletter CTA — so the essay reads like
     its own standalone page. The "All essays" back link stays as the
     way home. */
  .essays-main[data-view="reader"] .main-header.collection-header,
  .essays-main[data-view="reader"] .field-notes-inline-cta {
    display: none !important;
  }
  /* Collapse the sidebar column entirely in reader view by collapsing the
     grid template. The sidebar lives outside .essays-main, so target it
     from the layout wrapper. */
  .essays-layout:has(.essays-main[data-view="reader"]) .essays-sidebar {
    display: none;
  }
  .essays-layout:has(.essays-main[data-view="reader"]) {
    grid-template-columns: 1fr !important;
  }
  /* Widen the article column so it reads like a standalone post. */
  .essays-main[data-view="reader"] {
    max-width: 760px;
    margin-inline: auto;
  }
  /* scrollIntoView({block:'start'}) on .essays-main puts the wrapper at
     viewport top, but the sticky navbar covers the first ~64px — so the
     back link + title disappear under it. scroll-margin-top makes
     scrollIntoView leave that gap clear. */
  .essays-main { scroll-margin-top: 72px; }
  /* Tighten the gap between the "All essays" back link and the article. */
  .essays-main[data-view="reader"] .essay-back-to-list { margin-bottom: 0.25rem; }
  .essays-main[data-view="reader"] #essays-container.content-section { padding-top: 0; }
  /* Strip the card chrome on the article so it reads as a standalone
     post. Reorder children via flexbox order so the date sits between
     the title and the subtitle. */
  .essays-main[data-view="reader"] .article-full {
    display: flex;
    flex-direction: column;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
