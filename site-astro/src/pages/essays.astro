---
import essaysData from '../../public/data/essays.json';
import CollectionPage from '../components/CollectionPage.astro';
import { ESSAY_LIST_OPTIONS, ESSAY_SECTIONS } from '../lib/collection-sections';
import { formatDate } from '../lib/dates';
import { escapeAttr, escapeHtml } from '../lib/html-escape';

const canonical = 'https://jevangoldsmith.com/essays.html';
const essaysJson = JSON.stringify(essaysData);

// SSR the first (most recent) published essay so the page reaches its
// final layout in one paint — eliminates the JS-driven CLS that shows
// up after hydration. essays.ts adopts the SSR'd DOM and only re-renders
// for filter / search / nav-button changes.
const sortedEssays = (essaysData.essays as Array<Record<string, unknown>>)
  .filter((essay) => essay.status === 'published')
  .sort((a, b) => new Date(b.date as string).getTime() - new Date(a.date as string).getTime());
const firstEssay = sortedEssays[0];
const total = sortedEssays.length;
const nextTitle = sortedEssays[1]?.title as string | undefined;

function essayExcerpt(html: string, max = 160): string {
  const text = String(html || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  if (text.length <= max) return text;
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

function categorySlugOf(cat: string): string {
  return String(cat || '').toLowerCase().replace(/[^a-z0-9]+/g, '-');
}

function subtitleFor(essay: Record<string, unknown>): string {
  const sub = String(essay.subtitle || '').trim();
  if (sub) return sub;
  return essayExcerpt((essay.content as string) || '', 100);
}

// Group by category for a minimal list layout (one section per category).
const byCategory = new Map<string, Array<Record<string, unknown>>>();
for (const essay of sortedEssays) {
  const cat = (essay.category as string) || 'Other';
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(essay);
}

// Use canonical category order from section-presets, with any extras after.
const CATEGORY_ORDER = ['Philosophy', 'Management', 'Technology', 'Personal', 'Finance', 'Writing'];
const orderedCategories = [
  ...CATEGORY_ORDER.filter((c) => byCategory.has(c)),
  ...Array.from(byCategory.keys()).filter((c) => !CATEGORY_ORDER.includes(c))
];

// Render all essays in a single "Writing" section — no per-category headings.
const allRowsHtml = orderedCategories.flatMap((cat) => {
  const slug = categorySlugOf(cat);
  return (byCategory.get(cat) || []).map((essay) => {
    const id = escapeAttr(essay.id as string);
    const title = escapeHtml(essay.title as string || '');
    const subtitle = escapeHtml(subtitleFor(essay));
    return `<li class="essay-row" data-essay-id="${id}" data-category="${escapeAttr(slug)}">
            <a href="#${id}" class="essay-row-link" data-action="openEssayFromCard" data-action-args="${id}" data-action-eventobj="true">
                <span class="essay-row-title">${title}</span>
                <span class="essay-row-subtitle">${subtitle}</span>
            </a>
        </li>`;
  });
}).join('\n        ');

const ssrCardsHtml = `<section class="essay-section" data-category="writing">
        <h3 class="essay-section-title">Writing</h3>
        <ul class="essay-list">
        ${allRowsHtml}
        </ul>
    </section>`;

const ssrEssayHtml = firstEssay
  ? `<article class="article-full" id="${escapeAttr(firstEssay.id as string)}">
        <div class="post-meta">
            <span class="post-date">${escapeHtml(formatDate(firstEssay.date as string))}</span>
            <span class="post-category">${escapeHtml(firstEssay.category as string || '')}</span>
        </div>
        <h2>${escapeHtml(firstEssay.title as string || '')}</h2>
        ${firstEssay.subtitle ? `<p><em>${escapeHtml(firstEssay.subtitle as string)}</em></p>` : ''}
        ${(firstEssay.content as string) || ''}
    </article>
    <div class="essay-nav">
        <button class="essay-nav-btn essay-nav-prev" disabled data-action="prevEssay">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            <span class="essay-nav-label">
                <span class="essay-nav-direction">Previous</span>
            </span>
        </button>
        <span class="essay-nav-counter">1 / ${total}</span>
        <button class="essay-nav-btn essay-nav-next" ${total <= 1 ? 'disabled' : ''} data-action="nextEssay">
            <span class="essay-nav-label essay-nav-label-right">
                <span class="essay-nav-direction">Next</span>
                ${nextTitle ? `<span class="essay-nav-title">${escapeHtml(nextTitle)}</span>` : ''}
            </span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
    </div>`
  : '';

// after-main.html (field-notes inline CTA + seo-related) is added by the
// post-build normalizer + Base layout, so we leave it out here.
const config = ({
  layout: { id: 'essays-layout', className: 'essays-layout collection-layout' },
  sidebar: {
    id: 'essays-sidebar',
    className: 'essays-sidebar collection-sidebar',
    collapseAction: 'toggleEssaysSidebar',
    listAction: 'toggleListDropdown',
    currentListName: 'Essays',
    listOptions: ESSAY_LIST_OPTIONS,
    search: {
      inputId: 'essay-search',
      inputClass: 'book-search-input collection-search-input',
      placeholder: 'Search essays...',
      clearButtonId: 'search-clear-btn',
      clearAction: 'clearEssaySearch',
      searchAction: 'searchEssays',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    sections: ESSAY_SECTIONS
  },
  main: {
    className: 'essays-main collection-main',
    titleTag: 'h2',
    title: 'Essays',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="writing-philosophy.html" class="header-subtitle-link">My Writing Philosophy</a><span class="read-first-note">read this first</span></div>',
    counterExtraHtml: `<div class="view-toggle main-view-toggle">
    <button class="view-toggle-btn active" id="list-view-btn-main" data-action="set-view-mode" data-mode="list" title="List view">
        <svg class="ico-stroke" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-listView"/></svg>
    </button>
    <button class="view-toggle-btn" id="grid-view-btn-main" data-action="set-view-mode" data-mode="grid" title="Grid view">
        <svg class="ico-stroke" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="/sprite.svg#icon-gridView"/></svg>
    </button>
</div>`,
    counterGroupClass: 'header-right',
    counterId: 'essay-count',
    counterLabel: 'Total Essays',
    headerExtraHtml: '',
    bodyHtml: `<button type="button" class="essay-back-to-list" data-action="setEssayView" data-action-args="cards" data-view="reader">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        All essays
    </button>
    <div id="essays-container" class="content-section essays-view-reader" data-view="reader" hidden>${ssrEssayHtml}</div>
    <div id="essays-cards" class="essays-cards essays-view-cards" data-view="cards">
        ${ssrCardsHtml}
    </div>
    <section class="field-notes-inline-cta" data-field-notes-inline>
        <p class="archive-kicker">Field Notes</p>
        <h2>Want more notes like this?</h2>
        <p>Field Notes is where I send useful ideas before they become polished essays: books, objects, questions, and experiments worth keeping.</p>
        <a href="field-notes.html" class="btn-primary">Get Field Notes</a>
    </section>`
  }
});
---
<CollectionPage
  config={config}
  title="Essays on Thinking, Business, Culture &amp; Personal Systems"
  description="Longer essays from Jevan Goldsmith on attention, business, culture, decisions, money, meaning, and useful systems."
  canonical={canonical}
/>

<script is:inline type="application/json" id="jg-essays-data" set:html={essaysJson} />

<script>
  import '../scripts/essays.ts';
</script>

<style is:global>
  /* Index view — minimal grouped list, inspired by emilkowal.ski */
  .essays-cards {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 0.5rem 4rem;
    display: block;
  }
  .essay-section { margin-bottom: 3rem; }
  .essay-section:last-child { margin-bottom: 0; }
  .essay-section-title {
    font-family: Chivo, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-light);
    text-transform: none;
    letter-spacing: 0;
    margin: 0 0 0.5rem;
    padding: 0 0.75rem;
  }
  .essay-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .essay-row { background: transparent; }
  .essay-row-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
    transition: background .15s ease;
  }
  .essay-row-link:hover,
  .essay-row-link:focus-visible {
    background: var(--background-alt);
    outline: none;
  }
  .essay-row-title {
    font-family: Chivo, sans-serif;
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--primary-color);
    line-height: 1.35;
  }
  .essay-row-subtitle {
    font-size: 0.96rem;
    color: var(--text-light);
    line-height: 1.45;
  }

  /* "All essays" back link shown in reader view only */
  .essay-back-to-list {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 1rem;
    padding: 6px 10px 6px 0;
    background: transparent;
    border: 0;
    color: var(--text-light);
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    transition: color .15s ease;
  }
  .essay-back-to-list:hover,
  .essay-back-to-list:focus-visible {
    color: var(--primary-color);
    outline: none;
  }

  /* On mobile, widen the essays page to go edge-to-edge with the
     navbar chrome (logo on the left, hamburger on the right). The
     .essays-main wrapper's default 2rem padding was indenting the
     content well inside the logo edge — drop it to 1rem and zero
     out the per-card / per-row paddings so everything aligns. */
  @media (max-width: 768px) {
    .essays-main { padding: 1rem; }
    .essays-cards { padding: 0.5rem 0 3rem; max-width: none; }
    .essay-section-title { padding: 0; }
    .essay-row-link { padding-left: 0; padding-right: 0; }
    .essay-row-link:hover,
    .essay-row-link:focus-visible {
      /* Background hover would otherwise extend past the text edge
         and look untidy against the now-edge-to-edge layout. */
      background: transparent;
    }
  }
  @media (max-width: 640px) {
    .essay-section { margin-bottom: 2.25rem; }
    .essay-section-title { font-size: 0.92rem; }
    .essay-row-title { font-size: 1rem; }
    .essay-row-subtitle { font-size: 0.93rem; }
  }

  /* When cards view is active, hide the reader nav, back link, and field-notes CTA */
  .essays-main[data-view="cards"] .essay-nav,
  .essays-main[data-view="cards"] .essay-back-to-list,
  .essays-main[data-view="cards"] .field-notes-inline-cta {
    display: none;
  }

  /* Hide the mobile List/Grid view toggle on essays — only one view exists. */
  .essays-layout > .collection-mobile-toggle { display: none !important; }

  /* --- Dark-mode polish for the essays sidebar --- */
  [data-theme="dark"] .essays-sidebar .sidebar-category {
    border-left: 3px solid transparent;
  }
  [data-theme="dark"] .essays-sidebar .sidebar-category.active {
    background: rgba(212, 184, 122, 0.12);
    color: var(--secondary-color);
    border-left-color: var(--secondary-color);
    font-weight: 600;
  }
  [data-theme="dark"] .essays-sidebar .sidebar-category.active .category-name,
  [data-theme="dark"] .essays-sidebar .sidebar-category.active .category-icon svg {
    color: var(--secondary-color);
    stroke: var(--secondary-color);
  }
  [data-theme="dark"] .essays-sidebar .sidebar-category.active .category-count {
    background: rgba(212, 184, 122, 0.18);
    color: var(--secondary-color);
  }
  [data-theme="dark"] .essays-sidebar .sidebar-category:hover:not(.active) {
    background: rgba(255, 255, 255, 0.04);
  }
  [data-theme="dark"] .essays-sidebar .sidebar-category:hover:not(.active) .category-name,
  [data-theme="dark"] .essays-sidebar .sidebar-category:hover:not(.active) .category-icon svg {
    color: #fff;
    stroke: #fff;
  }

  /* Nested essay list (expanded under a category) */
  [data-theme="dark"] .essays-sidebar .category-essays {
    background: rgba(255, 255, 255, 0.02);
    border-left: 1px solid rgba(255, 255, 255, 0.06);
    margin-left: 1.25rem;
    padding: 4px 0;
  }
  [data-theme="dark"] .essays-sidebar .essay-link {
    color: rgba(255, 255, 255, 0.72);
    background: transparent;
    border-left: 2px solid transparent;
    padding: 0.5rem 0.85rem;
    transition: background-color .15s ease, color .15s ease, border-color .15s ease;
  }
  [data-theme="dark"] .essays-sidebar .essay-link .essay-link-date {
    color: rgba(255, 255, 255, 0.42);
  }
  [data-theme="dark"] .essays-sidebar .essay-link:hover {
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
  }
  [data-theme="dark"] .essays-sidebar .essay-link.active {
    background: rgba(212, 184, 122, 0.10);
    color: var(--secondary-color);
    border-left-color: var(--secondary-color);
    font-weight: 600;
  }
  [data-theme="dark"] .essays-sidebar .essay-link.active .essay-link-date {
    color: rgba(212, 184, 122, 0.7);
  }
</style>
