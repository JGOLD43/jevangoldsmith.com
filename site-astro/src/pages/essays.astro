---
import essaysData from '../../public/data/essays.json';
import CollectionPage from '../components/CollectionPage.astro';
import { ESSAY_LIST_OPTIONS, ESSAY_SECTIONS } from '../lib/collection-sections';
import { formatDate } from '../lib/dates';
import { escapeAttr, escapeHtml } from '../lib/html-escape';

const canonical = 'https://jevangoldsmith.com/essays.html';
const essaysJson = JSON.stringify(essaysData);

// SSR the first (most recent) published essay so the page reaches its
// final layout in one paint — eliminates the JS-driven CLS that shows
// up after hydration. essays.ts adopts the SSR'd DOM and only re-renders
// for filter / search / nav-button changes.
const sortedEssays = (essaysData.essays as Array<Record<string, unknown>>)
  .filter((essay) => essay.status === 'published')
  .sort((a, b) => new Date(b.date as string).getTime() - new Date(a.date as string).getTime());
const firstEssay = sortedEssays[0];
const total = sortedEssays.length;
const nextTitle = sortedEssays[1]?.title as string | undefined;

function essayExcerpt(html: string, max = 160): string {
  const text = String(html || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  if (text.length <= max) return text;
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

function readMinutes(html: string): number {
  const words = String(html || '').replace(/<[^>]+>/g, ' ').trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 220));
}

const ssrCardsHtml = sortedEssays.map((essay) => {
  const id = escapeAttr(essay.id as string);
  const title = escapeHtml(essay.title as string || '');
  const category = escapeHtml((essay.category as string) || '');
  const categorySlug = String(essay.category || '').toLowerCase().replace(/[^a-z0-9]+/g, '-');
  const date = escapeHtml(formatDate(essay.date as string));
  const excerpt = escapeHtml(essayExcerpt((essay.content as string) || (essay.subtitle as string) || ''));
  const minutes = readMinutes((essay.content as string) || '');
  return `<article class="essay-card" data-essay-id="${id}" data-category="${escapeAttr(categorySlug)}">
        <a href="#${id}" class="essay-card-link" data-action="openEssayFromCard" data-action-args="${id}" data-action-eventobj="true">
            <div class="essay-card-thumb" aria-hidden="true">
                <span class="essay-card-initial">${escapeHtml((essay.title as string || '').trim().charAt(0).toUpperCase())}</span>
            </div>
            <div class="essay-card-body">
                <span class="essay-card-tag tag-${escapeAttr(categorySlug)}">${category}</span>
                <h3 class="essay-card-title">${title}</h3>
                <p class="essay-card-excerpt">${excerpt}</p>
                <div class="essay-card-meta">
                    <span class="essay-card-date">${date}</span>
                    <span class="essay-card-dot" aria-hidden="true">·</span>
                    <span class="essay-card-read">${minutes} min read</span>
                </div>
            </div>
        </a>
    </article>`;
}).join('\n    ');

const ssrEssayHtml = firstEssay
  ? `<article class="article-full" id="${escapeAttr(firstEssay.id as string)}">
        <div class="post-meta">
            <span class="post-date">${escapeHtml(formatDate(firstEssay.date as string))}</span>
            <span class="post-category">${escapeHtml(firstEssay.category as string || '')}</span>
        </div>
        <h2>${escapeHtml(firstEssay.title as string || '')}</h2>
        ${firstEssay.subtitle ? `<p><em>${escapeHtml(firstEssay.subtitle as string)}</em></p>` : ''}
        ${(firstEssay.content as string) || ''}
    </article>
    <div class="essay-nav">
        <button class="essay-nav-btn essay-nav-prev" disabled data-action="prevEssay">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            <span class="essay-nav-label">
                <span class="essay-nav-direction">Previous</span>
            </span>
        </button>
        <span class="essay-nav-counter">1 / ${total}</span>
        <button class="essay-nav-btn essay-nav-next" ${total <= 1 ? 'disabled' : ''} data-action="nextEssay">
            <span class="essay-nav-label essay-nav-label-right">
                <span class="essay-nav-direction">Next</span>
                ${nextTitle ? `<span class="essay-nav-title">${escapeHtml(nextTitle)}</span>` : ''}
            </span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
    </div>`
  : '';

// after-main.html (field-notes inline CTA + seo-related) is added by the
// post-build normalizer + Base layout, so we leave it out here.
const config = ({
  layout: { id: 'essays-layout', className: 'essays-layout collection-layout' },
  sidebar: {
    id: 'essays-sidebar',
    className: 'essays-sidebar collection-sidebar',
    collapseAction: 'toggleEssaysSidebar',
    listAction: 'toggleListDropdown',
    currentListName: 'Essays',
    listOptions: ESSAY_LIST_OPTIONS,
    search: {
      inputId: 'essay-search',
      inputClass: 'book-search-input collection-search-input',
      placeholder: 'Search essays...',
      clearButtonId: 'search-clear-btn',
      clearAction: 'clearEssaySearch',
      searchAction: 'searchEssays',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    sections: ESSAY_SECTIONS
  },
  main: {
    className: 'essays-main collection-main',
    title: 'Essays',
    subtitleText: 'Thoughts on philosophy, management, and modern life',
    counterId: 'essay-count',
    counterLabel: 'Essays Published',
    headerExtraHtml: `<div class="essays-view-toggle" role="tablist" aria-label="Essay view">
        <button type="button" class="essays-view-btn active" data-view="reader" data-action="setEssayView" data-action-args="reader" role="tab" aria-selected="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h7v16H4z"/><path d="M13 4h7v16h-7z"/></svg>
            Reader
        </button>
        <button type="button" class="essays-view-btn" data-view="cards" data-action="setEssayView" data-action-args="cards" role="tab" aria-selected="false">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Index
        </button>
    </div>`,
    bodyHtml: `<div id="essays-container" class="content-section essays-view-reader" data-view="reader">${ssrEssayHtml}</div>
    <div id="essays-cards" class="essays-cards essays-view-cards" data-view="cards" hidden>
        ${ssrCardsHtml}
    </div>
    <section class="field-notes-inline-cta" data-field-notes-inline>
        <p class="archive-kicker">Field Notes</p>
        <h2>Want more notes like this?</h2>
        <p>Field Notes is where I send useful ideas before they become polished essays: books, objects, questions, and experiments worth keeping.</p>
        <a href="field-notes.html" class="btn-primary">Get Field Notes</a>
    </section>`
  }
});
---
<CollectionPage
  config={config}
  title="Essays on Thinking, Business, Culture &amp; Personal Systems"
  description="Longer essays from Jevan Goldsmith on attention, business, culture, decisions, money, meaning, and useful systems."
  canonical={canonical}
/>

<script is:inline type="application/json" id="jg-essays-data" set:html={essaysJson} />

<script>
  import '../scripts/essays.ts';
</script>

<style is:global>
  .essays-view-toggle {
    display: inline-flex;
    gap: 0;
    padding: 4px;
    background: var(--background-alt);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    margin-left: auto;
    align-self: center;
  }
  .essays-view-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-light);
    background: transparent;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    transition: color .2s, background .2s;
  }
  .essays-view-btn:hover { color: var(--primary-color); }
  .essays-view-btn.active {
    color: var(--primary-color);
    background: var(--card-bg);
    box-shadow: 0 1px 3px rgba(0,0,0,.08);
  }
  .essays-view-btn svg { stroke-width: 2; }

  /* Index (card) view — Bourke-inspired feed */
  .essays-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding: 2rem 0;
    max-width: 760px;
    margin: 0 auto;
  }
  .essay-card {
    background: transparent;
  }
  .essay-card-link {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.75rem;
    color: inherit;
    text-decoration: none;
    align-items: start;
  }
  .essay-card-link:hover .essay-card-title { color: var(--secondary-color); }
  .essay-card-link:hover .essay-card-thumb { transform: translateY(-2px); }
  .essay-card-thumb {
    aspect-ratio: 4/3;
    border-radius: var(--site-radius-md);
    background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
    display: grid;
    place-items: center;
    overflow: hidden;
    transition: transform .25s ease;
    box-shadow: var(--shadow);
  }
  .essay-card-initial {
    font-family: Chivo, Georgia, serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: rgba(255,255,255,.92);
    letter-spacing: -.02em;
  }
  .essay-card-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 0.75rem;
    background: var(--background-alt);
    color: var(--text-light);
  }
  .essay-card-tag.tag-philosophy { background: #e8e1f0; color: #6b4f9b; }
  .essay-card-tag.tag-management { background: #e1ecf0; color: #2d6b86; }
  .essay-card-tag.tag-technology { background: #e8f0e1; color: #4a7a3a; }
  .essay-card-tag.tag-personal   { background: #f0e8e1; color: #9b6b4f; }
  .essay-card-tag.tag-finance    { background: #f0e1e1; color: #9b4f4f; }
  .essay-card-tag.tag-writing    { background: #f0ebd9; color: #8a7028; }
  [data-theme="dark"] .essay-card-tag { background: var(--background-alt); color: var(--text-light); }
  [data-theme="dark"] .essay-card-tag.tag-philosophy { background: #2a2438; color: #b89dd6; }
  [data-theme="dark"] .essay-card-tag.tag-management { background: #1f2e36; color: #8fc3dc; }
  [data-theme="dark"] .essay-card-tag.tag-technology { background: #1f2e1f; color: #9fc88f; }
  [data-theme="dark"] .essay-card-tag.tag-personal   { background: #36281f; color: #d6a587; }
  [data-theme="dark"] .essay-card-tag.tag-finance    { background: #36201f; color: #d68f8f; }
  [data-theme="dark"] .essay-card-tag.tag-writing    { background: #2e2a18; color: #d6c478; }

  .essay-card-title {
    font-family: Chivo, Georgia, serif;
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.25;
    margin: 0 0 0.5rem;
    color: var(--primary-color);
    transition: color .2s;
  }
  .essay-card-excerpt {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-light);
    margin: 0 0 0.75rem;
  }
  .essay-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-light);
  }
  .essay-card-dot { opacity: 0.5; }

  @media (max-width: 640px) {
    .essay-card-link { grid-template-columns: 110px 1fr; gap: 1rem; }
    .essay-card-title { font-size: 1.25rem; }
    .essay-card-initial { font-size: 2.25rem; }
    .essays-cards { padding: 1rem 0; gap: 2rem; }
  }

  /* When cards view is active, hide the reader nav buttons + field-notes CTA */
  .essays-main[data-view="cards"] .essay-nav,
  .essays-main[data-view="cards"] .field-notes-inline-cta {
    display: none;
  }
</style>
