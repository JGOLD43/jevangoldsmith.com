---
import raw from '../../../data/products.json';
import Base from '../layouts/Base.astro';
import { renderResourceCard } from '../lib/free-resources-render';

interface Resource {
  id: string;
  slug?: string;
  title: string;
  category?: string;
  type?: string;
  shortDescription?: string;
  description?: string;
  ctaLabel?: string;
  downloadUrl?: string;
  checkoutUrl?: string;
}

interface ResourceCategory {
  id: string;
  title: string;
  icon?: string;
}

const resources: Resource[] = (raw as { resources?: Resource[] }).resources ?? [];
const resourceCategories: ResourceCategory[] = (raw as { resourceCategories?: ResourceCategory[] }).resourceCategories ?? [];

const cards = resources.map((r) => renderResourceCard(r, resourceCategories)).join('\n            ');
---
<Base
  title="Useful Resources for Thinking, Building &amp; Learning"
  description="Templates, guides, and practical tools from Jevan Goldsmith for reflection, better thinking, reading, and useful work."
  canonical="https://jevangoldsmith.com/free-resources.html"
  pageType="CollectionPage"
>
  <main class="resources-content">
    <section class="resources-intro">
      <h1 class="resources-title">Practical artifacts from the archive.</h1>
      <p class="resources-subtitle">Templates, guides, and tools I use or am shaping into something useful. Start with the weekly review.</p>
      <div class="resources-cta-row">
        <a href="#resources-grid" class="resources-cta resources-cta--primary">Browse resources</a>
        <a href="/newsletter.html" class="resources-cta resources-cta--secondary">Subscribe to newsletter</a>
      </div>
    </section>

    <div class="resources-grid" id="resources-grid">
      <Fragment set:html={cards} />
    </div>

  </main>

  <style is:inline>
    /* === Restyled resource cards ===
       Cleaner, more refined treatment: tighter card geometry, a
       small icon in its own muted square (no longer a heavy gold
       block), a hairline gold accent on the top-edge that grows on
       hover, and an underlined CTA that animates an arrow on hover
       instead of changing colour. Inline overrides win against the
       legacy-css base rules. */
    .resources-grid {
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
      margin: 0 0 4rem;
    }
    .resource-card {
      position: relative;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 14px;
      padding: 1.4rem 1.4rem 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      transition: transform 0.22s cubic-bezier(.25, .8, .25, 1),
                  box-shadow 0.22s ease,
                  border-color 0.22s ease;
      overflow: hidden;
    }
    /* Gold accent line at the top of every card — subtle in resting
       state, brightens + thickens on hover so the card feels alive
       without changing its visual weight. */
    .resource-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--secondary-color);
      opacity: 0.35;
      transform: scaleX(0.18);
      transform-origin: left center;
      transition: opacity 0.25s ease, transform 0.35s cubic-bezier(.25, .8, .25, 1);
    }
    .resource-card:hover {
      transform: translateY(-3px);
      border-color: var(--secondary-color);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    }
    .resource-card:hover::before {
      opacity: 1;
      transform: scaleX(1);
    }

    .resource-icon {
      background: color-mix(in srgb, var(--secondary-color) 16%, transparent);
      color: var(--secondary-color);
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.4rem;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .resource-card:hover .resource-icon {
      background: var(--secondary-color);
      color: #1a1a1a;
    }
    .resource-icon svg {
      width: 18px;
      height: 18px;
    }

    .resource-category {
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 1.4px;
      font-size: 0.62rem;
      font-weight: 700;
      margin: 0;
    }

    .resource-title {
      color: var(--primary-color);
      font-family: Chivo, sans-serif;
      font-size: 1.05rem;
      font-weight: 600;
      line-height: 1.28;
      margin: 0;
    }

    .resource-description {
      color: var(--text-light);
      font-size: 0.86rem;
      line-height: 1.5;
      flex: 1;
      margin: 0.3rem 0 1rem;
    }

    .resource-link {
      color: var(--primary-color);
      font-size: 0.82rem;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      margin-top: auto;
      padding-bottom: 2px;
      border-bottom: 1px solid transparent;
      transition: color 0.2s ease, border-color 0.2s ease, gap 0.25s cubic-bezier(.25, .8, .25, 1);
      align-self: flex-start;
      width: fit-content;
    }
    .resource-link:hover {
      color: var(--secondary-color);
      border-bottom-color: var(--secondary-color);
      gap: 0.6rem;
    }
    .resource-link svg {
      width: 14px;
      height: 14px;
      transition: transform 0.25s cubic-bezier(.25, .8, .25, 1);
    }
    .resource-link:hover svg {
      transform: translateX(2px);
    }

    [data-theme="dark"] .resource-card {
      background: #1c1c1c;
      border-color: #2a2a2a;
    }
    [data-theme="dark"] .resource-card:hover {
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
    }

    /* Tidier CTA pair matching the navbar Follow button: primary is
       gold-on-black, secondary is outlined. Equal-weighted pills,
       same height, sit side by side on a single row when there's
       room and stack on narrow screens. */
    .resources-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 1rem;
    }
    .resources-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.65rem 1.4rem;
      border-radius: 999px;
      font-family: Chivo, sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.3px;
      text-decoration: none;
      transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
      cursor: pointer;
      white-space: nowrap;
    }
    .resources-cta--primary {
      background: gold;
      color: #000;
      border: 2px solid #000;
    }
    .resources-cta--primary:hover {
      background: #000;
      color: gold;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px #0003;
    }
    .resources-cta--secondary {
      background: transparent;
      color: var(--text-color);
      border: 1.5px solid var(--text-color);
    }
    .resources-cta--secondary:hover {
      background: var(--text-color);
      color: var(--background);
      transform: translateY(-1px);
    }
    [data-theme="dark"] .resources-cta--secondary {
      border-color: var(--text-color);
    }
  </style>
</Base>

<script>
  // (slice 13) + Phase 7 (slice 5): shelf + grid-zoom as native modules.
  import '../scripts/grid-zoom.ts';
  import '../scripts/shelf.ts';
</script>
