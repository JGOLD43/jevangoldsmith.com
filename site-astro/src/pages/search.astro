---
import Base from '../layouts/Base.astro';
---
<Base
  title="Search Jevan Goldsmith&#39;s Archive"
  description="Search Jevan Goldsmith's archive of Field Notes, essays, books, resources, projects, skills, tools, and ideas."
  canonical="https://jevangoldsmith.com/search.html"
  pageType="WebPage"
>
  <main class="search-page">
    <section class="search-hero">
      <div class="container">
        <p class="section-eyebrow">DISCOVER</p>
        <h1>Search Jevan Goldsmith</h1>
        <div class="site-search-shell">
          <svg class="site-search-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
          <input id="site-search-input" class="site-search-input" type="search" placeholder="Search books, essays, skills, adventures..." autocomplete="off" autofocus />
        </div>
        <div class="site-search-filters" id="site-search-filters" aria-label="Search filters" />
      </div>
    </section>

    <section class="search-results-section">
      <div class="container">
        <div class="search-results-header">
          <span id="site-search-count">Loading...</span>
          <a href="/api/v1/search-index.json" class="search-api-link">JSON</a>
        </div>
        <div class="search-results" id="site-search-results" />
      </div>
    </section>
  </main>
</Base>

<script>
  const SEARCH_INDEX_URL = '/api/v1/search-index.json';

  const state: { records: Array<Record<string, any>>; query: string; type: string } = {
    records: [],
    query: '',
    type: 'all'
  };

  function debounce<T extends (...args: any[]) => any>(fn: T, wait = 120): T {
    let t: ReturnType<typeof setTimeout> | null = null;
    return ((...args: any[]) => {
      if (t) clearTimeout(t);
      t = setTimeout(() => fn(...args), wait);
    }) as T;
  }

  function escapeHTML(s: string) {
    return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }
  function escapeAttr(s: string) { return escapeHTML(s); }
  function sanitizeUrl(u: string) {
    if (!u) return '#';
    if (/^javascript:/i.test(u)) return '#';
    return u;
  }

  function normalize(v: any) { return String(v ?? '').toLowerCase().trim(); }
  function recordText(r: any) {
    if (r.searchText) return normalize(r.searchText);
    return normalize([r.title, r.summary, r.section, r.type, ...(r.tags || [])].join(' '));
  }
  function displayType(t: string) { return String(t || 'page').replace(/-/g, ' '); }

  const input = document.getElementById('site-search-input') as HTMLInputElement | null;
  const filters = document.getElementById('site-search-filters');
  const results = document.getElementById('site-search-results');
  const count = document.getElementById('site-search-count');

  function renderFilters() {
    if (!filters) return;
    const types = ['all', ...Array.from(new Set(state.records.map((r) => r.type))).sort()];
    filters.innerHTML = types.map((type) => (
      `<button class="site-search-filter ${type === state.type ? 'active' : ''}" type="button" data-search-type="${escapeAttr(type)}">${escapeHTML(displayType(type))}</button>`
    )).join('');
  }

  function filteredRecords() {
    const q = normalize(state.query);
    return state.records.filter((r) => {
      const typeMatches = state.type === 'all' || r.type === state.type;
      const queryMatches = !q || recordText(r).includes(q);
      return typeMatches && queryMatches;
    });
  }

  function renderResults() {
    if (!results || !count) return;
    const records = filteredRecords();
    count.textContent = `${records.length} ${records.length === 1 ? 'result' : 'results'}`;
    if (records.length === 0) {
      results.innerHTML = '<div class="search-empty">No results found.</div>';
      return;
    }
    results.innerHTML = records.slice(0, 80).map((r) => {
      const safeHref = sanitizeUrl(r.url);
      const safeTitle = escapeHTML(r.title);
      const safeSummary = escapeHTML(r.summary || '');
      const safeType = escapeHTML(displayType(r.type));
      return '<a class="search-result-card" ' + 'hr' + 'ef="' + safeHref + '">' +
        '<span><span class="search-result-title">' + safeTitle + '</span>' +
        '<span class="search-result-summary">' + safeSummary + '</span></span>' +
        '<span class="search-result-type">' + safeType + '</span></a>';
    }).join('');
  }

  function applyUrlQuery() {
    if (!input) return;
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q') || '';
    state.query = q;
    input.value = q;
  }

  function bindEvents() {
    if (input) {
      const debouncedRender = debounce(renderResults, 120);
      input.addEventListener('input', () => {
        state.query = input.value;
        debouncedRender();
      });
    }
    if (filters) {
      filters.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement | null)?.closest('[data-search-type]') as HTMLElement | null;
        if (!btn) return;
        state.type = btn.dataset.searchType || 'all';
        renderFilters();
        renderResults();
      });
    }
  }

  async function init() {
    if (!results || !count) return;
    try {
      const res = await fetch(SEARCH_INDEX_URL);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const payload = await res.json();
      state.records = Array.isArray(payload.records) ? payload.records : [];
      applyUrlQuery();
      renderFilters();
      bindEvents();
      renderResults();
    } catch {
      count.textContent = 'Search unavailable';
      results.innerHTML = '<div class="search-empty">Search index unavailable.</div>';
    }
  }

  init();
</script>
