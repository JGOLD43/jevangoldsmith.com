---
import CollectionPage from '../components/CollectionPage.astro';
import { getCollection } from 'astro:content';
import {
  tasteListOptions,
  PODCAST_SECTIONS
} from '../lib/collection-chrome';
import { renderPodcastCardHtml } from '../lib/podcast-card';

const canonical = 'https://jevangoldsmith.com/podcasts.html';

// Phase B: pre-render curated podcast cards.
const podcasts = await getCollection('podcasts');
const podcastCardsHtml = podcasts.map((p: any) => renderPodcastCardHtml(p.data as Record<string, unknown>)).join('');

const config = ({
  layout: { id: 'podcasts-layout', className: 'movies-layout podcasts-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'podcasts-sidebar',
    className: 'movies-sidebar collection-sidebar collection-sidebar--taste collapsed',
    collapseAction: 'togglePodcastSidebar',
    listAction: 'togglePodcastListDropdown',
    currentListName: 'Podcasts',
    listOptions: tasteListOptions('podcasts', 'podcasts'),
    search: {
      inputId: 'podcast-search',
      inputClass: 'movie-search-input collection-search-input',
      placeholder: 'Search podcasts...',
      clearButtonId: 'podcast-search-clear-btn',
      clearAction: 'clearPodcastSearch',
      searchAction: 'searchPodcasts',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    footerText: 'Shows and episodes I return to',
    sections: PODCAST_SECTIONS
  },
  main: {
    className: 'movies-main collection-main',
    title: 'Podcasts I Listen To',
    subtitleText: 'Conversations, shows, and episodes that shaped how I think about business, technology, and life.',
    counterId: 'podcast-count',
    counterLabel: 'Audio Notes',
    bodyHtml: `<section id="spotify-recent-section" class="spotify-section" hidden>
    <div class="spotify-section-header">
        <h2>Recently Listened on Spotify</h2>
        <p class="spotify-section-meta" id="spotify-recent-meta"></p>
    </div>
    <div id="spotify-recent-container" class="movies-grid"></div>
</section>

<section id="spotify-shows-section" class="spotify-section" hidden>
    <div class="spotify-section-header">
        <h2>Shows I Follow on Spotify</h2>
        <p class="spotify-section-meta" id="spotify-shows-meta"></p>
    </div>
    <div id="spotify-shows-container" class="movies-grid"></div>
</section>

<section id="curated-podcasts-section">
    <div class="spotify-section-header">
        <h2>Curated Picks</h2>
        <p class="spotify-section-meta">Hand-picked shows and episodes I return to.</p>
    </div>
    <div id="podcasts-container" class="movies-grid">${podcastCardsHtml}</div>
</section>`
  }
});
---
<CollectionPage
  config={config}
  title="Podcasts, Conversations &amp; Audio Notes"
  description="A podcast archive of conversations, shows, and audio ideas Jevan Goldsmith returns to."
  canonical={canonical}
/>

<script>
  // Phase 5 (slice 7) + Phase 7 (slice 4): podcasts + infra deps as native modules.
  import '../scripts/grid-zoom.js';
  import '../scripts/collection-ui.js';
  import '../scripts/collection-runtime.js';
  import '../scripts/collection-helpers.js';
  import '../scripts/data-fetch.js';
  import '../scripts/action-dispatcher.js';
  import '../scripts/sanitize.js';
  import '../scripts/podcasts.js';
</script>
