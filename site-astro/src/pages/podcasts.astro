---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import podcastEpisodesData from '../../public/data/podcast-episodes.json';
import podcastShowsData from '../../public/data/podcast-shows.json';
import CollectionPage from '../components/CollectionPage.astro';
import PodcastCard from '../components/PodcastCard.astro';
import PodcastStatsBody from '../components/PodcastStatsBody.astro';
import { PODCAST_SECTIONS, tasteListOptions } from '../lib/collection-sections';
import { formatEpisodeDuration, formatRelativeDate } from '../lib/dates';

const canonical = 'https://jevangoldsmith.com/podcasts.html';

// pre-render curated podcast cards.
const podcasts = await getCollection('podcasts') as CollectionEntry<'podcasts'>[];
const spotifyEpisodes = Array.isArray(podcastEpisodesData.episodes) ? podcastEpisodesData.episodes.slice(0, 24) : [];
const spotifyShows = Array.isArray(podcastShowsData.shows) ? podcastShowsData.shows : [];

// Build category-folder cards for the grid view — mirrors books/movies.
const podcastsByCategory = podcasts.reduce<Record<string, typeof podcasts>>((groups, p) => {
  const c = (p.data.category || 'Uncategorized').trim();
  (groups[c] ||= []).push(p);
  return groups;
}, {});
const categoryGridCards = Object.entries(podcastsByCategory)
  .sort((a, b) => b[1].length - a[1].length)
  .map(([category, items]) => ({
    category,
    count: items.length,
    covers: items.slice(0, 8).map((p) => ({
      src: p.data.image || '',
      alt: p.data.title || ''
    })),
    emptySlots: Math.max(0, 8 - Math.min(8, items.length))
  }));

const config = ({
  layout: { id: 'podcasts-layout', className: 'movies-layout podcasts-layout collection-layout sidebar-collapsed' },
  sidebar: {
    id: 'podcasts-sidebar',
    className: 'movies-sidebar collection-sidebar collection-sidebar--taste collapsed',
    collapseAction: 'togglePodcastSidebar',
    listAction: 'togglePodcastListDropdown',
    currentListName: 'Podcasts',
    listOptions: tasteListOptions('podcasts'),
    search: {
      inputId: 'podcast-search',
      inputClass: 'movie-search-input collection-search-input',
      placeholder: 'Search podcasts...',
      clearButtonId: 'podcast-search-clear-btn',
      clearAction: 'clearPodcastSearch',
      searchAction: 'searchPodcasts',
      searchUsesValue: true,
      searchEvent: 'input',
      wrapperClass: 'search-input-wrapper search-bubble'
    },
    footerText: 'Shows and episodes I return to',
    sections: PODCAST_SECTIONS
  },
  main: {
    className: 'movies-main collection-main',
    titleTag: 'h2',
    title: 'Podcasts',
    mobileGridLabel: 'Podcasts',
    subtitleHtml: '<div class="philosophy-link-wrapper"><a href="podcast-philosophy.html" class="header-subtitle-link">My Podcast Philosophy</a><span class="read-first-note">read this first</span></div>',
    counterId: 'podcast-count',
    counterLabel: 'Audio Notes',
    counterGroupClass: 'movie-counter-group'
  }
});
---
<CollectionPage
  config={config}
  title="Podcasts, Conversations &amp; Audio Notes"
  description="A podcast archive of conversations, shows, and audio ideas Jevan Goldsmith returns to."
  canonical={canonical}
>
  <Fragment slot="counter-extra">
    <div class="movie-counter-row">
      <button type="button" class="stats-toggle podcast-stats-toggle" aria-expanded="false" aria-controls="podcast-stats-panel" aria-label="Show listening stats">Stats <span aria-hidden="true">▾</span></button>
      <button class="view-toggle-single" id="podcasts-view-toggle" data-action="toggle-podcasts-view-mode" data-current-mode="list" aria-label="Switch to category grid view" title="Switch to category grid view">
        <svg class="ico-stroke view-icon view-icon-list" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-listView"></use></svg>
        <svg class="ico-stroke view-icon view-icon-grid" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-gridView"></use></svg>
      </button>
    </div>
  </Fragment>
  <section id="podcast-stats-panel" class="movie-stats-panel collapsed" aria-label="Listening stats" hidden>
    <div class="stats-body">
      <PodcastStatsBody
        podcasts={podcasts.map((p) => ({ title: p.data.title, host: p.data.host, category: p.data.category, badge: p.data.badge }))}
        spotifyEpisodeCount={spotifyEpisodes.length}
        spotifyShowCount={spotifyShows.length}
      />
    </div>
  </section>
  <section id="spotify-recent-section" class="spotify-section" hidden={spotifyEpisodes.length === 0}>
    <div class="spotify-section-header">
      <h2>Recently Listened on Spotify</h2>
      <p class="spotify-section-meta" id="spotify-recent-meta">
        {spotifyEpisodes.length > 0 && `${spotifyEpisodes.length} ${spotifyEpisodes.length === 1 ? 'recent episode' : 'recent episodes'}${podcastEpisodesData.generatedAt ? ` · synced ${formatRelativeDate(podcastEpisodesData.generatedAt)}` : ''}`}
      </p>
    </div>
    <div id="spotify-recent-container" class="movies-grid">
      {spotifyEpisodes.map((ep) => (
        <div class="movie-card podcast-card js-zoom-item" data-spotify="episode">
          <div class="movie-poster-wrapper">
            {ep.image
              ? <img src={ep.image} alt={ep.showName || ep.episodeName || ''} class="podcast-cover" width="150" height="150" loading="lazy" decoding="async" />
              : <div class="podcast-cover-placeholder">🎧</div>}
          </div>
          <div class="movie-info">
            <div class="movie-title-row">
              <h3 class="movie-title">{ep.episodeName || 'Untitled episode'}</h3>
            </div>
            <div class="podcast-category-badge">{ep.showName || 'Unknown show'}</div>
            {(formatEpisodeDuration(ep.durationMs) || formatRelativeDate(ep.listenedAt)) && (
              <div class="spotify-episode-duration">
                {formatEpisodeDuration(ep.durationMs)}
                {formatEpisodeDuration(ep.durationMs) && formatRelativeDate(ep.listenedAt) ? ' · ' : ''}
                {formatRelativeDate(ep.listenedAt)}
              </div>
            )}
            {ep.episodeUrl && <a class="spotify-episode-link" href={ep.episodeUrl} target="_blank" rel="noopener noreferrer">Open in Spotify →</a>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="spotify-shows-section" class="spotify-section" hidden={spotifyShows.length === 0}>
    <div class="spotify-section-header">
      <h2>Shows I Follow on Spotify</h2>
      <p class="spotify-section-meta" id="spotify-shows-meta">
        {spotifyShows.length > 0 && `${spotifyShows.length} ${spotifyShows.length === 1 ? 'show' : 'shows'}${podcastShowsData.generatedAt ? ` · synced ${formatRelativeDate(podcastShowsData.generatedAt)}` : ''}`}
      </p>
    </div>
    <div id="spotify-shows-container" class="movies-grid">
      {spotifyShows.map((show) => (
        <div class="movie-card podcast-card js-zoom-item" data-spotify="show">
          <div class="movie-poster-wrapper">
            {show.image
              ? <img src={show.image} alt={show.name || ''} class="podcast-cover" width="150" height="150" loading="lazy" decoding="async" />
              : <div class="podcast-cover-placeholder">🎙️</div>}
          </div>
          <div class="movie-info">
            <div class="movie-title-row">
              <h3 class="movie-title">{show.name || 'Untitled show'}</h3>
            </div>
            {show.publisher && <div class="podcast-category-badge">{show.publisher}</div>}
            {show.url && <a class="spotify-episode-link" href={show.url} target="_blank" rel="noopener noreferrer">Open in Spotify →</a>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="curated-podcasts-section">
    <div id="podcasts-container" class="movies-grid">
      {podcasts.map((p, i) => <PodcastCard podcast={{ ...p.data, id: p.id }} index={i} />)}
    </div>
  </section>
  <div class="category-grid-view" id="podcasts-category-grid-view" style="display: none;">
    <div class="category-grid">
      {categoryGridCards.map((g) => (
        <div class="category-card" data-action="open-podcast-category-modal" data-category={g.category}>
          <div class="category-card-books">
            {g.covers.map((cover) => (
              cover.src ? <img src={cover.src} alt={cover.alt} loading="lazy" decoding="async" data-remove-on-error="true" /> : <div class="empty-slot"></div>
            ))}
            {Array.from({ length: g.emptySlots }).map(() => <div class="empty-slot"></div>)}
          </div>
          <div class="category-card-info">
            <span class="category-card-name">{g.category}</span>
            <span class="category-card-count">{g.count}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
  <div id="podcast-category-modal" class="category-expanded" role="dialog" aria-modal="true" aria-labelledby="podcast-category-title">
    <div class="category-modal-backdrop" data-action="close-podcast-category-modal"></div>
    <div class="category-modal-content">
      <div class="category-expanded-header">
        <h2 class="category-expanded-title" id="podcast-category-title"></h2>
        <button class="category-expanded-close" data-action="close-podcast-category-modal" aria-label="Close">&times;</button>
      </div>
      <div class="category-expanded-books" id="podcast-category-list"></div>
    </div>
  </div>
</CollectionPage>

<style is:inline>
  .movie-counter-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }
</style>

<script>
  import { createCollectionRuntime } from '../scripts/collection-runtime';
  import { onDomReady } from '../scripts/dom-ready';
  import { initCoverFlight } from '../scripts/cover-flight';
  import { renderSpotifyFollowedShows, renderSpotifyRecentEpisodes } from '../scripts/podcasts-spotify';
  import '../scripts/podcasts-folder-view.ts';

  let podcastRuntime: AnyObj = null;

  function buildCollectionController() {
      podcastRuntime = createCollectionRuntime({
          actions: {
              clearSearch: 'clearPodcastSearch',
              filter: 'filterPodcasts',
              search: 'searchPodcasts',
              toggleDropdown: 'togglePodcastListDropdown',
              toggleSidebar: 'togglePodcastSidebar'
          },
          allButtonSelector: '.sidebar-category[data-podcast-category="all"]',
          buttonSelector: '.sidebar-category',
          cardSelector: '.podcast-card',
          categoryMode: 'exact',
          counterId: 'podcast-count',
          layoutId: 'podcasts-layout',
          searchClearButtonId: 'podcast-search-clear-btn',
          searchInputId: 'podcast-search',
          sidebarId: 'podcasts-sidebar',
          storageKey: 'podcasts-sidebar-collapsed'
      });
  }

  async function initPodcastsPage() {
      buildCollectionController();
      podcastRuntime.init();

      const grid = document.getElementById('podcasts-container');
      if (grid) {
          // Replace the old grid-zoom with cover-flight so the open
          // animation matches books/movies — clone the cover, FLIP it
          // from the card to the detail-page hero, then SPA-swap.
          initCoverFlight({
              grid: grid as HTMLElement,
              cardSelector: 'a.podcast-card',
              coverSelector: 'img.podcast-cover',
              detailMainSelector: 'main.detail-page--podcast',
              detailHeroImgSelector: '.detail-hero-cover img',
              bodyLaunchClass: 'is-podcast-launching',
              arrivalKey: 'podcast',
              listingBackSelectors: ['.movies-sidebar', '.collection-sidebar']
          });
      }

      renderSpotifyRecentEpisodes();
      renderSpotifyFollowedShows();
  }

  onDomReady(initPodcastsPage, 'podcasts init');
</script>
