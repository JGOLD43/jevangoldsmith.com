{
  "name": "jevangoldsmith-website",
  "version": "1.0.0",
  "private": true,
  "description": "Static personal website for jevangoldsmith.com",
  "scripts": {
    "assets:optimize": "node scripts/optimize-assets.js",
    "snap:routes": "node scripts/snap-popular-routes.js",
    "build": "npm run snap:routes && npm run assets:optimize && node scripts/legacy-build/build-site.js",
    "dev": "npm run --prefix site-astro dev",
    "build:astro": "npm run snap:routes && npm run assets:optimize && npm run --prefix site-astro build",
    "build:astro:fast": "npm run --prefix site-astro build",
    "check": "node scripts/check/run-all.js",
    "check:build": "npm run build",
    "check:lint": "npx biome check js scripts",
    "check:seo": "node scripts/check/seo-fixture.js check",
    "check:seo:capture": "node scripts/check/seo-fixture.js capture",
    "check:content": "node scripts/check/content-fixture.js check",
    "check:content:capture": "node scripts/check/content-fixture.js capture",
    "check:perf": "node scripts/check/perf-baseline.js check",
    "check:perf:capture": "node scripts/check/perf-baseline.js capture",
    "check:visual": "node scripts/check/visual-baselines.js check",
    "check:visual:capture": "node scripts/check/visual-baselines.js capture",
    "check:parity": "node scripts/check-parity.js",
    "check:parity:build": "node scripts/check-parity.js --build",
    "check:parity:visual": "node scripts/check-visual-parity.mjs",
    "check:parity:runtime": "node scripts/check-runtime.mjs",
    "check:parity:capture": "npm run build && npm run check:seo:capture && npm run check:content:capture && npm run check:visual:capture && npm run check:perf:capture",
    "check:links": "node scripts/check-links.js",
    "check:page-baselines": "node scripts/check-page-baselines.js",
    "check:smoke": "node scripts/check-smoke.js",
    "check:live": "node scripts/check-live.js",
    "check:live:firebase": "LIVE_BASE_URL=https://jevan-goldsmith-website.web.app LIVE_CANONICAL_BASE_URL=https://jevangoldsmith.com node scripts/check-live.js",
    "test:browser": "npx playwright test",
    "enrich:movies": "node scripts/enrich-movies.js",
    "photos:sync": "node scripts/sync-photos.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1",
    "lightningcss": "^1.32.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@tmcw/togeojson": "^7.1.2",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@xmldom/xmldom": "^0.9.10",
    "dotenv": "^17.4.2"
  },
  "optionalDependencies": {
    "googleapis": "^171.4.0"
  }
}
