{
  "name": "jevangoldsmith-website",
  "version": "1.0.0",
  "private": true,
  "description": "Static personal website for jevangoldsmith.com",
  "scripts": {
    "dev": "npm run --prefix site-astro dev",
    "build": "npm run snap:routes && npm run assets:optimize && npm run --prefix site-astro build && npm run normalize:html && npm run bundle:js && npm run purge:css",
    "build:fast": "npm run --prefix site-astro build && npm run normalize:html && npm run bundle:js && npm run purge:css",
    "snap:routes": "node scripts/snap-popular-routes.js",
    "assets:optimize": "node scripts/optimize-assets.js",
    "normalize:html": "node scripts/normalize-astro-html.js --dist=dist",
    "bundle:js": "node scripts/bundle-page-scripts.js --dist=dist",
    "purge:css": "node scripts/purge-css-per-page.js --dist=dist",
    "lint": "npx biome check js scripts",
    "enrich:movies": "node scripts/enrich-movies.js",
    "photos:sync": "node scripts/sync-photos.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "http-server": "^14.1.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@tmcw/togeojson": "^7.1.2",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@xmldom/xmldom": "^0.9.10",
    "dotenv": "^17.4.2"
  },
  "optionalDependencies": {
    "googleapis": "^171.4.0"
  }
}
