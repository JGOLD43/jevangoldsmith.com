{
  "name": "jevangoldsmith-website",
  "version": "1.0.0",
  "private": true,
  "description": "Static personal website for jevangoldsmith.com",
  "scripts": {
    "dev": "node scripts/generate-icon-sprite.js --public-out=site-astro/public/sprite.svg && npm run --prefix site-astro dev",
    "dev:full": "node scripts/generate-icon-sprite.js --public-out=site-astro/public/sprite.svg && (node scripts/watch-assets.js & npm run --prefix site-astro dev)",
    "watch:assets": "node scripts/watch-assets.js",
    "serve": "npx firebase-tools emulators:start --only hosting",
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "node scripts/build.js",
    "build:fast": "node scripts/build.js --fast",
    "people:merge": "node scripts/merge-people.js",
    "search:audit:strict": "node scripts/audit-search-index.js --strict",
    "content:validate": "node scripts/validate-content.js",
    "content:validate:strict": "node scripts/validate-content.js --strict",
    "smoke": "node scripts/smoke-check.js",
    "perf:lighthouse": "node scripts/perf-lighthouse.js",
    "perf:check": "node scripts/check-lighthouse-budget.js",
    "movies:sync": "node scripts/sync-letterboxd.js",
    "test:browser": "cd site-astro && npx playwright test",
    "test:unit": "node --test tests/unit/*.test.js",
    "search:sync": "node scripts/sync-search-index.js --write",
    "snap:routes": "node scripts/snap-popular-routes.js",
    "routes:split": "node scripts/split-popular-routes.js",
    "assets:optimize": "node scripts/optimize-assets.js",
    "assets:inventory": "node scripts/asset-inventory.js",
    "assets:prune:dry": "node scripts/prune-generated-assets.js --dry-run",
    "assets:prune": "node scripts/prune-generated-assets.js",
    "check": "npm run --prefix site-astro astro check",
    "purge:css": "node scripts/purge-css-per-page.js --dist=dist",
    "slim:json": "node scripts/slim-runtime-json.js --dist=dist",
    "prune:dist": "node scripts/prune-dist-assets.js --dist=dist",
    "perf:budget": "node scripts/check-performance-budgets.js --dist=dist",
    "csp:hashes": "node scripts/update-csp-hashes.js --dist=dist",
    "lint": "npx biome check scripts",
    "verify": "node scripts/verify.js",
    "check:live": "node scripts/check-live.js",
    "css:build-legacy": "node scripts/build-legacy-css.js",
    "enrich:movies": "node scripts/enrich-movies.js",
    "photos:sync": "node scripts/sync-photos.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "dotenv": "^17.4.2",
    "html-minifier-terser": "^7.2.0",
    "lightningcss": "^1.32.0",
    "sharp": "^0.34.5"
  },
  "optionalDependencies": {
    "googleapis": "^171.4.0"
  }
}
