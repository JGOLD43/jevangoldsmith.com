{
  "name": "jevangoldsmith-website",
  "version": "1.0.0",
  "private": true,
  "description": "Static personal website for jevangoldsmith.com",
  "scripts": {
    "assets:optimize": "node scripts/optimize-assets.js",
    "snap:routes": "node scripts/snap-popular-routes.js",
    "build": "npm run snap:routes && npm run assets:optimize && node scripts/build-site.js",
    "dev": "npm run build && npx http-server dist -p 3000 -c-1",
    "check": "npm run check:repo && npm run check:source && npm run check:structure && npm run check:build && npm run check:seo && npm run check:js && npm run check:lint && npm run check:deadcode && npm run check:content && npm run check:links && npm run check:deploy && npm run check:api && npm run check:performance && npm run check:assets && npm run check:inline && npm run check:page-baselines && npm run check:docs && npm run check:smoke",
    "check:repo": "node scripts/check-repo.js",
    "check:source": "node scripts/check-source-ownership.js",
    "check:structure": "node scripts/check-structure.js",
    "check:build": "node scripts/build-site.js --verify",
    "check:seo": "node scripts/check-seo.js",
    "check:js": "node scripts/check-js.js",
    "check:lint": "npx biome check js scripts",
    "check:deadcode": "node scripts/check-deadcode.js",
    "check:content": "node scripts/check-content.js",
    "check:links": "node scripts/check-links.js",
    "check:deploy": "node scripts/check-deploy.js",
    "check:api": "node scripts/check-api-contract.js",
    "check:performance": "node scripts/check-performance-budget.js",
    "check:assets": "node scripts/check-assets.js",
    "check:inline": "node scripts/check-inline-ratchet.js",
    "check:page-baselines": "node scripts/check-page-baselines.js",
    "check:docs": "node scripts/check-docs.js",
    "check:smoke": "node scripts/check-smoke.js",
    "check:live": "node scripts/check-live.js",
    "check:live:firebase": "LIVE_BASE_URL=https://jevan-goldsmith-website.web.app LIVE_CANONICAL_BASE_URL=https://jevangoldsmith.com node scripts/check-live.js",
    "test:browser": "npx playwright test",
    "sync:site": "node scripts/sync-site-config.js",
    "enrich:movies": "node scripts/enrich-movies.js",
    "photos:sync": "node scripts/sync-photos.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1",
    "leaflet.markercluster": "^1.5.3",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@fontsource/chivo": "^5.2.8",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@xmldom/xmldom": "^0.9.10",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0"
  }
}
