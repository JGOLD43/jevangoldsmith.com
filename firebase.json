{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "admin/**",
      "functions/**",
      "site-astro/src/**",
      "scripts/**",
      "css/src/**"
    ],
    "headers": [
      {
        "source": "**/*.@(avif|webp|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/_astro/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/css/chrome.*.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/css/per-page/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/sprite.svg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "/images/generated/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|svg|gif|mp4)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      },
      {
        "source": "/api/v1/people-modal.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, stale-while-revalidate=86400"
          }
        ]
      },
      {
        "source": "/api/v1/books-runtime.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, stale-while-revalidate=86400"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'sha256-96MAWE8dU1hV0CuI1iRIFYHEMXMGa1zZVsDTnE+qUBk=' 'sha256-9x5FdsG4SVC0XamUXvJ11vwhhGrkJxKKI7w3vo9fZ0o=' 'sha256-GbcwBkpHyMF6bE89Z+UelbWF3WcJhNriK8ocZ0qLkTI=' 'sha256-iEb1UvPC6DMDwDmPZ4lGNhy5seUE5F9EAOYybFq4tGw=' 'sha256-ojGcl0F7C6GJHQdzZWsBE3pgtXPGJrQwrQJ/QDz5nhI='; style-src 'self' 'sha256-1ZG95obVrY+tyPKnnv9V+m4qflE7beMsS8L9pXiGnP8=' 'sha256-4SUlbtBb/TxwESOviJSUDi5lJlSovLCf1mJQrIxkNXU=' 'sha256-4SmBmymAD8jNl5TjimU/EYqAimMRvzim0qXYa37NW4M=' 'sha256-C7jOfzEMg0sU5x0BLzsvrtkGfhTA9mbZnVcmkfdwGo0=' 'sha256-Ga+IXK55QmuZJxr0HqB+btghmZdlD2ttjzxINX2zsU8=' 'sha256-m2SzYLJdEG/6q9DqgI+Y6PQOyxLPusFDSTftWpRZTMA=' 'sha256-w0vzoqSlOU6XrigA5uA3IhlN2gwvEpqWIGQsEqaDokA=' 'sha256-w35Dg5HsngJoahcjKc20mQhunX+s2CQh8hnXEKTN2tg=' 'sha256-ylbTCSp44DA4uDYrOHr+Ceyh6Fo1ojc5HPgGLFbYWWs='; font-src 'self'; img-src 'self' https://*.ltrbxd.com https://covers.openlibrary.org https://server.arcgisonline.com https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com data:; connect-src 'self' https://api.allorigins.win https://formsubmit.co https://server.arcgisonline.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' mailto: https://formsubmit.co"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    }
  }
}
