{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "admin/**",
      "functions/**",
      "site-astro/src/**",
      "scripts/**",
      "css/src/**"
    ],
    "headers": [
      {
        "source": "**/*.@(avif|webp|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/_astro/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/css/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/sprite.+(*).svg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/images/generated/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|svg|gif|mp4)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      },
      {
        "source": "/api/v1/people-modal.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, stale-while-revalidate=86400"
          }
        ]
      },
      {
        "source": "/api/v1/books-runtime.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, stale-while-revalidate=86400"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains; preload"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'sha256-3Gu6Bm7X3ZvZrJMc4fIcu06e6zHBwXZZrh+uHiCFqbU=' 'sha256-3ehQeKSGV+P483UrfPlw53IEpLakNEnA2pyN0Hn8QF8=' 'sha256-5nN8mjUmtJw7b8t2CBbhpoF9lU0LzYcS/Qg69proSBQ=' 'sha256-7aztZYzCx55gVbVv2Aq1QIojswWRuvXyjdlFnszAhCo=' 'sha256-PFyi4nfXxyr7KXDytUFooE3WUixQZALQIYaS4T0mydo=' 'sha256-PfhxCieARBqj4iHLDEWjY/L81PWOgpf2APOuVm4lQyM=' 'sha256-VFkwEupNT252YQc4ztuPpB3AQ4T8KpSjetmeDuSvv0I=' 'sha256-Y53AR4mPDK95XVcA9+cTjL8x4y3O7yuVu4olPoBE4Qo=' 'sha256-c/KfcIgADwgIUOl3rLaY61kBfqTQzCNMQDQIlAppuoU=' 'sha256-hA91K66T6NKYhQENm6LeWZPkwZNxEmM2bTkIqA936iw=' 'sha256-iEb1UvPC6DMDwDmPZ4lGNhy5seUE5F9EAOYybFq4tGw=' 'sha256-k1Vl9bbT1Vr2JJQbxSftaEBZ2OOaaoTsw7ROshUNfJc=' 'sha256-qWIXZvBKFD/zgYaLN43GmJyljXgVPRzgRDKSQMnuYiE=' 'sha256-tO4/4+qALONokQiUY05Eu1KHYGT6HYY686bqH/1WXnI='; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' https://*.ltrbxd.com https://covers.openlibrary.org https://images.unsplash.com https://server.arcgisonline.com https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com data:; connect-src 'self' https://api.allorigins.win https://formsubmit.co https://server.arcgisonline.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' mailto: https://formsubmit.co"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    }
  }
}
