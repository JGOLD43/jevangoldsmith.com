# System files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
node_modules/

# Temporary files
*.tmp
.cache/

# Local env / secrets
.env
.env.local
.secrets/

# Test artifacts
test-results/
playwright-report/
.playwright-cli/
.playwright-mcp/
tests/visual-diff/
# Root-level debug screenshots (live in tests/ if needed long-term)
/*.png
/*.jpeg
/*.jpg
!/CNAME
!/llms.txt

# Generated build output
dist/
dist-astro/
.firebase/

# Astro migration (in-progress)
site-astro/node_modules/
site-astro/.astro/
site-astro/dist/
# Dev-only sprite (regenerated by `npm run dev`); production sprite is hashed into dist/.
site-astro/public/sprite.svg

# Generated root artifacts from npm run build
css/style.css
data/generated-manifest.json
data/*.generated.json
# Allow snapshots of data files needed at build time by astro check
# (which reads content.config.ts before our build pipeline can regenerate them)
!data/books.generated.json
!data/people.merged.generated.json
!data/countries.slim.generated.json
!data/photos.generated.json
!data/routes.generated.json
!data/remote-assets.generated.json
# images/generated/ used to be ignored, but CI can't reliably regenerate
# them inside the 30-min job timeout, so we ship pre-optimized variants
# in-tree. Regenerate locally via `npm run assets:optimize` when adding
# new source images; commit the resulting variants.
images/source/remote/
sitemap.xml
llms.txt
.gstack/
.perf-tmp/*.run-*.json
.claude/scheduled_tasks.lock
.codex_tmp/

# OCR training artifact occasionally dropped at repo root by tooling
eng.traineddata

# Claude auto-batch hook artifacts
.claude/edit-count.txt
.claude/auto-batch.log
.claude/scripts/

# Local git worktrees (should never be tracked)
.claude/worktrees/
